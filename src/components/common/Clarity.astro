---
// Microsoft Clarity — per-visitor session replay + heatmaps (click/scroll/dwell).
// This is the "watch what a visitor actually did" layer that GA and Vercel
// Analytics don't provide.
//
// SETUP (one-time): create a free project at https://clarity.microsoft.com,
// then paste its Project ID below (a short string like "sa9f3k2x1q") — find it
// under Settings → Overview, or in the install snippet ("/tag/<ID>").
// Empty string = nothing is injected (safe default).
//
// Privacy: Clarity masks text inputs by default. The /privacy page discloses
// session analytics when this is active.
const CLARITY_ID = 'x5h8gmhtc5';

const clarityTag = CLARITY_ID
  ? `(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);})(window,document,"clarity","script","${CLARITY_ID}");`
  : '';
---

{clarityTag ? <script type="text/javascript" set:html={clarityTag} /> : null}
