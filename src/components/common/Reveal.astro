---
// Global scroll-reveal motion — restrained, premium, and BULLETPROOF.
// Design guarantees (so content can never be stuck invisible):
//   • Content is visible by default. Only BELOW-the-fold [data-reveal] blocks get
//     hidden (by JS, after paint, while off-screen) and fade up as they scroll in.
//   • Above-the-fold blocks (hero) are never hidden → instant paint, no LCP hit.
//   • No-JS, JS-error, or prefers-reduced-motion → nothing is hidden, everything shows.
//   • Plain rAF-throttled passive scroll/resize listener (no IntersectionObserver
//     dependency) — simple, reliable on every device.
// Opt in per element with `data-reveal`; the system is inert until used.
---

<style is:global>
  @media (prefers-reduced-motion: no-preference) {
    [data-reveal].reveal-hidden {
      opacity: 0;
      transform: translateY(16px);
    }
    [data-reveal].reveal-in {
      opacity: 1;
      transform: none;
      transition:
        opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }
  }
</style>
<script>
  function initReveal() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const all = Array.from(document.querySelectorAll('[data-reveal]'));
    if (!all.length) return;
    const vh = () => window.innerHeight || document.documentElement.clientHeight || 0;

    // Guard: never arm against a zero/invalid viewport height (would trap the hero hidden).
    // Wait a frame until the layout reports a real height.
    if (!vh()) {
      requestAnimationFrame(initReveal);
      return;
    }

    // Arm only what's below the fold at load — above-the-fold stays instantly visible.
    let pending = all.filter((el) => el.getBoundingClientRect().top >= vh() * 0.9);
    pending.forEach((el) => el.classList.add('reveal-hidden'));
    if (!pending.length) return;

    let ticking = false;
    function check() {
      ticking = false;
      const limit = vh() * 0.92;
      pending = pending.filter((el) => {
        if (el.getBoundingClientRect().top < limit) {
          el.classList.remove('reveal-hidden');
          el.classList.add('reveal-in');
          return false;
        }
        return true;
      });
      if (!pending.length) {
        window.removeEventListener('scroll', onScroll);
        window.removeEventListener('resize', onScroll);
      }
    }
    function onScroll() {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(check);
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  }
  document.addEventListener('astro:page-load', initReveal);
</script>
