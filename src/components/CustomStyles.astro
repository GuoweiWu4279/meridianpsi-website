---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #b45309;       /* amber-600 */
    --aw-color-secondary: #92400e;     /* amber-700 */
    --aw-color-accent: #b45309;

    --aw-color-text-heading: #18181b;  /* zinc-900 */
    --aw-color-text-default: #3f3f46;  /* zinc-700 */
    --aw-color-text-muted: #71717a;    /* zinc-500 */
    --aw-color-bg-page: white;

    --aw-color-bg-page-dark: rgb(9 9 11); /* zinc-950 */

    ::selection {
      background-color: #fef3c7;
      color: #78350f;
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: #fbbf24;
    --aw-color-secondary: #fde68a;
    --aw-color-accent: #fbbf24;

    --aw-color-text-heading: #fafafa;
    --aw-color-text-default: #e4e4e7;
    --aw-color-text-muted: #a1a1aa;
    --aw-color-bg-page: rgb(9 9 11);

    ::selection {
      background-color: #78350f;
      color: #fef3c7;
    }
  }
</style>
