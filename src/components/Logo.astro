---
import { SITE } from 'astrowind:config';

interface Props {
  variant?: 'header' | 'compact';
}

const { variant = 'header' } = Astro.props;
const name = SITE?.name ?? 'Meridian';

// Horizontal layout: ECG wave on left, wordmark on right — naturally wide,
// no background, currentColor wordmark follows theme automatically.
const sizeClass =
  variant === 'compact'
    ? 'h-8 w-auto'
    : 'h-11 md:h-12 w-auto';
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 200 44"
  role="img"
  aria-label={`${name} — home`}
  class:list={[sizeClass, 'self-center text-zinc-900 dark:text-zinc-50']}
>
  <!-- ECG wave, left side -->
  <path
    d="M 8 22 L 36 22 L 44 8 L 52 38 L 60 22 L 88 22"
    fill="none"
    stroke="#10b981"
    stroke-width="2.8"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <!-- Subtle divider -->
  <line x1="96" y1="8" x2="96" y2="36" stroke="currentColor" stroke-width="0.75" opacity="0.2" />
  <!-- Wordmark, right side -->
  <text
    x="106"
    y="27"
    dominant-baseline="middle"
    font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif"
    font-size="13.5"
    font-weight="500"
    letter-spacing="3"
    fill="currentColor"
  >MERIDIAN</text>
</svg>
