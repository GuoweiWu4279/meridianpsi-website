---
interface Props {
  lastUpdated: string;
}
const { lastUpdated } = Astro.props;
---

<section class="border-b border-zinc-100 dark:border-zinc-800 bg-gradient-to-b from-emerald-50/50 to-white dark:from-emerald-950/20 dark:to-zinc-950">
  <div class="max-w-6xl mx-auto px-6 pt-12 pb-10">

    <!-- Eyebrow -->
    <p class="text-xs font-medium uppercase tracking-widest text-emerald-700 dark:text-emerald-500 mb-5 flex items-center gap-2">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-600" aria-hidden="true"></span>
      Creator Kit · Meridian Partner Program
    </p>

    <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50 mb-3">
      Welcome<span id="name-display"></span>.
    </h1>

    <p class="text-base text-zinc-500 dark:text-zinc-400 mb-8 max-w-xl leading-relaxed">
      Your toolkit for making Meridian content — personalized assets, talking points, compliance, and ready-to-paste scripts. Everything in one place.
    </p>

    <!-- Three cards -->
    <div class="grid sm:grid-cols-3 gap-3 mb-5" id="hero-cards">

      <!-- Affiliate link -->
      <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4">
        <p class="text-xs font-medium uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-2">Affiliate link</p>
        <p class="text-sm font-mono text-zinc-700 dark:text-zinc-200 break-all mb-3 leading-snug"
           data-personalize="link" data-fallback="whop.com/meridian/?a=YOURNAME">
          whop.com/meridian/?a=YOURNAME
        </p>
        <button type="button"
          class="hero-copy-btn flex items-center gap-1.5 text-xs text-zinc-400 hover:text-emerald-700 dark:hover:text-emerald-400 transition-colors focus-visible:outline-none"
          data-copy-from="link" aria-label="Copy affiliate link">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          <span class="copy-label">Copy</span>
        </button>
      </div>

      <!-- Promo code -->
      <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4">
        <p class="text-xs font-medium uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-2">Promo code</p>
        <p class="text-xl font-mono font-bold tracking-widest text-zinc-900 dark:text-zinc-50 mb-3"
           data-personalize="code" data-fallback="YOURNAME10">
          YOURNAME10
        </p>
        <button type="button"
          class="hero-copy-btn flex items-center gap-1.5 text-xs text-zinc-400 hover:text-emerald-700 dark:hover:text-emerald-400 transition-colors focus-visible:outline-none"
          data-copy-from="code" aria-label="Copy promo code">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          <span class="copy-label">Copy</span>
        </button>
      </div>

      <!-- Guard license -->
      <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4">
        <p class="text-xs font-medium uppercase tracking-widest text-zinc-400 dark:text-zinc-500 mb-2">Guard license</p>
        <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-50 mb-1">Active — full Guard tier</p>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-snug">Activate inside the Meridian Dashboard with the key from your welcome email.</p>
      </div>
    </div>

    <!-- No-params hint -->
    <p id="hero-placeholder-note" class="hidden text-xs text-zinc-400 dark:text-zinc-500">
      Open your Creator Kit using the link in your welcome email to auto-fill your personal link and code above.
    </p>

    <!-- Meta line -->
    <p class="text-xs text-zinc-400 dark:text-zinc-500 mt-6">
      Last updated: <time datetime={lastUpdated}>{lastUpdated}</time>
      <span class="mx-2">·</span>
      Questions? <a href="mailto:garycaffrey@meridian-partnership.com" class="underline hover:text-zinc-600">garycaffrey@meridian-partnership.com</a>
    </p>
  </div>
</section>

<script>
  (function () {
    const params = new URLSearchParams(window.location.search);
    const name = params.get('name');
    const code = params.get('code');
    const link = params.get('link');

    if (name) {
      const el = document.getElementById('name-display');
      if (el) el.textContent = ', ' + decodeURIComponent(name);
    }

    function fill(key: string, val: string | null) {
      if (!val) return;
      document.querySelectorAll<HTMLElement>(`[data-personalize="${key}"]`).forEach((el) => {
        el.textContent = decodeURIComponent(val);
      });
    }
    fill('code', code);
    fill('link', link);

    if (!code && !link) {
      document.getElementById('hero-placeholder-note')?.classList.remove('hidden');
    }

    document.querySelectorAll<HTMLButtonElement>('.hero-copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const key = btn.dataset.copyFrom ?? '';
        const src = document.querySelector<HTMLElement>(`[data-personalize="${key}"]`);
        const text = src?.textContent?.trim() ?? '';
        try { await navigator.clipboard.writeText(text); }
        catch {
          const ta = Object.assign(document.createElement('textarea'), { value: text });
          Object.assign(ta.style, { position: 'fixed', opacity: '0' });
          document.body.appendChild(ta); ta.focus(); ta.select();
          document.execCommand('copy'); document.body.removeChild(ta);
        }
        const label = btn.querySelector<HTMLElement>('.copy-label');
        if (label) {
          label.textContent = 'Copied';
          setTimeout(() => { label.textContent = 'Copy'; }, 1500);
        }
      });
    });
  })();
</script>
