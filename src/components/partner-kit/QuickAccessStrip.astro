---
interface Props {
  oneSentencePitch: string;
  ftcShortDisclosure: string;
  promoCodeTemplate: string;
}

const { oneSentencePitch, ftcShortDisclosure, promoCodeTemplate } = Astro.props;

const items = [
  {
    label: 'One-sentence pitch',
    text: oneSentencePitch,
    id: 'strip-pitch',
    iconPath: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  },
  {
    label: 'FTC short disclosure',
    text: ftcShortDisclosure,
    id: 'strip-ftc',
    iconPath: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    label: 'Promo code line',
    text: promoCodeTemplate,
    id: 'strip-promo',
    iconPath: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z',
  },
];
---

<section class="max-w-6xl mx-auto px-6 pt-2 pb-2" aria-label="Quick-copy snippets">
  <div class="grid sm:grid-cols-3 gap-2">
    {items.map((item) => (
      <button
        type="button"
        class="strip-copy-btn group flex items-start gap-3 p-4 rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 hover:border-emerald-300 dark:hover:border-emerald-700 transition-colors text-left focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/40"
        data-strip-copy={item.text}
        data-strip-id={item.id}
        aria-label={`Copy ${item.label.toLowerCase()}`}
      >
        <svg class="shrink-0 w-4 h-4 text-zinc-400 group-hover:text-emerald-700 dark:group-hover:text-emerald-400 transition-colors mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.iconPath} />
        </svg>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100 flex items-center gap-2">
            {item.label}
            <span class="strip-feedback opacity-0 text-xs font-normal text-emerald-600 dark:text-emerald-400 transition-opacity">Copied</span>
          </p>
          <p class="strip-preview text-xs text-zinc-500 dark:text-zinc-400 mt-0.5 leading-snug line-clamp-2">{item.text}</p>
        </div>
      </button>
    ))}
  </div>
</section>

<script>
  function personalize(text: string): string {
    const code = localStorage.getItem('meridian-kit:code') ?? '';
    const link = localStorage.getItem('meridian-kit:link') ?? '';
    return text
      .replace(/\[YOURCODE\]/g, code || '[YOURCODE]')
      .replace(/\[YOUR AFFILIATE LINK\]/g, link || '[YOUR AFFILIATE LINK]');
  }

  // Update promo code preview text in strip from localStorage
  function refreshStrip() {
    const code = localStorage.getItem('meridian-kit:code') ?? '';
    document.querySelectorAll<HTMLButtonElement>('.strip-copy-btn').forEach((btn) => {
      if (btn.dataset.stripId === 'strip-promo' && code) {
        const preview = btn.querySelector<HTMLElement>('.strip-preview');
        if (preview) preview.textContent = btn.dataset.stripCopy!.replace(/\[YOURCODE\]/g, code);
      }
    });
  }
  refreshStrip();

  document.querySelectorAll<HTMLButtonElement>('.strip-copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = personalize(btn.dataset.stripCopy ?? '');
      try { await navigator.clipboard.writeText(text); }
      catch {
        const ta = Object.assign(document.createElement('textarea'), { value: text });
        Object.assign(ta.style, { position: 'fixed', opacity: '0' });
        document.body.appendChild(ta); ta.focus(); ta.select();
        document.execCommand('copy'); document.body.removeChild(ta);
      }
      const fb = btn.querySelector<HTMLElement>('.strip-feedback');
      if (fb) {
        fb.style.opacity = '1';
        setTimeout(() => { fb.style.opacity = '0'; }, 1500);
      }
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
