---
interface Props {
  id: string;
  numLabel: string;
  title: string;
  subtitle?: string;
  defaultOpen?: boolean;
}

const { id, numLabel, title, subtitle, defaultOpen = false } = Astro.props;
---

<details
  id={id}
  class="kit-section group scroll-mt-24 rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 overflow-hidden open:shadow-sm transition-shadow"
  data-default-open={defaultOpen ? 'true' : 'false'}
  open={defaultOpen}
>
  <summary
    class="list-none cursor-pointer select-none px-6 py-5 flex items-center gap-4 hover:bg-zinc-50 dark:hover:bg-zinc-900/60 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/40 focus-visible:ring-offset-2"
    aria-controls={`${id}-content`}
  >
    <span
      class="shrink-0 w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 text-xs font-bold flex items-center justify-center"
      aria-hidden="true"
    >
      {numLabel}
    </span>
    <div class="flex-1 min-w-0">
      <h2 class="text-lg sm:text-xl font-semibold text-zinc-900 dark:text-zinc-50">{title}</h2>
      {subtitle && (
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-0.5 leading-snug">{subtitle}</p>
      )}
    </div>
    <svg
      class="shrink-0 w-4 h-4 text-zinc-400 transition-transform group-open:rotate-180"
      fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </summary>

  <div
    id={`${id}-content`}
    class="px-6 pb-8 pt-2 border-t border-zinc-100 dark:border-zinc-800"
  >
    <slot />
  </div>
</details>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details > summary::marker { content: ''; }

  @media print {
    .kit-section { display: block !important; }
    .kit-section > summary svg { display: none !important; }
    .kit-section > div { display: block !important; }
  }
</style>

<script>
  (function () {
    const PREFIX = 'meridian-kit:section-open:';
    document.querySelectorAll<HTMLDetailsElement>('.kit-section').forEach((el) => {
      const stored = localStorage.getItem(PREFIX + el.id);
      if (stored !== null) el.open = stored === '1';
      else el.open = el.dataset.defaultOpen === 'true';
      el.addEventListener('toggle', () => {
        localStorage.setItem(PREFIX + el.id, el.open ? '1' : '0');
      });
    });

    function openTargeted() {
      const id = window.location.hash.slice(1);
      if (!id) return;
      const el = document.getElementById(id);
      if (el?.matches('.kit-section')) (el as HTMLDetailsElement).open = true;
      const parent = el?.closest<HTMLDetailsElement>('.kit-section');
      if (parent) parent.open = true;
    }
    openTargeted();
    window.addEventListener('hashchange', openTargeted);
  })();
</script>
