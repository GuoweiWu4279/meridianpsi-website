---
/**
 * RiskBanner — required on every page per compliance rules.
 * DO NOT REMOVE OR HIDE. See .cursor/rules/03-compliance-rules.mdc
 */
---

<div class="w-full" style="background: rgba(255,252,248,0.82); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);">
  <div class="flex items-center justify-center gap-1.5 flex-wrap px-4 py-1.5 text-xs leading-none" style="color:#78350f;">
    <span class="font-semibold whitespace-nowrap">Risk disclosure:</span>
    <span class="whitespace-nowrap">Trading involves substantial risk of loss.</span>
    <span class="opacity-30 hidden sm:inline" aria-hidden="true">·</span>
    <span class="whitespace-nowrap">Past performance is not indicative of future results.</span>
    <span class="opacity-30 hidden sm:inline" aria-hidden="true">·</span>
    <span class="whitespace-nowrap">Meridian is a behavioral monitoring tool and does not constitute financial advice.</span>
    <a href="/disclaimer" class="underline underline-offset-2 font-medium whitespace-nowrap hover:opacity-75 transition-opacity">
      Full disclaimer &rarr;
    </a>
  </div>
</div>
