---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';

// ─────────────────────────────────────────────────────────────────────────────
// ARTICLES — the editorial index. Voice register: OBJECTIVE / editorial.
// Job: list every published post cleanly so readers and crawlers find them.
// Design system matches the homepage (index.astro): light site, emerald accent,
// halo hero band, eyebrow + H2 scale, rounded-2xl zinc-bordered cards. Header,
// Footer, RiskBanner come from PageLayout. The post collection wiring and the
// category-filter script below are load-bearing — do not break them.
// ─────────────────────────────────────────────────────────────────────────────

const metadata = {
  title: 'Trading Psychology & Risk Management Articles',
  description:
    'In-depth articles on trading psychology, risk management, and execution discipline for active NinjaTrader 8 futures traders — the research behind behavioral risk management.',
  robots: { index: true, follow: true },
};

const allPosts = await getCollection('post');

const posts = await Promise.all(
  allPosts
    .filter((p) => !p.data.draft)
    .sort((a, b) => {
      const da = a.data.publishDate ? new Date(a.data.publishDate).valueOf() : 0;
      const db = b.data.publishDate ? new Date(b.data.publishDate).valueOf() : 0;
      return db - da;
    })
    .map(async (post) => {
      const { remarkPluginFrontmatter } = await render(post);
      return {
        ...post,
        readingTime: remarkPluginFrontmatter?.readingTime as number | undefined,
        resolvedImage: post.data.image ? await findImage(post.data.image) : null,
      };
    })
);

const categoryMap: Record<string, string> = {
  'trading-psychology': 'Trading Psychology',
  'risk-management':    'Risk Management',
  'prop-trading':       'Prop Trading',
  'execution':          'Execution',
};

const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))];

function formatDate(d?: Date) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

const SITE = 'https://www.meridianpsi.com';

const featured = posts[0];
const rest = posts.slice(1);

// ─────────────────────────────────────────────────────────────────────────────
// JSON-LD: a Blog + CollectionPage built from the real post collection, so the
// index is legible to crawlers and GEO. Injected via set:html — inline
// `{JSON.stringify({...})}` breaks because Astro reads an inner `}` as closing
// the expression.
// ─────────────────────────────────────────────────────────────────────────────
const articlesJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Blog',
      '@id': `${SITE}/articles#blog`,
      name: 'Meridian — Trading Insights',
      description: metadata.description,
      url: `${SITE}/articles`,
      publisher: { '@id': `${SITE}/#organization` },
      blogPost: posts.map((post) => ({
        '@type': 'BlogPosting',
        headline: post.data.title,
        description: post.data.excerpt ?? undefined,
        url: `${SITE}${getPermalink(post.id, 'post')}`,
        datePublished: post.data.publishDate ? new Date(post.data.publishDate).toISOString() : undefined,
        author: { '@type': 'Organization', name: post.data.author ?? 'Meridian' },
        keywords: post.data.tags?.join(', ') || undefined,
      })),
    },
    {
      '@type': 'CollectionPage',
      '@id': `${SITE}/articles#webpage`,
      name: 'Trading Insights — Meridian',
      description: metadata.description,
      url: `${SITE}/articles`,
      isPartOf: { '@id': `${SITE}/#website` },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
        { '@type': 'ListItem', position: 2, name: 'Trading Insights', item: `${SITE}/articles` },
      ],
    },
  ],
};

const articlesJsonLdHtml = JSON.stringify(articlesJsonLd).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <!-- Structured data: Blog + CollectionPage + breadcrumbs, built from the post collection -->
  <script type="application/ld+json" set:html={articlesJsonLdHtml} />

  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="halo">
    <div class="max-w-5xl mx-auto px-6 pt-20 md:pt-24 pb-12 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-4">TRADING INSIGHTS</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-[1.06]">
        The research behind<br />behavioral risk management.
      </h1>
      <p class="mt-7 max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 leading-relaxed">
        Trading psychology, risk management, and execution discipline for active NinjaTrader 8 futures traders &mdash;
        the mechanisms behind why accounts fail under pressure, and what the research says about managing it.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── INDEX ───────────────────────── -->
  <section class="border-t border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-16 md:py-20">

      <!-- Category tabs -->
      {categories.length > 0 && (
        <div class="flex flex-wrap items-center gap-2.5 mb-12" id="cat-tabs">
          <button
            data-cat="all"
            class="cat-btn active text-sm font-medium px-4 py-2 rounded-full border border-emerald-500 bg-emerald-600 text-white transition-colors"
          >
            All Posts
          </button>
          {categories.map((cat) => (
            <button
              data-cat={cat}
              class="cat-btn text-sm font-medium px-4 py-2 rounded-full border border-zinc-200 bg-white text-zinc-600 hover:border-zinc-400 hover:text-zinc-900 transition-colors"
            >
              {categoryMap[cat!] ?? cat}
            </button>
          ))}
        </div>
      )}

      <!-- Featured post — full-width lead card -->
      {featured && (
        <a
          href={getPermalink(featured.id, 'post')}
          data-cat={featured.data.category ?? ''}
          class="article-card group block rounded-2xl border border-zinc-200 bg-[#fafafa] overflow-hidden hover:border-zinc-300 hover:shadow-sm transition mb-8"
        >
          <div class="grid md:grid-cols-2">
            <div class="overflow-hidden bg-zinc-900 md:order-2" style="aspect-ratio: 16/10;">
              {featured.resolvedImage ? (
                <img
                  src={typeof featured.resolvedImage === 'string'
                    ? featured.resolvedImage
                    : (featured.resolvedImage as any).src ?? featured.resolvedImage}
                  alt={featured.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                  loading="eager"
                />
              ) : (
                <div class="w-full h-full bg-gradient-to-br from-zinc-800 via-zinc-700 to-emerald-900 flex items-end p-7">
                  <span class="text-[10px] font-semibold tracking-widest uppercase text-emerald-400/90">
                    {categoryMap[featured.data.category ?? ''] ?? featured.data.category ?? 'Article'}
                  </span>
                </div>
              )}
            </div>
            <div class="flex flex-col justify-center p-8 md:p-10 md:order-1">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-[11px] font-bold tracking-widest uppercase text-emerald-700">
                  {categoryMap[featured.data.category ?? ''] ?? featured.data.category ?? 'Featured'}
                </span>
                <span class="text-zinc-300">&middot;</span>
                <span class="text-xs text-zinc-500 tnum">{formatDate(featured.data.publishDate)}</span>
              </div>
              <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 leading-snug group-hover:text-emerald-700 transition-colors">
                {featured.data.title}
              </h2>
              {featured.data.excerpt && (
                <p class="mt-4 text-lg text-zinc-600 leading-relaxed line-clamp-3">{featured.data.excerpt}</p>
              )}
              <div class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-emerald-700">
                Read article
                <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 12h14" /><path d="M13 6l6 6-6 6" /></svg>
                {featured.readingTime && <span class="text-zinc-400 font-normal tnum">{featured.readingTime} min read</span>}
              </div>
            </div>
          </div>
        </a>
      )}

      <!-- Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="articles-grid">
        {rest.map((post) => {
          const cat = post.data.category ?? '';
          const label = categoryMap[cat] ?? cat;
          const href = getPermalink(post.id, 'post');
          const mins = post.readingTime;
          const date = formatDate(post.data.publishDate);
          const img = post.resolvedImage;

          return (
            <a
              href={href}
              data-cat={cat}
              class="article-card group flex flex-col rounded-2xl border border-zinc-200 bg-white overflow-hidden hover:border-zinc-300 hover:shadow-sm transition"
            >
              <!-- Cover -->
              <div class="overflow-hidden bg-zinc-900 shrink-0" style="aspect-ratio: 16/9;">
                {img ? (
                  <img
                    src={typeof img === 'string' ? img : (img as any).src ?? img}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-500"
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-zinc-800 via-zinc-700 to-emerald-900 flex items-end p-5">
                    <span class="text-[10px] font-semibold tracking-widest uppercase text-emerald-400/90">
                      {label || 'Article'}
                    </span>
                  </div>
                )}
              </div>

              <!-- Body -->
              <div class="flex flex-col flex-1 p-6">
                <div class="flex items-center gap-2.5 mb-3 text-xs">
                  {label && <span class="font-bold tracking-widest uppercase text-emerald-700">{label}</span>}
                  {label && <span class="text-zinc-300">&middot;</span>}
                  <span class="text-zinc-500 tnum">{date}</span>
                </div>

                <h2 class="text-lg font-bold text-zinc-900 leading-snug group-hover:text-emerald-700 transition-colors">
                  {post.data.title}
                </h2>

                {post.data.excerpt && (
                  <p class="mt-3 text-sm text-zinc-600 leading-relaxed line-clamp-3">{post.data.excerpt}</p>
                )}

                <div class="flex-1"></div>

                {mins && (
                  <div class="mt-5 pt-4 border-t border-zinc-100 text-xs text-zinc-400 tnum">{mins} min read</div>
                )}
              </div>
            </a>
          );
        })}
      </div>

      <!-- Empty state -->
      {posts.length === 0 && (
        <p class="text-center text-zinc-400 py-24">No articles yet. Check back soon.</p>
      )}
    </div>
  </section>

  <!-- ───────────────────────── CTA ───────────────────────── -->
  <section class="halo">
    <div class="max-w-3xl mx-auto px-6 py-24 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">FROM READING TO PRACTICE</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 leading-tight">
        The research is the easy part.<br />Acting on it mid-session isn't.
      </h2>
      <p class="mt-5 text-lg text-zinc-600">
        Meridian does everything a traditional NinjaTrader 8 risk tool does &mdash; daily loss limits, drawdown
        caps, loss-streak cutoffs &mdash; plus the behavioral layer none of them have: it surfaces revenge, oversizing, and tilt in real time and
        intervenes before the order.
      </p>
      <div class="mt-9">
        <a href="/pricing" class="inline-block font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-8 py-4 rounded-xl text-lg transition shadow-sm">Start your 14-day free trial</a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">No charge until day 14 &middot; From $49.99/mo &middot; Cancel anytime</p>
    </div>
  </section>
</Layout>

<style>
  .cat-btn.active {
    background-color: #059669;
    border-color: #10b981;
    color: #fff;
  }
</style>

<script>
  // Category filter. Re-attach on every Astro client-side navigation (View Transitions).
  function initArticleFilter() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.cat-btn');
    const cards = document.querySelectorAll<HTMLElement>('.article-card');
    if (!tabs.length) return;

    const ACTIVE = ['active', 'bg-emerald-600', 'border-emerald-500', 'text-white'];
    const IDLE = ['bg-white', 'border-zinc-200', 'text-zinc-600'];

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const cat = tab.dataset.cat ?? 'all';

        tabs.forEach((t) => {
          t.classList.remove(...ACTIVE);
          t.classList.add(...IDLE);
        });
        tab.classList.remove(...IDLE);
        tab.classList.add(...ACTIVE);

        cards.forEach((card) => {
          card.style.display = cat === 'all' || card.dataset.cat === cat ? '' : 'none';
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initArticleFilter);
</script>
