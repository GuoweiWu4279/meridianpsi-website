---
// src/pages/admin/usage.astro
// Private usage dashboard — the "who's using Meridian / P&L / churn / signals" report
// as a live web page. Static shell: ALL data flows through /api/admin/research?action=snapshot
// (x-admin-key == RESEARCH_ADMIN_SECRET). The snapshot is published by ~/.meridian/usage.py publish
// (near-real-time via a scheduled task). The key lives in the browser's localStorage only
// (shared with /admin/research) — entered once, never rendered into the HTML.
//
// NOTE: styles are is:global ON PURPOSE. The dashboard body is built at runtime via innerHTML,
// so Astro's default scoped styles would NOT bind to those nodes (they lack the scope attribute).
// This is a standalone full-document page (no shared Layout), so global styles have zero blast radius.
export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Usage — Admin</title>
    <style is:global>
      :root {
        --bg: #0b0b0d; --panel: #17171a; --panel2: #1e1e22; --line: #2a2a30;
        --fg: #ededf0; --fg2: #9a9aa4; --fg3: #64646e;
        --accent: #34d399; --amber: #f5c451; --danger: #f47272; --blue: #6cc4ff;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; background: var(--bg); color: var(--fg);
        font: 14px/1.55 ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      .wrap { max-width: 1120px; margin: 0 auto; padding: 30px 22px 90px; }
      .mono { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
      .tnum { font-variant-numeric: tabular-nums; }
      .hidden { display: none !important; }

      /* header */
      .head { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; flex-wrap: wrap; margin-bottom: 6px; }
      h1 { font-size: 21px; font-weight: 650; margin: 0; letter-spacing: -0.01em; }
      .sub { color: var(--fg2); font-size: 13px; margin: 2px 0 0; }
      .sub a { color: var(--accent); text-decoration: none; }
      .sub a:hover { text-decoration: underline; }
      .toolbar { display: flex; align-items: center; gap: 9px; flex-wrap: wrap; }
      button { background: var(--panel2); border: 1px solid var(--line); color: var(--fg); border-radius: 8px; padding: 7px 12px; font-size: 12.5px; cursor: pointer; }
      button:hover { background: #26262c; }
      button.primary { background: var(--accent); border-color: var(--accent); color: #06281c; font-weight: 600; }
      .stamp { color: var(--fg3); font-size: 12px; }

      /* login gate */
      .card { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 18px; margin-top: 18px; }
      input { background: var(--panel2); border: 1px solid var(--line); color: var(--fg); border-radius: 8px; padding: 9px 11px; font-size: 14px; width: 280px; max-width: 60vw; }
      .err { color: var(--danger); margin-top: 10px; font-size: 13px; }

      /* KPI rail */
      .kpis { display: grid; grid-template-columns: repeat(auto-fit, minmax(148px, 1fr)); gap: 11px; margin: 20px 0 8px; }
      .kpi { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 14px 16px; }
      .kpi .n { font-size: 25px; font-weight: 680; line-height: 1.05; letter-spacing: -0.01em; }
      .kpi .l { color: var(--fg2); font-size: 12px; margin-top: 3px; }
      .kpi .d { font-size: 12px; font-weight: 600; margin-left: 6px; }
      .kpi.warn .n { color: var(--amber); }
      .pos { color: var(--accent); } .neg { color: var(--danger); }
      .period { color: var(--fg3); font-size: 12px; margin: 6px 2px 0; }

      /* section headers */
      .sh { font-size: 11px; text-transform: uppercase; letter-spacing: 0.09em; color: var(--fg2); margin: 30px 0 13px; display: flex; align-items: center; gap: 9px; }
      .sh::after { content: ""; flex: 1; height: 1px; background: var(--line); }
      .sh .count { color: var(--fg3); letter-spacing: 0; text-transform: none; }

      /* roster grid */
      .roster { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(430px, 100%), 1fr)); gap: 13px; align-items: start; }
      .u { background: var(--panel); border: 1px solid var(--line); border-radius: 14px; padding: 0; overflow: hidden; }
      .u.trader { border-left: 3px solid var(--accent); }
      .u.churn { border-left: 3px solid var(--amber); }
      .u-body { padding: 15px 17px 4px; }
      .u-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
      .u-name { font-size: 15.5px; font-weight: 640; letter-spacing: -0.01em; }
      .u-sub { color: var(--fg2); font-size: 12px; margin-top: 2px; }
      .u-sub .em { color: var(--fg); }
      .pills { display: flex; gap: 5px; flex-wrap: wrap; justify-content: flex-end; }
      .pill { border-radius: 999px; padding: 2px 9px; font-size: 10.5px; font-weight: 650; letter-spacing: 0.01em; white-space: nowrap; background: #2a2a30; color: var(--fg2); }
      .pill.live { background: rgba(52,211,153,0.15); color: var(--accent); }
      .pill.churn { background: rgba(245,196,81,0.15); color: var(--amber); }
      .pill.blue { background: rgba(108,196,255,0.15); color: var(--blue); }

      /* hero metrics */
      .hero { display: flex; gap: 10px; margin: 14px 0 12px; }
      .metric { flex: 1; background: var(--panel2); border: 1px solid var(--line); border-radius: 10px; padding: 10px 12px; }
      .metric .mn { font-size: 22px; font-weight: 680; line-height: 1.1; letter-spacing: -0.02em; }
      .metric .ml { color: var(--fg2); font-size: 11px; margin-top: 2px; }
      .metric.psi.low .mn { color: var(--amber); }
      .metric.muted { background: transparent; border-style: dashed; }
      .metric.muted .mn { color: var(--fg2); font-size: 16px; font-weight: 600; }

      /* stat cluster */
      .cluster { display: grid; grid-template-columns: 1fr 1fr; gap: 6px 16px; margin-bottom: 12px; }
      .cell { font-size: 12.5px; color: var(--fg); display: flex; justify-content: space-between; gap: 8px; padding: 3px 0; border-bottom: 1px solid rgba(42,42,48,0.5); }
      .cell .ck { color: var(--fg2); }

      /* feature bars */
      .feats { margin-bottom: 10px; }
      .feats-empty { color: var(--fg3); font-size: 12px; font-style: italic; margin-bottom: 10px; }
      .feat { display: grid; grid-template-columns: 78px 1fr 30px; align-items: center; gap: 9px; margin: 5px 0; }
      .feat .fl { color: var(--fg2); font-size: 11.5px; }
      .feat .track { height: 5px; background: #26262c; border-radius: 3px; overflow: hidden; }
      .feat .fill { height: 100%; background: var(--fg3); border-radius: 3px; }
      .feat.top .fill { background: var(--accent); }
      .feat .fv { font-size: 11.5px; color: var(--fg2); text-align: right; }
      .feat.top .fv { color: var(--fg); font-weight: 600; }

      /* read footer */
      .read { border-top: 1px solid var(--line); padding: 10px 17px; background: rgba(0,0,0,0.18); color: var(--fg); font-size: 12.5px; }
      .read .rk { color: var(--fg3); }

      /* churn / signals lists */
      .list { display: flex; flex-direction: column; gap: 8px; }
      .li { background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 11px 14px; font-size: 13px; display: flex; align-items: center; gap: 10px; }
      .li.amber { border-left: 3px solid var(--amber); }
      .li.dot::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--fg3); flex-shrink: 0; }
      .li .grow { flex: 1; }

      /* by-day table */
      .tbl { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; overflow: hidden; }
      table { width: 100%; border-collapse: collapse; }
      th, td { text-align: right; padding: 9px 16px; font-size: 12.5px; border-bottom: 1px solid var(--line); }
      th:first-child, td:first-child { text-align: left; }
      tr:last-child td { border-bottom: none; }
      th { color: var(--fg2); font-weight: 500; font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.05em; }
      .devs { color: var(--fg3); font-size: 12px; }

      /* daily timeline */
      .tl-card { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 2px 18px; }
      .day { display: grid; grid-template-columns: 92px 1fr; gap: 16px; padding: 13px 0; border-top: 1px solid var(--line); }
      .day:first-child { border-top: none; }
      .day.empty .day-rel, .day.empty .day-date { opacity: 0.6; }
      .day-rel { font-size: 14px; font-weight: 640; }
      .day-rel.today { color: var(--accent); }
      .day-date { color: var(--fg2); font-size: 11.5px; margin-top: 2px; }
      .day-sum { font-size: 12px; color: var(--fg2); margin-bottom: 7px; }
      .day-none { font-size: 12.5px; color: var(--fg3); padding: 1px 0; }
      .day-u { padding: 5px 0; font-size: 13px; }
      .day-u-top { display: flex; align-items: center; gap: 10px; }
      .day-u .ddot { width: 7px; height: 7px; border-radius: 50%; background: var(--fg3); flex-shrink: 0; }
      .day-u .ddot.live { background: var(--accent); }
      .day-u .dn { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
      .day-u .da { color: var(--fg2); font-size: 12px; white-space: nowrap; }
      .day-u .dnet { width: 70px; text-align: right; font-weight: 600; }
      .day-u-act { margin-left: 17px; margin-top: 3px; color: var(--fg3); font-size: 11.5px; line-height: 1.5; }
      .day-u-act .tz { color: var(--fg2); }
      .ptag { font-size: 10px; font-weight: 650; padding: 1px 6px; border-radius: 999px; margin-left: 7px; white-space: nowrap; }
      .ptag.client { background: rgba(108,196,255,0.15); color: var(--blue); }
      .pill.client { background: rgba(108,196,255,0.15); color: var(--blue); }
    </style>
  </head>
  <body>
    <div class="wrap">
      <div class="head">
        <div>
          <h1>Meridian — 用户数据</h1>
          <p class="sub">谁在用 · 盈亏 · 谁在流失 · <a href="/admin/research">原始会话 →</a></p>
        </div>
        <div class="toolbar hidden" id="toolbar">
          <button id="refreshBtn">↻ 刷新</button>
          <button id="logoutBtn">忘记密钥</button>
          <span class="stamp" id="stamp"></span>
        </div>
      </div>

      <!-- Login gate (shares the key with /admin/research) -->
      <div id="login" class="card">
        <div style="margin-bottom:10px;">输入 admin key <span style="color:var(--fg2)">(本浏览器记住，无需重复输入)</span></div>
        <div style="display:flex; gap:10px; flex-wrap:wrap;">
          <input id="key" type="password" placeholder="RESEARCH_ADMIN_SECRET" autocomplete="off" />
          <button class="primary" id="loginBtn">解锁</button>
        </div>
        <div id="loginErr" class="err hidden"></div>
      </div>

      <!-- Dashboard -->
      <div id="dash" class="hidden"><div id="body"></div></div>
    </div>

    <script is:inline>
      const $ = (id) => document.getElementById(id);
      const API = '/api/admin/research';
      let KEY = localStorage.getItem('mpsi_admin_key') || '';
      let timer = null;

      const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      const money = (n) => { n = Number(n); return n === 0 ? '$0' : (n > 0 ? '+' : '−') + Math.abs(n).toLocaleString(); };
      const netCls = (n) => (n < 0 ? 'neg' : n > 0 ? 'pos' : '');

      function pill(f) {
        let c = 'pill';
        if (f === '交易中') c += ' live';
        else if (f === '流失中') c += ' churn';
        else if (f === '今天活跃' || f === '新' || f === '回归') c += ' blue';
        return `<span class="${c}">${esc(f)}</span>`;
      }

      function featBars(tabs) {
        const keys = ['Intelligence', 'Journal', 'History', 'Guard', 'Settings'];
        const zh = { Intelligence: 'Intel 智能', Journal: '日志', History: '历史', Guard: 'Guard', Settings: '设置' };
        const max = Math.max(1, ...keys.map((k) => tabs[k] || 0));
        return keys.map((k) => {
          const v = tabs[k] || 0;
          const top = v === max && v > 0 ? ' top' : '';
          const w = Math.round((v / max) * 100);
          return `<div class="feat${top}"><span class="fl">${zh[k]}</span><span class="track"><span class="fill" style="width:${w}%"></span></span><span class="fv tnum">${v}</span></div>`;
        }).join('');
      }

      function userCard(u) {
        const cls = 'u ' + ((u.flags || []).includes('流失中') ? 'churn' : u.tier === 'TRADER' ? 'trader' : '');
        const pills = (u.flags || []).map(pill).join('') + (u.platform === 'Client' ? '<span class="pill client">客户端</span>' : '');
        const noTrades = (u.rts || 0) === 0;
        const psiLow = u.psi_low != null && u.psi_low <= 20;
        const winr = u.winrate != null ? u.winrate + '% 胜' : '—';
        const acct = u.mode && u.mode !== '?' ? `${esc(u.mode)}/${esc(u.acctClass)}${u.vendor ? '/' + esc(u.vendor) : ''}` : '—';
        const tabsSum = ['Intelligence', 'Journal', 'History', 'Guard', 'Settings'].reduce((s, k) => s + ((u.tabs || {})[k] || 0), 0);

        const hero = noTrades
          ? `<div class="hero"><div class="metric muted"><div class="mn">未交易</div><div class="ml">装了 ${u.days_using} 天 · 从未下单</div></div></div>`
          : `<div class="hero">
              <div class="metric"><div class="mn ${netCls(u.net)} tnum">${money(u.net)}</div><div class="ml">生涯净 P&L ($)</div></div>
              <div class="metric psi ${psiLow ? 'low' : ''}"><div class="mn tnum">${u.psi_low ?? '?'}</div><div class="ml">PSI 最低${psiLow ? ' · 情绪失控' : ''}</div></div>
            </div>`;

        const feats = tabsSum === 0
          ? `<div class="feats-empty">复盘功能未使用</div>`
          : `<div class="feats">${featBars(u.tabs || {})}</div>`;

        return `
        <div class="${cls}">
          <div class="u-body">
            <div class="u-top">
              <div>
                <div class="u-name">${esc(u.label)}</div>
                <div class="u-sub"><span class="mono">${esc(u.install8)}</span> · tz ${esc(u.tz)} · 在用 <span class="em">${u.days_using}</span>天 · 最后 <span class="em">${u.last_ago}</span>天前</div>
              </div>
              <div class="pills">${pills}</div>
            </div>
            ${hero}
            <div class="cluster">
              <div class="cell"><span class="ck">生涯</span><span class="tnum">${u.sessions} 会话 · ${u.rts} 笔</span></div>
              <div class="cell"><span class="ck">胜率</span><span class="tnum">${winr}</span></div>
              <div class="cell"><span class="ck">本期</span><span class="tnum">+${u.period_sessions} 会话 · +${u.period_rts} 笔</span></div>
              <div class="cell"><span class="ck">账户</span><span>${acct}</span></div>
            </div>
            ${feats}
          </div>
          <div class="read"><span class="rk">读 · </span>${esc(u.read)}</div>
        </div>`;
      }

      const TAB_ZH = { Session: '监控', Intelligence: '智能', Journal: '日志', History: '历史', Guard: 'Guard', Settings: '设置', Profile: '档案', License: '授权' };
      function dur(m) { m = Math.round(m || 0); if (m < 60) return m + '分'; return Math.floor(m / 60) + '时' + (m % 60) + '分'; }

      function dailyHTML(days) {
        return days.map((day) => {
          const empty = day.users.length === 0;
          const relCls = day.rel === '今天' ? ' today' : '';
          const rows = day.users.map((u) => {
            const client = u.platform === 'Client';
            const dot = u.tier === 'TRADER' ? ' live' : '';
            const badge = client ? '<span class="ptag client">客户端</span>' : '';
            const act = u.rts > 0 ? `${u.sessions}会话 · ${u.rts}笔` : `${u.sessions}会话 · 未成交`;
            const net = u.rts > 0
              ? `<span class="dnet tnum ${netCls(u.net)}">${money(u.net)}</span>`
              : `<span class="dnet tnum" style="color:var(--fg3)">—</span>`;
            // what they actually did that day: duration + tabs opened + clicks + guard
            const tabs = (u.tabs || []).map(([n, c]) => `${TAB_ZH[n] || n}×${c}`).join(' ');
            const bits = [];
            if (u.dur > 0) bits.push(`<span class="tz">用了 ${dur(u.dur)}</span>`);
            if (tabs) bits.push('看了 ' + esc(tabs));
            if (u.clicks > 0) bits.push('点击 ' + u.clicks);
            if (u.guard > 0) bits.push('Guard ' + u.guard);
            const detail = bits.length ? bits.join(' · ') : (client ? '回填历史 · 无实时会话' : '无明细');
            return `<div class="day-u">
              <div class="day-u-top"><span class="ddot${dot}"></span><span class="dn">${esc(u.label)}${badge}</span><span class="da">${act}</span>${net}</div>
              <div class="day-u-act">${detail}</div>
            </div>`;
          }).join('');
          const sum = `<div class="day-sum">${day.users.length}人 · ${day.sessions}会话 · ${day.rts}笔 · 净 <span class="${netCls(day.net)}">${money(day.net)}</span>${day.dur ? ' · 共 ' + dur(day.dur) : ''}</div>`;
          return `
          <div class="day${empty ? ' empty' : ''}">
            <div class="day-when"><div class="day-rel${relCls}">${esc(day.rel)}</div><div class="day-date">${esc(day.date)} ${esc(day.wd)}</div></div>
            <div class="day-main">${empty ? '<div class="day-none">无活跃</div>' : sum + rows}</div>
          </div>`;
        }).join('');
      }

      function fmtAgo(iso) {
        const min = Math.max(0, Math.round((Date.now() - new Date(iso).getTime()) / 60000));
        if (min < 1) return '刚刚';
        if (min < 60) return min + ' 分钟前';
        const h = Math.floor(min / 60);
        return h + ' 小时' + (min % 60) + ' 分前';
      }

      function render(d) {
        const t = d.tldr;
        const ago = fmtAgo(d.generated_utc);
        const stale = Date.now() - new Date(d.generated_utc).getTime() > 45 * 60 * 1000;
        $('stamp').innerHTML = `数据 ${esc(d.generated_pt)} · <span style="color:${stale ? 'var(--amber)' : 'var(--fg2)'}">${ago}</span> · 每 20 分钟自动更新`;
        const kpi = (n, l, cls = '', d2 = '') => `<div class="kpi ${cls}"><div class="n tnum">${n}${d2}</div><div class="l">${l}</div></div>`;
        const dtxt = t.delta === 0 ? '' : `<span class="d ${t.delta > 0 ? 'pos' : 'neg'}">${t.delta > 0 ? '+' : ''}${t.delta}</span>`;

        const churn = (d.changes.churned || []).map((c) =>
          `<div class="li amber"><span class="grow">${esc(c.label)} <span class="mono" style="color:var(--fg3)">${esc(c.install8)}</span> · 静默 <b>${c.silent_days}</b> 天</span><span class="tnum ${netCls(c.net)}">${money(c.net)}</span></div>`
        ).join('');
        const signals = (d.signals || []).map((s) => `<div class="li dot">${esc(s)}</div>`).join('');
        const daily = dailyHTML(d.daily || []);
        const devs = (d.devs || []).map((x) => `${esc(x.label)} (${esc(x.install8)})`).join(' · ');

        $('body').innerHTML = `
          <div class="kpis">
            ${kpi(t.real, '真实用户', '', dtxt)}
            ${kpi(t.trader, '交易中')}
            ${kpi(t.trying, '刚装试用')}
            ${kpi(t.active, '本期活跃')}
            ${kpi(t.churning, '流失中', t.churning > 0 ? 'warn' : '')}
            ${kpi(t.period_sessions + '/' + t.period_rts, '本期 会话/成交')}
          </div>
          <div class="period">${esc(d.period_note)} · 库 ${d.lib.installs} 装 / ${d.lib.objects} 会话 / ${esc(d.lib.bytes_h)}</div>

          <div class="sh">每日活跃 <span class="count">最近 ${(d.daily || []).length} 天 · 谁在动</span></div>
          <div class="tl-card">${daily}</div>

          <div class="sh">谁在用 <span class="count">${d.roster.length} 人 · 按最近活跃</span></div>
          <div class="roster">${d.roster.map(userCard).join('')}</div>

          ${churn ? `<div class="sh">流失中 · 可挽回 <span class="count">${d.changes.churned.length}</span></div><div class="list">${churn}</div>` : ''}

          <div class="sh">产品信号 / 建议</div>
          <div class="list">${signals}</div>

          ${devs ? `<div class="sh">已排除 · 测试机</div><div class="devs">${devs}</div>` : ''}
        `;
      }

      async function fetchSnapshot() {
        const res = await fetch(API + '?action=snapshot', { headers: { 'x-admin-key': KEY } });
        if (res.status === 401) throw new Error('unauthorized');
        if (res.status === 404) return null; // no snapshot published yet
        if (!res.ok) throw new Error('http ' + res.status);
        return res.json();
      }

      async function load() {
        try {
          const d = await fetchSnapshot();
          $('login').classList.add('hidden');
          $('toolbar').classList.remove('hidden');
          $('dash').classList.remove('hidden');
          if (!d) {
            $('body').innerHTML = '<div class="card">还没有快照。在你的机器上跑一次:<br><br><code class="mono">cd ~/.meridian &amp;&amp; python -X utf8 usage.py publish</code><br><br><span style="color:var(--fg2)">(之后由定时任务每 ~20 分钟自动发布。)</span></div>';
            $('stamp').textContent = '';
            return;
          }
          render(d);
        } catch (err) {
          $('dash').classList.add('hidden');
          $('toolbar').classList.add('hidden');
          $('login').classList.remove('hidden');
          $('loginErr').textContent = '密钥错误，无法访问。';
          $('loginErr').classList.remove('hidden');
          localStorage.removeItem('mpsi_admin_key');
          KEY = '';
          if (timer) { clearInterval(timer); timer = null; }
        }
      }

      function start() {
        load();
        if (timer) clearInterval(timer);
        timer = setInterval(load, 10 * 60 * 1000); // re-pull the latest published snapshot every 10 min
      }

      $('refreshBtn').onclick = async () => {
        const b = $('refreshBtn');
        b.textContent = '刷新中…';
        await load();
        b.textContent = '✓ 已是最新';
        setTimeout(() => { b.textContent = '↻ 刷新'; }, 1600);
      };
      $('logoutBtn').onclick = () => {
        localStorage.removeItem('mpsi_admin_key');
        KEY = '';
        if (timer) { clearInterval(timer); timer = null; }
        location.reload();
      };
      $('loginBtn').onclick = () => {
        KEY = $('key').value.trim();
        if (!KEY) return;
        localStorage.setItem('mpsi_admin_key', KEY);
        $('loginErr').classList.add('hidden');
        start();
      };
      $('key').addEventListener('keydown', (e) => { if (e.key === 'Enter') $('loginBtn').click(); });
      if (KEY) start();
    </script>
  </body>
</html>
