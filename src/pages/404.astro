---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Page Not Found',
  description: 'The page you are looking for may have moved or no longer exists. Return to the Meridian homepage.',
  robots: { index: false, follow: true },
};
---

<Layout metadata={metadata}>
  <section class="halo">
    <div data-reveal class="max-w-3xl mx-auto px-6 py-28 md:py-36 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-6">ERROR 404</p>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-zinc-900 leading-[1.05]">
        This page wandered <span class="text-emerald-600">off.</span>
      </h1>
      <p class="mt-7 max-w-xl mx-auto text-lg md:text-xl text-zinc-600 leading-relaxed">
        We couldn't find the page you were looking for &mdash; it may have moved or never existed. Let's get you back to
        something useful.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm"
          >Back to homepage</a
        >
        <a
          href="/pricing"
          class="font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3.5 rounded-xl transition"
          >Start 14-day free trial</a
        >
      </div>
      <div class="mt-12 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-zinc-500">
        <span class="text-zinc-400">Or jump to:</span>
        <a href="/pricing" class="font-medium text-zinc-700 hover:text-emerald-700 transition">Pricing</a>
        <span class="text-zinc-300">&middot;</span>
        <a href="/download" class="font-medium text-zinc-700 hover:text-emerald-700 transition">Download</a>
        <span class="text-zinc-300">&middot;</span>
        <a href="/contact" class="font-medium text-zinc-700 hover:text-emerald-700 transition">Contact</a>
      </div>
    </div>
  </section>
</Layout>
