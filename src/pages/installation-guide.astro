---
import Layout from '~/layouts/PageLayout.astro';
import EcosystemVendorBadge from '~/components/widgets/EcosystemVendorBadge.astro';

// ─────────────────────────────────────────────────────────────────────────────
// INSTALLATION GUIDE — voice register: CLEAR / instructional. Precise,
// numbered, low-friction. Design uplifted to match the homepage light/emerald/
// zinc system (alternating bg/bg-white bands, .win product window, rounded-2xl
// cards). Header, Footer, RiskBanner come from PageLayout. HowTo JSON-LD below
// is preserved verbatim — do not remove.
// ─────────────────────────────────────────────────────────────────────────────

const DOWNLOAD_PAGE = 'https://www.meridianpsi.com/download';
const WHOP_URL = 'https://whop.com/@me/settings/memberships';
const SUPPORT_EMAIL = 'contactmeridianpsi@gmail.com';

const metadata = {
  // Brand already in the query phrase — suppress the site-wide "— Meridian" suffix.
  title: 'How to Install Meridian in NinjaTrader 8 — Installation Guide',
  ignoreTitleTemplate: true,
  description:
    'Step-by-step installation guide for Meridian on NinjaTrader 8: get your Whop license key, download the add-on, import via NinjaScript, activate, and configure your trading profile.',
  robots: { index: true, follow: true },
};

const howToSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Install Meridian in NinjaTrader 8',
  description: 'Install Meridian, activate your license, and configure your trading profile in NinjaTrader 8.',
  totalTime: 'PT10M',
  tool: [
    { '@type': 'HowToTool', name: 'NinjaTrader 8 (64-bit, Windows)' },
    { '@type': 'HowToTool', name: 'Whop account with active Meridian subscription' },
  ],
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: 'Get your license key from Whop',
      text: 'Sign in to Whop with the email used at checkout. Open your Meridian PSI membership and copy the license key from the Software / License Key section.',
      url: 'https://www.meridianpsi.com/installation-guide#step-1',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: 'Download the latest Meridian .zip',
      text: 'Go to meridianpsi.com/download and download the latest MeridianPSI .zip file. Do not extract it.',
      url: 'https://www.meridianpsi.com/installation-guide#step-2',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: 'Import via NinjaScript Add-On',
      text: 'In NinjaTrader 8, go to Tools → Import → NinjaScript Add-On and select the downloaded .zip file.',
      url: 'https://www.meridianpsi.com/installation-guide#step-3',
    },
    {
      '@type': 'HowToStep',
      position: 4,
      name: 'Open the Meridian Dashboard',
      text: 'Go to Control Center → New → Add-on → Meridian Dashboard, or click the ☰ icon in the top-right of the Meridian HUD.',
      url: 'https://www.meridianpsi.com/installation-guide#step-4',
    },
    {
      '@type': 'HowToStep',
      position: 5,
      name: 'Activate your license',
      text: 'In the Dashboard, open the License tab, paste your Whop license key, and click Activate.',
      url: 'https://www.meridianpsi.com/installation-guide#step-5',
    },
    {
      '@type': 'HowToStep',
      position: 6,
      name: 'Configure your trading profile',
      text: 'Open Settings and configure your trading profile: position size limits, session time window, signal weights, and response preset.',
      url: 'https://www.meridianpsi.com/installation-guide#step-6',
    },
    {
      '@type': 'HowToStep',
      position: 7,
      name: '(Optional) Test in SIM before going live',
      text: 'Connect a SIM account, confirm it appears in the Dashboard, then place a few small Simulation trades to verify the HUD and Dashboard are responding correctly. Market Replay sessions are tracked in a separate context and won\'t affect your live baseline.',
      url: 'https://www.meridianpsi.com/installation-guide#step-7',
    },
  ],
}).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={howToSchema} />

  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="halo">
    <div data-reveal class="max-w-5xl mx-auto px-6 pt-20 md:pt-24 pb-12 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-4">INSTALLATION GUIDE &middot; ~10 MINUTES</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-[1.05]">
        Install Meridian in<br />NinjaTrader 8.
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 leading-relaxed">
        Seven clear steps: get your key, download the add-on, import it, activate, and set up your profile. Optionally
        test in SIM before you go live.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={DOWNLOAD_PAGE} class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm">Download the latest build</a>
        <a href="#steps" class="font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3.5 rounded-xl transition">Jump to the steps</a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">
        Trade through Tradovate or Ironbeam instead? Install the <a href="/install-app" class="text-emerald-700 underline underline-offset-2">standalone app</a> &mdash; no NinjaTrader required.
      </p>
      <div class="mt-7 flex justify-center">
        <EcosystemVendorBadge variant="strip" align="center" />
      </div>
    </div>
  </section>

  <!-- ───────────────────────── BEFORE YOU START ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div data-reveal>
          <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">BEFORE YOU START</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900">What you'll need.</h2>
          <p class="mt-5 text-lg text-zinc-600 leading-relaxed">
            Three things, and the whole install takes about ten minutes. Have them ready and the steps below go without
            a hitch.
          </p>
          <ul class="mt-7 space-y-3 text-zinc-700">
            <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>NinjaTrader 8 installed (Windows, 64-bit)</span></li>
            <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>An active Meridian subscription</span></li>
            <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Your Whop login</span></li>
          </ul>
          <p class="mt-7 text-sm text-zinc-600 border-l-2 border-emerald-500 pl-4 py-1 leading-relaxed">
            Recommended for first use: finish your trading profile in Settings, then place a few SIM trades to confirm
            the HUD and Dashboard respond before going live. Guard rules are off by default until you configure them.
          </p>
        </div>

        <!-- Quick Start card -->
        <div data-reveal class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-7">
          <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-4">QUICK START</p>
          <ol class="space-y-3 text-zinc-700 leading-relaxed">
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">1</span><span>Get your license key from Whop (the Software / License Key section of your Meridian PSI membership).</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">2</span><span>Download the latest <code class="text-[13px] bg-white border border-zinc-200 px-1.5 py-0.5 rounded">.zip</code> from <a class="text-emerald-700 underline font-medium break-all" href={DOWNLOAD_PAGE}>meridianpsi.com/download</a> &mdash; do not extract it.</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">3</span><span>In NinjaTrader 8, go to <strong>Tools &rarr; Import &rarr; NinjaScript Add-On</strong> and select the <code class="text-[13px] bg-white border border-zinc-200 px-1.5 py-0.5 rounded">.zip</code>.</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">4</span><span>Open the Dashboard from <strong>Control Center &rarr; New &rarr; Add-on &rarr; Meridian Dashboard</strong> (or the <strong>&#9776;</strong> icon in the top-right of the HUD).</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">5</span><span>In the Dashboard, open the <strong>License tab</strong>, paste your key, click <strong>Activate</strong>.</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">6</span><span>Open <strong>Settings</strong> and configure your trading profile (size, session window, signal weights, response preset).</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">7</span><span><em>Optional:</em> test in SIM before going live.</span></li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── DETAILED STEPS ───────────────────────── -->
  <section id="steps" class="max-w-5xl mx-auto px-6 py-24 scroll-mt-24">
    <div data-reveal class="text-center mb-14">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">STEP BY STEP</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">The full walkthrough.</h2>
      <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">Follow them in order. Each step is short and self-contained.</p>
    </div>

    <div data-reveal class="space-y-6">
      <!-- 1 -->
      <section id="step-1" class="rounded-2xl border border-zinc-200 bg-white p-7 md:p-9 scroll-mt-24">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-2xl font-extrabold text-emerald-600 tnum">01</span>
          <h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Get your license key</h3>
        </div>
        <p class="text-zinc-600 leading-relaxed mb-4">Your Meridian license key is stored inside your Whop membership.</p>
        <ol class="space-y-2.5 text-zinc-700 mb-4">
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">1</span><span>Go to <a class="text-emerald-700 underline font-medium" href={WHOP_URL} target="_blank" rel="noopener noreferrer">{WHOP_URL}</a></span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">2</span><span>Sign in with the same email you used at checkout</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">3</span><span>Open your Meridian PSI membership</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">4</span><span>Find the Software / License Key section</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">5</span><span>Copy your license key</span></li>
        </ol>
        <p class="text-sm text-zinc-600 border-l-2 border-emerald-500 pl-4 py-1 leading-relaxed">
          Copy the key exactly &mdash; no extra spaces before or after. Can't find it? Email
          <a class="text-emerald-700 underline font-medium" href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>
          and include the email address you used at checkout.
        </p>
      </section>

      <!-- 2 -->
      <section id="step-2" class="rounded-2xl border border-zinc-200 bg-white p-7 md:p-9 scroll-mt-24">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-2xl font-extrabold text-emerald-600 tnum">02</span>
          <h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Download Meridian</h3>
        </div>
        <p class="text-zinc-600 leading-relaxed mb-3">Download the latest Meridian build here:</p>
        <p class="mb-4">
          <a class="text-emerald-700 underline font-medium break-all" href={DOWNLOAD_PAGE}>{DOWNLOAD_PAGE}</a>
        </p>
        <p class="text-zinc-600 leading-relaxed mb-4">Save the file somewhere easy to find, such as your Downloads folder.</p>
        <p class="text-sm text-zinc-700 bg-[#fafafa] border border-zinc-200 rounded-xl px-4 py-3 leading-relaxed">
          <strong class="text-zinc-900">Important:</strong> the download is a NinjaScript
          <code class="text-[13px] bg-white border border-zinc-200 px-1.5 py-0.5 rounded">.zip</code> package. Do not
          extract it &mdash; import the <code class="text-[13px] bg-white border border-zinc-200 px-1.5 py-0.5 rounded">.zip</code>
          file directly into NinjaTrader.
        </p>
      </section>

      <!-- 3 -->
      <section id="step-3" class="rounded-2xl border border-zinc-200 bg-white p-7 md:p-9 scroll-mt-24">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-2xl font-extrabold text-emerald-600 tnum">03</span>
          <h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Import Meridian into NinjaTrader 8</h3>
        </div>
        <ol class="space-y-2.5 text-zinc-700 mb-4">
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">1</span><span>Open NinjaTrader 8</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">2</span><span>Go to the Control Center</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">3</span><span>Click <strong>Tools</strong></span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">4</span><span>Click <strong>Import</strong></span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">5</span><span>Click <strong>NinjaScript Add-On</strong></span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">6</span><span>Select the Meridian <code class="text-[13px] bg-zinc-100 border border-zinc-200 px-1.5 py-0.5 rounded">.zip</code> file you downloaded</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">7</span><span>Confirm the import</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">8</span><span>Allow NinjaTrader to compile the add-on</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">9</span><span>Restart NinjaTrader if prompted</span></li>
        </ol>
        <p class="text-sm text-zinc-700 bg-[#fafafa] border border-zinc-200 rounded-xl px-4 py-3 leading-relaxed">
          <strong class="text-zinc-900">Important:</strong> Meridian is not a chart indicator. Don't look for it in
          the chart Indicators list.
        </p>
      </section>

      <!-- 4 -->
      <section id="step-4" class="rounded-2xl border border-zinc-200 bg-white p-7 md:p-9 scroll-mt-24">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-2xl font-extrabold text-emerald-600 tnum">04</span>
          <h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Open the Meridian Dashboard</h3>
        </div>
        <p class="text-zinc-600 leading-relaxed mb-3">Either method works any time:</p>
        <ul class="space-y-2.5 text-zinc-700 mb-4">
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span><strong>Control Center &rarr; New &rarr; Add-on &rarr; Meridian Dashboard</strong>, or</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Click the <strong>hamburger icon (&#9776;, three lines)</strong> in the top-right of the HUD</span></li>
        </ul>
        <p class="text-zinc-600 leading-relaxed">Both open the Dashboard window. The HUD overlay comes up with it.</p>
      </section>

      <!-- 5 -->
      <section id="step-5" class="rounded-2xl border border-zinc-200 bg-white p-7 md:p-9 scroll-mt-24">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-2xl font-extrabold text-emerald-600 tnum">05</span>
          <h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Activate your license</h3>
        </div>
        <p class="text-zinc-600 leading-relaxed mb-3">In the Dashboard:</p>
        <ol class="space-y-2.5 text-zinc-700 mb-4">
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">1</span><span>Open the <strong>License tab</strong></span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">2</span><span>Paste your Whop license key</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">3</span><span>Click <strong>Activate</strong></span></li>
        </ol>
        <p class="text-zinc-600 leading-relaxed mb-2">If activation fails, check that:</p>
        <ul class="space-y-2 text-zinc-700">
          <li class="flex gap-3"><span class="text-zinc-400">&bull;</span><span>You copied the full key with no extra spaces</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&bull;</span><span>You're using the same Whop account that purchased the subscription</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&bull;</span><span>Your machine has an active internet connection (one-time validation call)</span></li>
        </ul>
      </section>

      <!-- 6 -->
      <section id="step-6" class="rounded-2xl border border-zinc-200 bg-white p-7 md:p-9 scroll-mt-24">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-2xl font-extrabold text-emerald-600 tnum">06</span>
          <h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Configure your trading profile</h3>
        </div>
        <p class="text-zinc-600 leading-relaxed mb-4">Open <strong>Settings</strong> in the Dashboard and configure your profile before going live.</p>
        <p class="font-semibold text-zinc-900 mb-3">Recommended first setup:</p>
        <ol class="space-y-2.5 text-zinc-700 mb-4">
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">1</span><span>Set your normal trading <strong>size</strong> (typical contracts/lots per trade)</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">2</span><span>Set your <strong>session time window</strong> (or toggle the Session Window off for 24/7 monitoring)</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">3</span><span>Review the <strong>signal weights</strong> &mdash; set any individual signal to zero to disable it, or leave defaults</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">4</span><span>Pick a <strong>response preset</strong>: Sensitive, Balanced, or Relaxed (sets how aggressively PSI moves on a behavioral pattern)</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">5</span><span>Save the profile</span></li>
        </ol>
        <p class="text-sm text-zinc-600 border-l-2 border-emerald-500 pl-4 py-1 leading-relaxed">
          Guard rules are configured separately in the <strong>Guard tab</strong> (Guard tier only) &mdash; not in
          Settings. Guard rules are off by default until you create them.
        </p>
      </section>

      <!-- 7 -->
      <section id="step-7" class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-7 md:p-9 scroll-mt-24">
        <div class="flex items-baseline gap-4 mb-5">
          <span class="text-2xl font-extrabold text-emerald-600 tnum">07</span>
          <h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Optional: test in SIM</h3>
        </div>
        <p class="text-zinc-600 leading-relaxed mb-3">SIM testing is optional but recommended for new installs:</p>
        <ol class="space-y-2.5 text-zinc-700 mb-4">
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">1</span><span>Connect a SIM account in NinjaTrader</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">2</span><span>Confirm your account appears in the Dashboard (use <strong>Refresh Accounts</strong> in Settings if not)</span></li>
          <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">3</span><span>Place a few small SIM trades and confirm the HUD and Dashboard update</span></li>
        </ol>
        <p class="text-zinc-600 leading-relaxed">Market Replay sessions are tracked in a separate context &mdash; they won't affect your live baseline.</p>
      </section>
    </div>
  </section>

  <!-- ───────────────────────── COMMON ISSUES ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <div data-reveal class="text-center mb-14">
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">TROUBLESHOOTING</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Common issues.</h2>
        <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">Quick fixes for the things new installs run into most.</p>
      </div>

      <div data-reveal class="grid md:grid-cols-2 gap-5">
        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-7">
          <h3 class="font-semibold text-zinc-900 mb-3">No accounts are showing</h3>
          <ol class="space-y-2 text-sm text-zinc-700 mb-3">
            <li class="flex gap-2.5"><span class="font-bold text-emerald-600 tnum">1</span><span>Make sure your SIM or live account is connected in NinjaTrader</span></li>
            <li class="flex gap-2.5"><span class="font-bold text-emerald-600 tnum">2</span><span>Click <strong>Refresh Accounts</strong> in Meridian</span></li>
            <li class="flex gap-2.5"><span class="font-bold text-emerald-600 tnum">3</span><span>If needed, close and reopen the Meridian Dashboard</span></li>
          </ol>
          <p class="text-sm text-zinc-500">If the issue continues, send a screenshot to support.</p>
        </div>

        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-7">
          <h3 class="font-semibold text-zinc-900 mb-3">PSI shows Warning or Critical on the first SIM trade</h3>
          <p class="text-sm text-zinc-700 mb-2">Usually a behavioral signal fired against your configured profile. Common causes:</p>
          <ul class="space-y-1.5 text-sm text-zinc-700 mb-3">
            <li class="flex gap-2.5"><span class="text-zinc-400">&bull;</span><span>You're trading outside your configured session window</span></li>
            <li class="flex gap-2.5"><span class="text-zinc-400">&bull;</span><span>Your position size is above your profile's typical size</span></li>
            <li class="flex gap-2.5"><span class="text-zinc-400">&bull;</span><span>Your profile isn't fully configured yet &mdash; defaults can be tight on a fresh install</span></li>
          </ul>
          <p class="text-sm text-zinc-500">Switch the response preset to <strong>Relaxed</strong> in Settings while you dial in your profile, or lower the weight on the signal that's firing.</p>
        </div>

        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-7">
          <h3 class="font-semibold text-zinc-900 mb-3">I can't find Meridian in Indicators</h3>
          <p class="text-sm text-zinc-700 mb-2">That's expected. Meridian is an add-on, not a chart indicator &mdash; don't look for it in the chart Indicators list.</p>
          <p class="text-sm text-zinc-700">Open it from:</p>
          <p class="text-sm font-medium text-zinc-900 mt-1">Control Center &rarr; New &rarr; Add-on &rarr; Meridian Dashboard</p>
        </div>

        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-7">
          <h3 class="font-semibold text-zinc-900 mb-3">The import failed</h3>
          <p class="text-sm text-zinc-700 mb-2">Make sure you're importing through:</p>
          <p class="text-sm font-medium text-zinc-900 mb-2">Tools &rarr; Import &rarr; NinjaScript Add-On</p>
