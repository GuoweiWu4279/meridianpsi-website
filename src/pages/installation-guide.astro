  <style>
    /* Selected platform tab — emerald-600 fill (matches the site's bg-emerald-600). */
    .iv-tab[aria-selected='true'] {
      background-color: #059669;
      border-color: #059669;
      color: #fff;
    }
    .iv-tab[aria-selected='true'] .iv-sub {
      color: rgba(255, 255, 255, 0.85);
    }
    .iv-tab:focus-visible {
      outline: 2px solid #059669;
      outline-offset: 2px;
    }
  </style>

  <script>
    // Version selector: swap the visible install guide, keep it deep-linkable via
    // the URL hash (#ninjatrader / #tradovate / #ironbeam). Re-queries the DOM on
    // every call so it stays correct across Astro client navigations.
    function mSetInstallVersion(version, opts) {
      const focus = opts && opts.focus;
      const tablist = document.querySelector('[data-install-tablist]');
      if (!tablist) return;
      const tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
      const panels = Array.from(document.querySelectorAll('[data-install-panel]'));
      const ids = tabs.map((t) => t.getAttribute('data-version'));
      if (!ids.includes(version)) version = ids[0];
      tabs.forEach((t) => {
        const on = t.getAttribute('data-version') === version;
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.setAttribute('tabindex', on ? '0' : '-1');
        if (on && focus) t.focus();
      });
      panels.forEach((p) => {
        p.hidden = p.getAttribute('data-install-panel') !== version;
      });
      if (window.history && history.replaceState && '#' + version !== window.location.hash) {
        history.replaceState(null, '', '#' + version);
      }
    }

    function initInstallTabs() {
      const tablist = document.querySelector('[data-install-tablist]');
      if (!tablist || tablist.dataset.bound === '1') return;
      tablist.dataset.bound = '1';
      const tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
      const ids = tabs.map((t) => t.getAttribute('data-version'));

      // Initial: honor the hash (deep links from /download, /platforms, old /install-app).
      const fromHash = (window.location.hash || '').replace('#', '');
      mSetInstallVersion(ids.includes(fromHash) ? fromHash : ids[0]);

      tabs.forEach((t) => {
        t.addEventListener('click', () => mSetInstallVersion(t.getAttribute('data-version')));
      });

      // Keyboard: arrows / Home / End move between tabs.
      tablist.addEventListener('keydown', (e) => {
        const i = tabs.indexOf(document.activeElement);
        if (i < 0) return;
        let n = null;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') n = (i + 1) % tabs.length;
        if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') n = (i - 1 + tabs.length) % tabs.length;
        if (e.key === 'Home') n = 0;
        if (e.key === 'End') n = tabs.length - 1;
        if (n !== null) {
          e.preventDefault();
          mSetInstallVersion(ids[n], { focus: true });
        }
      });
    }

    // Bind window-level listeners once; re-init per page (the dataset guard above
    // makes initInstallTabs idempotent on a given tablist element).
    if (!window.__mInstallTabsBound) {
      window.__mInstallTabsBound = true;
      // Same-document hash changes (manual edit, back/forward, same-page hash link).
      window.addEventListener('hashchange', () => {
        const v = (window.location.hash || '').replace('#', '');
        if (v) mSetInstallVersion(v);
      });
      // Astro View Transitions navigation.
      document.addEventListener('astro:page-load', initInstallTabs);
    }
    // First paint / routers where astro:page-load may not fire.
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initInstallTabs);
    } else {
      initInstallTabs();
    }
  </script>
