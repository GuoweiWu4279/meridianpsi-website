---
import Layout from '~/layouts/PageLayout.astro';
import EcosystemVendorBadge from '~/components/widgets/EcosystemVendorBadge.astro';

const DOWNLOAD_PAGE = 'https://www.meridianpsi.com/download';
const WHOP_URL = 'https://whop.com';
const SUPPORT_EMAIL = 'contactmeridianpsi@gmail.com';

const metadata = {
  title: 'Installation Guide — Meridian',
  description:
    'Install Meridian in NinjaTrader 8: Whop license key, download, import, activate, configure your profile, and troubleshooting.',
};
---

<Layout metadata={metadata}>
  <section class="py-12 px-6">
    <div class="max-w-3xl mx-auto text-zinc-900 dark:text-white">
      <h1 class="text-3xl md:text-4xl font-bold mb-3">Install Meridian in NinjaTrader 8</h1>
      <p class="text-zinc-600 dark:text-zinc-400 text-base mb-5 leading-relaxed">
        Install Meridian, activate your license, and configure your trading profile. Optionally test in SIM before going live.
      </p>

      <div class="mb-10">
        <EcosystemVendorBadge variant="strip" align="left" />
      </div>

      <!-- Quick Start -->
      <div class="rounded-2xl border border-emerald-200 dark:border-emerald-900/50 bg-emerald-50/60 dark:bg-emerald-950/30 p-6 md:p-7 mb-12">
        <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">Quick Start</h2>
        <ol class="list-decimal list-inside space-y-1.5 text-sm text-zinc-700 dark:text-zinc-300 leading-relaxed">
          <li>Get your license key from Whop (Software section in the left-side panel of your Meridian membership)</li>
          <li>
            Download the latest <code class="text-xs bg-zinc-200/80 dark:bg-zinc-800 px-1 rounded">.zip</code> from <a class="text-emerald-800 dark:text-emerald-400 underline font-medium" href={DOWNLOAD_PAGE}>{DOWNLOAD_PAGE}</a> — do not extract it
          </li>
          <li>In NinjaTrader 8, go to <strong>Tools → Import → NinjaScript Add-On</strong> and select the <code class="text-xs bg-zinc-200/80 dark:bg-zinc-800 px-1 rounded">.zip</code></li>
          <li>Open the Dashboard from <strong>Control Center → New → Add-on → Meridian Dashboard</strong> (or click the <strong>☰ icon</strong> in the HUD's top-right)</li>
          <li>In the Dashboard, open the <strong>License tab</strong>, paste your key, click <strong>Activate</strong></li>
          <li>Open <strong>Settings</strong> and configure your trading profile (size, session window, signal weights, response preset)</li>
          <li><em>Optional:</em> test in SIM before going live</li>
        </ol>
      </div>

      <h2 class="text-xl font-semibold mb-3">Start here</h2>
      <p class="text-sm font-medium text-zinc-800 dark:text-zinc-200 mb-2">You will need:</p>
      <ul class="list-disc list-inside text-sm text-zinc-600 dark:text-zinc-400 space-y-1 mb-4">
        <li>NinjaTrader 8 installed (Windows, 64-bit)</li>
        <li>Your Whop login</li>
        <li>Your Meridian license key</li>
        <li>The latest Meridian download</li>
      </ul>
      <p class="text-sm text-zinc-600 dark:text-zinc-400 border-l-2 border-emerald-500 pl-3 py-1 mb-10">
        Recommended for first use: complete your trading profile in Settings, then place a few SIM trades to verify the HUD and Dashboard are responding before going live. Guard rules are off by default until you configure them.
      </p>

      <div class="space-y-10 text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">
        <section>
          <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">1. Get your license key</h2>
          <p class="mb-3">Your Meridian license key is stored inside your Whop membership.</p>
          <ol class="list-decimal list-inside space-y-1.5 mb-3">
            <li>Go to <a class="text-emerald-800 dark:text-emerald-400 underline font-medium" href={WHOP_URL} target="_blank" rel="noopener noreferrer">{WHOP_URL}</a></li>
            <li>Sign in with the same email you used at checkout</li>
            <li>Open your Meridian PSI membership</li>
            <li>Find the Software / License Key section</li>
            <li>Copy your license key</li>
          </ol>
          <p class="mb-3">Copy the key exactly. Do not add extra spaces before or after it.</p>
          <p class="mb-1">If you cannot find your license key, email:</p>
          <p class="mb-1">
            <a class="text-emerald-800 dark:text-emerald-400 underline font-medium" href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>
          </p>
          <p>Include the email address you used at checkout.</p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">2. Download Meridian</h2>
          <p class="mb-2">Download the latest Meridian build here:</p>
          <p class="mb-3">
            <a class="text-emerald-800 dark:text-emerald-400 underline font-medium break-all" href={DOWNLOAD_PAGE}>{DOWNLOAD_PAGE}</a>
          </p>
          <p class="mb-3">Save the file somewhere easy to find, such as your Downloads folder.</p>
          <p class="font-medium text-zinc-800 dark:text-zinc-200 mb-1">Important:</p>
          <p>
            If the downloaded file is a NinjaScript <code class="text-xs bg-zinc-200/80 dark:bg-zinc-800 px-1 rounded">.zip</code> package, do not extract it. Import the
            <code class="text-xs bg-zinc-200/80 dark:bg-zinc-800 px-1 rounded">.zip</code> file directly into NinjaTrader.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">3. Import Meridian into NinjaTrader 8</h2>
          <ol class="list-decimal list-inside space-y-1.5 mb-3">
            <li>Open NinjaTrader 8</li>
            <li>Go to the Control Center</li>
            <li>Click Tools</li>
            <li>Click Import</li>
            <li>Click NinjaScript Add-On</li>
            <li>Select the Meridian <code class="text-xs bg-zinc-200/80 dark:bg-zinc-800 px-1 rounded">.zip</code> file you downloaded</li>
            <li>Confirm the import</li>
            <li>Allow NinjaTrader to compile the add-on</li>
            <li>Restart NinjaTrader if prompted</li>
          </ol>
          <p class="font-medium text-zinc-800 dark:text-zinc-200 mb-1">Important:</p>
          <p>Meridian is not a chart indicator. Do not look for it in the chart Indicators list.</p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">4. Open the Meridian Dashboard</h2>
          <p class="mb-2">Either method works any time:</p>
          <ul class="list-disc list-inside space-y-1.5 mb-3">
            <li><strong>Control Center → New → Add-on → Meridian Dashboard</strong>, or</li>
            <li>Click the <strong>hamburger icon (☰, three lines)</strong> in the top-right of the HUD</li>
          </ul>
          <p>Both open the Dashboard window. The HUD overlay comes up with it.</p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">5. Activate your license</h2>
          <p class="mb-2">In the Dashboard:</p>
          <ol class="list-decimal list-inside space-y-1.5 mb-3">
            <li>Open the <strong>License tab</strong></li>
            <li>Paste your Whop license key</li>
            <li>Click <strong>Activate</strong></li>
          </ol>
          <p class="mb-2">If activation fails, check that:</p>
          <ul class="list-disc list-inside space-y-1">
            <li>You copied the full key with no extra spaces</li>
            <li>You are using the same Whop account that purchased the subscription</li>
            <li>Your machine has an active internet connection (one-time validation call)</li>
          </ul>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">6. Configure your trading profile</h2>
          <p class="mb-3">Open <strong>Settings</strong> in the Dashboard and configure your profile before going live.</p>
          <p class="font-medium text-zinc-800 dark:text-zinc-200 mb-2">Recommended first setup:</p>
          <ol class="list-decimal list-inside space-y-1.5 mb-3">
            <li>Set your normal trading <strong>size</strong> (typical contracts/lots per trade)</li>
            <li>Set your <strong>session time window</strong> (or toggle the Session Window off if you want 24/7 monitoring)</li>
            <li>Review the <strong>signal weights</strong> — set any individual signal to zero to disable it, or leave defaults</li>
            <li>Pick a <strong>response preset</strong>: Sensitive, Balanced, or Relaxed (sets how aggressively PSI moves on a behavioral pattern)</li>
            <li>Save the profile</li>
          </ol>
          <p class="mb-2">Guard rules are configured separately in the <strong>Guard tab</strong> (Guard tier only) — not in Settings. Guard rules are off by default until you create them.</p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">7. Optional: test in SIM</h2>
          <p class="mb-2">SIM testing is optional but recommended for new installs:</p>
          <ol class="list-decimal list-inside space-y-1.5 mb-3">
            <li>Connect a SIM account in NinjaTrader</li>
            <li>Confirm your account appears in the Dashboard (use <strong>Refresh Accounts</strong> in Settings if not)</li>
            <li>Place a few small SIM trades and confirm the HUD and Dashboard update</li>
          </ol>
          <p>Market Replay sessions are tracked in a separate context — they will not affect your live baseline.</p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-3">Common issues</h2>

          <h3 class="text-base font-semibold text-zinc-800 dark:text-zinc-200 mt-4 mb-2">No accounts are showing</h3>
          <p class="mb-2">Try this:</p>
          <ol class="list-decimal list-inside space-y-1.5 mb-2">
            <li>Make sure your SIM or live account is connected in NinjaTrader</li>
            <li>Click Refresh Accounts in Meridian</li>
            <li>If needed, close and reopen the Meridian Dashboard</li>
          </ol>
          <p class="mb-6">If the issue continues, send a screenshot to support.</p>

          <h3 class="text-base font-semibold text-zinc-800 dark:text-zinc-200 mb-2">PSI shows Warning or Critical on the first SIM trade</h3>
          <p class="mb-2">This usually means a behavioral signal fired against your configured profile.</p>
          <p class="mb-1 font-medium text-zinc-800 dark:text-zinc-200">Common causes:</p>
          <ul class="list-disc list-inside space-y-1 mb-2">
            <li>You are trading outside your configured session window</li>
            <li>Your position size is above your profile's typical size</li>
            <li>Your profile is not fully configured yet — defaults can be tight on a fresh install</li>
          </ul>
          <p class="mb-6">Switch the response preset to <strong>Relaxed</strong> in Settings to soften PSI movement while you dial in your profile, or lower the weight on the signal that's firing.</p>

          <h3 class="text-base font-semibold text-zinc-800 dark:text-zinc-200 mb-2">I cannot find Meridian in Indicators</h3>
          <p class="mb-2">That is expected.</p>
          <p class="mb-2">Meridian is an add-on, not a chart indicator. Do not look for it in the chart Indicators list.</p>
          <p class="mb-1">Open it from:</p>
          <p class="font-medium text-zinc-800 dark:text-zinc-200 mb-6">Control Center → New → Add-on → Meridian Dashboard</p>

          <h3 class="text-base font-semibold text-zinc-800 dark:text-zinc-200 mb-2">The import failed</h3>
          <p class="mb-2">Make sure you are importing through:</p>
          <p class="font-medium text-zinc-800 dark:text-zinc-200 mb-2">Tools → Import → NinjaScript Add-On</p>
          <p>If NinjaTrader shows an error, send a screenshot to support.</p>
        </section>

        <section class="rounded-xl border border-zinc-200 dark:border-zinc-800 p-5">
          <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">Need help?</h2>
          <p class="mb-1">Email:</p>
          <p class="mb-3">
            <a class="text-emerald-800 dark:text-emerald-400 underline font-medium" href={`mailto:${SUPPORT_EMAIL}`}>{SUPPORT_EMAIL}</a>
          </p>
          <p class="mb-1 font-medium text-zinc-800 dark:text-zinc-200">Please include:</p>
          <ul class="list-disc list-inside space-y-1">
            <li>Your Whop checkout email</li>
            <li>Your NinjaTrader 8 version</li>
            <li>Your Meridian version</li>
            <li>A screenshot of the issue</li>
            <li>The step where you got stuck</li>
          </ul>
        </section>

        <section class="text-xs text-zinc-500 dark:text-zinc-500 border-t border-zinc-200 dark:border-zinc-800 pt-8">
          <p class="font-semibold text-zinc-700 dark:text-zinc-400 mb-1">Risk notice</p>
          <p>
            Meridian is a behavioral monitoring and risk-management tool. It does not provide trade signals, financial advice, or profit guarantees. Test in SIM before using
            Meridian live.
          </p>
        </section>
      </div>
    </div>
  </section>
</Layout>
