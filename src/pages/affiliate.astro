---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Affiliate Program — Meridian',
  description: 'Apply to become a Meridian affiliate. Earn recurring commission by referring active NinjaTrader 8 traders to Meridian.',
  robots: { index: true, follow: true },
};

const email = 'contactmeridianpsi@gmail.com';
const subject = encodeURIComponent('Meridian Affiliate Application');
const body = encodeURIComponent(
`Name:
Platform / Channel (YouTube, X, Discord, blog, etc.):
Audience size (approximate):
Describe your audience (futures traders, prop firm traders, NT8 users, etc.):
Why you think Meridian is relevant to your audience:
Any questions:`
);
const mailtoHref = `mailto:${email}?subject=${subject}&body=${body}`;
---

<Layout metadata={metadata}>

  <!-- Header -->
  <section class="py-20 px-6 border-b border-zinc-100 bg-white">
    <div class="max-w-2xl mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.18em] uppercase text-emerald-700 mb-4">Partner Program</p>
      <h1 class="text-3xl md:text-4xl font-bold text-zinc-900 tracking-tight leading-snug mb-5">
        Affiliate Program
      </h1>
      <p class="text-zinc-600 leading-relaxed text-base mb-4">
        Meridian works with a small number of content creators, educators, and community leaders who have a genuine audience of active NinjaTrader 8 traders.
      </p>
      <p class="text-zinc-600 leading-relaxed text-base">
        If that describes you, and you believe Meridian is relevant to your audience, you can apply below. We review every application and respond to qualified candidates.
      </p>
    </div>
  </section>

  <!-- Commission details -->
  <section class="py-16 px-6 bg-zinc-50 border-b border-zinc-100">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-lg font-bold text-zinc-900 mb-8">Program details</h2>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="bg-white border border-zinc-200 rounded-2xl px-6 py-7">
          <p class="text-3xl font-bold text-zinc-900 mb-1">30%</p>
          <p class="text-sm text-zinc-500">Recurring commission for the lifetime of every subscription you refer — paid monthly through Whop</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-2xl px-6 py-7">
          <p class="text-3xl font-bold text-zinc-900 mb-1">10%</p>
          <p class="text-sm text-zinc-500">Permanent discount for your audience — applied via your unique promo code at checkout, every renewal</p>
        </div>
        <div class="bg-white border border-zinc-200 rounded-2xl px-6 py-7">
          <p class="text-3xl font-bold text-zinc-900 mb-1">Free</p>
          <p class="text-sm text-zinc-500">Complimentary Meridian Guard access for the duration of your active partnership — so you can use and evaluate the product directly</p>
        </div>
      </div>

      <div class="mt-10 space-y-4 text-sm text-zinc-600 leading-relaxed">
        <p><strong class="text-zinc-800">How it works.</strong> You receive a unique affiliate link and promo code. Subscribers who use your code get 10% off every billing cycle — permanently. You earn 30% of each payment they make, for as long as they remain subscribed. Commission is tracked and paid through Whop on a standard monthly cycle.</p>
        <p><strong class="text-zinc-800">Who this is for.</strong> Content creators, YouTubers, X (Twitter) traders, Discord community leads, and newsletter writers whose audience consists primarily of active futures or equity traders using NinjaTrader 8. Meridian requires NinjaTrader 8 on Windows — referrals outside this user base do not convert.</p>
        <p><strong class="text-zinc-800">Complimentary access.</strong> Accepted affiliates receive a full Meridian Guard license at no cost for the duration of the active partnership. This is a review license — intended for you to use the product, form an honest opinion, and communicate that accurately to your audience.</p>
        <p><strong class="text-zinc-800">What we do not do.</strong> We do not pay for unsolicited posts, spam campaigns, or cold outreach on our behalf. Affiliates are expected to present Meridian accurately and in accordance with financial promotion regulations applicable in their jurisdiction, including any required disclosure that content is associated with an affiliate arrangement.</p>
      </div>
    </div>
  </section>

  <!-- Application -->
  <section class="py-16 px-6 bg-white">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-lg font-bold text-zinc-900 mb-2">Apply</h2>
      <p class="text-sm text-zinc-500 mb-8">
        Send your application to <a href={`mailto:${email}`} class="text-emerald-700 hover:underline">{email}</a> with the subject line <span class="font-mono bg-zinc-100 px-1.5 py-0.5 rounded text-xs">Meridian Affiliate Application</span>. Include the following:
      </p>

      <ul class="space-y-3 text-sm text-zinc-700 mb-10">
        {[
          'Your name',
          'Platform or channel (YouTube, X, Discord, blog, newsletter, etc.)',
          'Approximate audience size',
          'Description of your audience — who they are and what they trade',
          'Why you believe Meridian is relevant to them',
          'Any questions',
        ].map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-1 w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span>
            {item}
          </li>
        ))}
      </ul>

      <a
        href={mailtoHref}
        class="inline-flex items-center gap-2 px-7 py-3 rounded-full bg-zinc-900 hover:bg-zinc-700 text-white text-sm font-semibold transition-colors"
      >
        Open email client to apply
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>

      <p class="text-xs text-zinc-400 mt-5">
        We review applications manually and typically respond within 3–5 business days. Not all applications are accepted.
      </p>
    </div>
  </section>

  <!-- Disclaimer -->
  <section class="py-10 px-6 bg-zinc-50 border-t border-zinc-100">
    <div class="max-w-2xl mx-auto">
      <p class="text-xs text-zinc-400 leading-relaxed">
        Meridian is a behavioral risk management add-on for NinjaTrader 8. It does not provide trading signals or investment advice. Trading involves substantial risk of loss. Affiliates are responsible for ensuring their promotional activity complies with all applicable laws and regulations in their jurisdiction, including financial promotion rules. Commission rates and program terms are subject to change with reasonable notice.
      </p>
    </div>
  </section>

</Layout>
