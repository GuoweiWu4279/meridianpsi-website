---
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import EcosystemVendorBadge from '~/components/widgets/EcosystemVendorBadge.astro';

const metadata = {
  // Brand already leads the title — suppress the site-wide "— Meridian" suffix.
  title: 'Compare Meridian — vs Native NinjaTrader, Hard-Limit Tools, Trading Journals',
  ignoreTitleTemplate: true,
  description:
    'Meridian vs every risk-tool category — native NinjaTrader 8 controls, hard-limit add-ons, journals, app blockers: every traditional limit plus a real-time behavioral layer, compared head-to-head.',
  robots: { index: true, follow: true },
};

const comparisons = [
  {
    title: 'vs Native NinjaTrader Risk',
    href: '/compare/meridian-vs-native-ninjatrader-risk',
    learn:
      'How Meridian operates one layer earlier than the built-in NinjaTrader 8 daily loss and account-level controls — behavioral pattern vs. financial outcome.',
    against: 'NinjaTrader 8 native controls',
  },
  {
    title: 'vs Hard-Limit Tools',
    href: '/compare/meridian-vs-hard-limit-tools',
    learn:
      'Where Meridian sits relative to Arty Account Guard, CrossTrade NAM, ClickAlgo Risk Manager, RiskMaster, and Guardian Angel — the third-party hard-limit category.',
    against: 'Arty · CrossTrade · ClickAlgo · RiskMaster · Guardian Angel',
  },
  {
    title: 'vs Account Risk Managers & Copiers',
    href: '/compare/meridian-vs-account-risk-manager',
    learn:
      'Account risk managers and copier suites (like the Affordable Indicators suite) win on multi-account, trade copier, and one-time pricing. Meridian wins on risk-control depth and the full trade loop — every hard limit, plus the behavioral layer, journal, and analytics.',
    against: 'Affordable Account Risk Manager · copier / multi-account suites',
  },
  {
    title: 'vs Guardian Angel',
    href: '/compare/meridian-vs-guardian-angel-ninjatrader',
    learn:
      'Guardian Angel enforces hard limits at the financial-outcome layer. Meridian operates one layer earlier, on the behavioral patterns that produce the outcome.',
    against: 'Guardian Angel for NinjaTrader',
  },
  {
    title: 'vs Trading Journals',
    href: '/compare/meridian-vs-trading-journals',
    learn:
      'Why a real-time psychological stability monitor is a different category from post-session retrospective analytics like Tradervue, Edgewonk, TraderSync, and TradesViz.',
    against: 'Tradervue · Edgewonk · TraderSync · TradesViz',
  },
  {
    title: 'vs TradeZella',
    href: '/compare/meridian-vs-tradezella',
    learn:
      'TradeZella analyzes trades after the session ends. Meridian monitors psychological stability while the session is running. Post-trade analysis vs. real-time intervention.',
    against: 'TradeZella',
  },
  {
    title: 'vs Zella AI',
    href: '/compare/meridian-vs-zella-ai',
    learn:
      'Zella AI reviews logged trades and flags revenge trading, oversizing, and plan drift after the session. Meridian computes the same signals from the live order stream and intervenes during it — the two closest products, split by timing.',
    against: 'Zella AI (TradeZella)',
  },
  {
    title: 'vs Daily Loss Limits',
    href: '/compare/meridian-guard-vs-daily-loss-limits',
    learn:
      'How Meridian Guard differs from a daily loss limit conceptually — fires on the behavioral pattern that produces the loss, before the P&L threshold needs to engage.',
    against: 'Daily loss limit add-ons',
  },
  {
    title: 'vs Prop-Firm Lockouts',
    href: '/compare/meridian-vs-prop-firm-lockouts',
    learn:
      'TopstepX, ProjectX, and Tradovate lock the account once a daily loss or trade-count threshold is hit. Meridian locks on the behavior that produces the loss, before the threshold — and includes those hard limits too.',
    against: 'TopstepX · ProjectX · Tradovate native locks',
  },
  {
    title: 'Cold Turkey Alternatives',
    href: '/compare/cold-turkey-alternatives-daytraders',
    learn:
      'Traders use Cold Turkey to block trading platforms after bad sessions. Meridian is the purpose-built alternative: behavioral enforcement calibrated to your live session state.',
    against: 'Cold Turkey and generic app blockers',
  },
];

const itemListSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Meridian Comparisons',
  description: 'Meridian vs every category of NinjaTrader 8 risk tool: the most complete NT8 risk manager — every traditional limit plus a real-time behavioral layer — compared head-to-head.',
  itemListElement: [
    ...comparisons.map((c, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: `Meridian ${c.title}`,
      url: `https://www.meridianpsi.com${c.href}`,
    })),
    {
      '@type': 'ListItem',
      position: comparisons.length + 1,
      name: 'Best NinjaTrader 8 Risk Management Tools (2026) — Generation Map',
      url: 'https://www.meridianpsi.com/best-ninjatrader-risk-management-tools',
    },
  ],
}).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={itemListSchema} />

  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-zinc-100">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
         style="background: radial-gradient(ellipse at 80% 0%, rgba(5,150,105,0.08) 0%, transparent 60%);"></div>
    <div class="relative max-w-4xl mx-auto px-6 py-20 md:py-24 text-center">
      <p class="text-[11px] font-semibold tracking-[0.15em] uppercase mb-4" style="color:var(--aw-color-primary);">Comparisons</p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-zinc-900 leading-[1.1] tracking-tight mb-6">
        How Meridian compares.
      </h1>
      <p class="text-lg text-zinc-600 leading-relaxed max-w-2xl mx-auto mb-4">
        Meridian does everything these tools do — daily loss limits, single-trade loss caps, P&amp;L and drawdown caps, loss-streak cutoffs — and adds a real-time behavioral layer the others don't. The comparisons below lay out exactly where each tool sits: the native controls, the hard-limit add-ons, the post-session journals, the daily loss limit category, and generic app-blockers.
      </p>
      <p class="text-xs text-zinc-400 mb-6">Last reviewed: June 2026</p>
      <div class="flex justify-center">
        <EcosystemVendorBadge variant="compact" />
      </div>
    </div>
  </section>

  <!-- COMPARISON CARD GRID -->
  <section class="px-6 py-16 md:py-20 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {comparisons.map((c) => (
          <a
            href={c.href}
            class="group relative block rounded-2xl border border-zinc-200 bg-white p-7 md:p-8 shadow-sm transition-all hover:border-emerald-600/40 hover:shadow-md hover:-translate-y-0.5"
          >
            <p class="text-[10px] font-bold tracking-[0.18em] uppercase mb-3" style="color:var(--aw-color-primary);">Meridian</p>
            <h2 class="text-xl md:text-2xl font-bold text-zinc-900 leading-tight tracking-tight mb-3">
              {c.title}
            </h2>
            <p class="text-sm text-zinc-500 leading-relaxed mb-5">
              {c.learn}
            </p>
            <p class="text-[11px] font-medium text-zinc-400 mb-6">
              <span class="font-semibold text-zinc-500">Compared against:</span> {c.against}
            </p>
            <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-700 group-hover:gap-2.5 transition-all">
              Read comparison
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED: full roundup -->
  <section class="px-6 py-16 md:py-20" style="background:#f7f5f1; border-top:1px solid rgba(0,0,0,0.05);">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-[11px] font-semibold tracking-[0.15em] uppercase mb-3 text-zinc-500">The full landscape</p>
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold text-zinc-900 leading-tight tracking-tight mb-4">
        See every NinjaTrader 8 risk tool ranked.
      </h2>
      <p class="text-base text-zinc-600 leading-relaxed mb-8 max-w-xl mx-auto">
        A generation map of every NT8 risk-management option — native broker limits, third-party hard-limit add-ons, and complete platforms that combine those traditional limits with a real-time behavioral layer — organized by the layer each one is designed to intercept.
      </p>
      <a
        href="/best-ninjatrader-risk-management-tools"
        class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold text-white shadow-sm transition-all hover:shadow-md"
        style="background:var(--aw-color-primary);"
      >
        Best NT8 Risk Tools (2026)
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <CallToAction
    title="Try Meridian on your platform."
    subtitle="See the behavioral signals fire in real time on your own session — 14-day free trial, cancel any time."
    actions={[
      { variant: 'primary', text: 'Start free trial', href: '/pricing' },
      { text: 'View pricing', href: '/pricing' },
    ]}
  />
</Layout>
