  </div>

</Layout>

<style>
  /* Print styles */
  @media print {
    #sticky-bar,
    #toc-nav,
    #toc-mobile,
    .copy-btn { display: none !important; }
    .kit-section { break-inside: avoid; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    * { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
  }

  /* Copy button active (copied) state */
  .copy-btn.copied .copy-label { color: rgb(5 150 105); }
  .copy-btn.copied .copy-icon { color: rgb(5 150 105); }

  /* TOC active link */
  .toc-link.active {
    color: rgb(5 150 105);
    background-color: rgb(240 253 244 / 0.7);
    font-weight: 600;
  }
  .dark .toc-link.active {
    color: rgb(52 211 153);
    background-color: rgb(6 78 59 / 0.25);
  }
  .toc-link.active .toc-icon {
    color: rgb(5 150 105);
  }
  .dark .toc-link.active .toc-icon {
    color: rgb(52 211 153);
  }
</style>

<script>
  // ── 1. Name personalisation ──────────────────────────────
  (function () {
    const params = new URLSearchParams(window.location.search);
    const name = params.get('name');
    if (name) {
      const el = document.getElementById('name-display');
      if (el) el.textContent = ', ' + decodeURIComponent(name);
    }
  })();

  // ── 2. Scroll-spy: highlight active TOC link ─────────────
  (function () {
    const sections = document.querySelectorAll<HTMLElement>('.kit-section');
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-target]');
    if (!sections.length || !links.length) return;

    let current = '';

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            current = entry.target.id;
            links.forEach((link) => {
              const active = link.dataset.tocTarget === current;
              link.classList.toggle('active', active);
            });
          }
        });
      },
      { rootMargin: '-15% 0px -75% 0px', threshold: 0 }
    );

    sections.forEach((s) => observer.observe(s));
  })();

  // ── 3. Copy-to-clipboard buttons ─────────────────────────
  (function () {
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const text = btn.getAttribute('data-copy') ?? '';
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          // Fallback for older browsers
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.focus();
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        const label = btn.querySelector<HTMLElement>('.copy-label');
        if (label) {
          const original = label.textContent;
          label.textContent = 'Copied';
          btn.classList.add('copied');
          setTimeout(() => {
            label.textContent = original;
            btn.classList.remove('copied');
          }, 1500);
        }
      });
    });
  })();
</script>
