---
import Layout from '~/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import DashboardHero from '~/components/partner-kit/DashboardHero.astro';
import QuickActionTiles from '~/components/partner-kit/QuickActionTiles.astro';
import QuickAccessStrip from '~/components/partner-kit/QuickAccessStrip.astro';
import WhatsNewBanner from '~/components/partner-kit/WhatsNewBanner.astro';
import KitSearch from '~/components/partner-kit/KitSearch.astro';
import PinnedDrawer from '~/components/partner-kit/PinnedDrawer.astro';
import CollapsibleSection from '~/components/partner-kit/CollapsibleSection.astro';

const allEntries = await getCollection('partnerKit');
const byId = Object.fromEntries(allEntries.map((e) => [e.id, e]));

async function renderEntry(id: string) {
  const entry = byId[id];
  if (!entry) return null;
  return await render(entry);
}

// Render all prose sections upfront
const [
  r01,
  r021, r022, r023,
  r031, r032, r033, r034,
  r041, r042, r043,
  r05,
  r061, r062, r063, r064, r065, r066,
  r07,
] = await Promise.all([
  renderEntry('01-personal-details'),
  renderEntry('02-1-install'),
  renderEntry('02-2-first-30-min'),
  renderEntry('02-3-product-deep-dive'),
  renderEntry('03-1-core-positioning'),
  renderEntry('03-2-differentiation'),
  renderEntry('03-3-audience-faq'),
  renderEntry('03-4-angles-by-audience'),
  renderEntry('04-1-ftc-disclosure'),
  renderEntry('04-2-forbidden-phrases'),
  renderEntry('04-3-when-in-doubt'),
  renderEntry('05-visual-assets'),
  renderEntry('06-1-video-60s-hook'),
  renderEntry('06-2-video-3min-walkthrough'),
  renderEntry('06-3-video-30s-short'),
  renderEntry('06-4-youtube-description'),
  renderEntry('06-5-twitter-thread'),
  renderEntry('06-6-newsletter-section'),
  renderEntry('07-1-support'),
]);

// Content components (capitalized for use as Astro components)
const PersonalContent    = r01?.Content;
const InstallContent     = r021?.Content;
const First30Content     = r022?.Content;
const DeepDiveContent    = r023?.Content;
const PositioningContent = r031?.Content;
const DiffContent        = r032?.Content;
const FaqContent         = r033?.Content;
const AnglesContent      = r034?.Content;
const FtcContent         = r041?.Content;
const ForbiddenContent   = r042?.Content;
const DoubtContent       = r043?.Content;
const AssetsContent      = r05?.Content;
const Script60Content    = r061?.Content;
const Script3mContent    = r062?.Content;
const Script30Content    = r063?.Content;
const YtDescContent      = r064?.Content;
const TweetContent       = r065?.Content;
const NewsletterContent  = r066?.Content;
const SupportContent     = r07?.Content;

// Structured frontmatter data
const heroData      = byId['00-hero']?.data;
const lastUpdated   = heroData?.lastUpdated ?? '2026-05-15';
const faqItems      = byId['03-3-audience-faq']?.data?.faqs ?? [];
const positioningCopyables  = byId['03-1-core-positioning']?.data?.copyables ?? [];
const diffCopyables         = byId['03-2-differentiation']?.data?.copyables ?? [];
const anglesCopyables       = byId['03-4-angles-by-audience']?.data?.copyables ?? [];
const ftcCopyables          = byId['04-1-ftc-disclosure']?.data?.copyables ?? [];
const script60Copyables     = byId['06-1-video-60s-hook']?.data?.copyables ?? [];
const script3mCopyables     = byId['06-2-video-3min-walkthrough']?.data?.copyables ?? [];
const script30Copyables     = byId['06-3-video-30s-short']?.data?.copyables ?? [];
const ytDescCopyables       = byId['06-4-youtube-description']?.data?.copyables ?? [];
const tweetCopyables        = byId['06-5-twitter-thread']?.data?.copyables ?? [];
const newsletterCopyables   = byId['06-6-newsletter-section']?.data?.copyables ?? [];

// ── Section index for search + What's new ─────────────────────
const sectionMeta: Record<string, { anchor: string; title: string }> = {
  'personal-details':   { anchor: 's1', title: 'Your Details' },
  'get-started':        { anchor: 's2', title: 'Get Started' },
  'talking-points':     { anchor: 's3', title: 'Talking Points' },
  'compliance':         { anchor: 's4', title: 'Compliance' },
  'visual-assets':      { anchor: 's5', title: 'Visual Assets' },
  'content-templates':  { anchor: 's6', title: 'Content Templates' },
  'support':            { anchor: 's7', title: 'Support' },
  'hero':               { anchor: '',   title: '' },
};

// Build the client-side search index
function flattenMarkdown(raw: string): string {
  return raw
    .replace(/```[\s\S]*?```/g, ' ')      // fenced code
    .replace(/`[^`]+`/g, ' ')             // inline code
    .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ') // images
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1') // links → label
    .replace(/[#>*_~|]/g, ' ')            // markdown syntax chars
    .replace(/\s+/g, ' ')
    .trim();
}

const searchIndex = allEntries
  .filter((e) => e.data.section !== 'hero')
  .map((entry) => {
    const meta = sectionMeta[entry.data.section] ?? { anchor: '', title: entry.data.section };
    const bodyText = flattenMarkdown(entry.body ?? '');
    const copyableTexts = (entry.data.copyables ?? []).map((c) => `${c.label}: ${c.content}`).join(' ');
    const faqTexts = (entry.data.faqs ?? []).map((f) => `${f.q} ${f.a}`).join(' ');
    return {
      id: entry.id,
      sectionAnchor: meta.anchor,
      sectionTitle: meta.title,
      title: entry.data.title,
      text: `${bodyText} ${copyableTexts} ${faqTexts}`.slice(0, 3000),
      copyableLabels: (entry.data.copyables ?? []).map((c) => c.label),
    };
  });

// Build the "what's new" list (last 14 days)
const today = new Date('2026-05-15');
const fourteenDaysAgo = new Date(today.getTime() - 14 * 24 * 60 * 60 * 1000);
const recentUpdates = allEntries
  .filter((e) => {
    if (!e.data.lastUpdated || e.data.section === 'hero') return false;
    const d = new Date(e.data.lastUpdated);
    return d >= fourteenDaysAgo;
  })
  .sort((a, b) => (b.data.lastUpdated ?? '').localeCompare(a.data.lastUpdated ?? ''))
  .slice(0, 8)
  .map((e) => {
    const meta = sectionMeta[e.data.section] ?? { anchor: '', title: '' };
    return {
      id: e.id,
      title: e.data.title,
      anchor: meta.anchor,
      lastUpdated: e.data.lastUpdated ?? '',
    };
  });

// ── Quick-access strip canonical copy ──────────────────────────
const oneSentencePitch = positioningCopyables[0]?.content ?? '';
const ftcShortDisclosure = ftcCopyables[0]?.content ?? '';
const promoCodeTemplate = 'Code [YOURCODE] is 10% off every renewal — not just the first month.';

// ── Visual asset grid (categorized) ────────────────────────────
type Asset = {
  label: string;
  desc: string;
  thumb?: string;
  href?: string;          // direct download/view URL; absent ⇒ "coming soon"
  type: 'image' | 'video' | 'pdf' | 'youtube';
};

type AssetCategory = {
  title: string;
  items: Asset[];
};

const assetCategories: AssetCategory[] = [
  {
    title: 'Logo',
    items: [
      { label: 'Logo — SVG (vector, transparent)', desc: 'Best quality at any size — use this for video, print, and high-res content', thumb: '/meridian-logo-light.png', href: '/meridian-logo.svg', type: 'image' },
      { label: 'Logo — light (PNG, 16:9)', desc: 'Horizontal layout, white background — for banners, thumbnails, overlays', thumb: '/meridian-logo-light.png', href: '/meridian-logo-light.png', type: 'image' },
      { label: 'Logo — dark (PNG, 16:9)', desc: 'Horizontal layout, black background — for dark content and overlays', thumb: '/meridian-logo-dark.png', href: '/meridian-logo-dark.png', type: 'image' },
      { label: 'Logo — light square (PNG)', desc: 'Square format, white background — for social profiles and thumbnails', thumb: '/meridian-logo-square-light.png', href: '/meridian-logo-square-light.png', type: 'image' },
      { label: 'Logo — dark square (PNG)', desc: 'Square format, black background — for dark social profiles and posts', thumb: '/meridian-logo-square-dark.png', href: '/meridian-logo-square-dark.png', type: 'image' },
    ],
  },
  {
    title: 'Live Monitor — HUD States',
    items: [
      { label: 'HUD — Stable', desc: 'Green zone, all signals flat', thumb: '/screenshots/hud-stable.png', href: '/screenshots/hud-stable.png', type: 'image' },
      { label: 'HUD — Warning', desc: 'Orange zone, Oversize signal active', thumb: '/screenshots/hud-warning-journal.png', href: '/screenshots/hud-warning-journal.png', type: 'image' },
      { label: 'HUD — Critical', desc: 'Red zone, high pressure, behavioral signals firing', thumb: '/screenshots/psi-critical.png', href: '/screenshots/psi-critical.png', type: 'image' },
    ],
  },
  {
    title: 'Guard — Intervention Levels',
    items: [
      { label: 'Guard — Acknowledge gate (L2)', desc: 'Must type a phrase to confirm before continuing', thumb: '/screenshots/guard-acknowledge.png', href: '/screenshots/guard-acknowledge.png', type: 'image' },
      { label: 'Guard — Countdown (L3)', desc: 'Forced cooldown timer, locked until it expires', thumb: '/screenshots/guard-countdown.png', href: '/screenshots/guard-countdown.png', type: 'image' },
      { label: 'Guard — Disconnect (L4)', desc: 'Broker connection cut, hard stop enforced by software', thumb: '/screenshots/guard-disconnect.png', href: '/screenshots/guard-disconnect.png', type: 'image' },
    ],
  },
  {
    title: 'Session Report',
    items: [
      { label: 'Session Report — PSI Insight', desc: 'PSI score, rule event log, overview stats', thumb: '/screenshots/session-report-full.png', href: '/screenshots/session-report-full.png', type: 'image' },
      { label: 'Session Report — Composure detail', desc: 'Composure Score, zone breakdown, tilt cascade log', thumb: '/screenshots/session-report-detail.png', href: '/screenshots/session-report-detail.png', type: 'image' },
    ],
  },
  {
    title: 'Intel — Analytics',
    items: [
      { label: "Intel — Today's risk brief + digest", desc: 'Pre-session summary, monthly composure grade, P&L correlation', thumb: '/screenshots/intel-overview.png', href: '/screenshots/intel-overview.png', type: 'image' },
      { label: 'Intel — Weekday patterns + progress', desc: 'Day-of-week breakdown, 6-month composure trend, crash patterns', thumb: '/screenshots/intel-performance-weekday.png', href: '/screenshots/intel-performance-weekday.png', type: 'image' },
    ],
  },
  {
    title: 'Journal & History',
    items: [
      { label: 'Journal — compiled daily view', desc: 'Auto-compiled session journal with trade entries and P&L', thumb: '/screenshots/journal-compiled.png', href: '/screenshots/journal-compiled.png', type: 'image' },
      { label: 'Journal — entries and reflection', desc: 'Session entries with mood tags, notes, and reflection prompts', thumb: '/screenshots/journal-entries.png', href: '/screenshots/journal-entries.png', type: 'image' },
      { label: 'History — month calendar', desc: 'PSI trend line and color-coded session calendar (April 2026)', thumb: '/screenshots/history-month-calendar.png', href: '/screenshots/history-month-calendar.png', type: 'image' },
    ],
  },
  {
    title: 'Settings & Profile',
    items: [
      { label: 'Settings — trading profile', desc: 'Session hours, position sizing, risk limits configuration', thumb: '/screenshots/settings-profile.png', href: '/screenshots/settings-profile.png', type: 'image' },
      { label: 'Settings — advanced and display', desc: 'Response level (Balanced), fine-tuning sliders, display modes', thumb: '/screenshots/settings-advanced.png', href: '/screenshots/settings-advanced.png', type: 'image' },
      { label: 'Profile — baseline learning', desc: 'Adaptive calibration progress, 140 sessions recorded', thumb: '/screenshots/profile-baseline.png', href: '/screenshots/profile-baseline.png', type: 'image' },
    ],
  },
  {
    title: 'B-roll Video',
    items: [
      { label: 'B-roll demo video (1080p, MP4)', desc: 'Use as background footage or picture-in-picture overlay', thumb: '/screenshots/hud-stable.png', href: '/videos/hero-demo.mp4', type: 'video' },
    ],
  },
  {
    title: 'Feature Demo Videos',
    items: [
      { label: 'PSI Monitor — feature walkthrough', desc: 'Live HUD, behavioral signals, and how PSI scores update in real time', thumb: '/screenshots/psi-monitor-thumb.jpg', href: 'https://www.youtube.com/watch?v=DjzPWxPGHs8', type: 'youtube' },
      { label: 'Adaptive Learning — settings walkthrough', desc: 'How the baseline learns from your sessions and how to configure your trading profile', thumb: '/screenshots/adaptive-learning-thumb.jpg', href: 'https://www.youtube.com/watch?v=3T-5hDFjeNQ', type: 'youtube' },
    ],
  },
];

// Detect if the optional "Download all" zip is shipped
import { existsSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
const zipPath = fileURLToPath(new URL('../../../public/partner-kit/meridian-creator-kit.zip', import.meta.url));
const zipAvailable = existsSync(zipPath);

const metadata = {
  title: 'Meridian Creator Kit',
  description: 'Everything you need to create great Meridian content.',
  robots: { index: false, follow: false },
};

const tocItems = [
  { id: 's1', label: 'Your Details',        icon: '01' },
  { id: 's2', label: 'Get Started',         icon: '02' },
  { id: 's3', label: 'Talking Points',      icon: '03' },
  { id: 's4', label: 'Compliance',          icon: '04' },
  { id: 's5', label: 'Visual Assets',       icon: '05' },
  { id: 's6', label: 'Content Templates',   icon: '06' },
  { id: 's7', label: 'Support',             icon: '07' },
];
---

<Layout metadata={metadata}>

  <!-- Skip to main content (keyboard / screen reader users) -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-emerald-600 focus:text-white focus:rounded-lg focus:text-sm focus:font-semibold"
  >
    Skip to main content
  </a>

  <!-- Search index for client-side fuzzy search -->
  <script type="application/json" id="kit-search-index" set:html={JSON.stringify(searchIndex)}></script>

  <!-- ═══════════════════════════════════════════════════════
       DASHBOARD HERO + WHAT'S NEW + QUICK ACTIONS + STRIP
       ═══════════════════════════════════════════════════════ -->
  <DashboardHero lastUpdated={lastUpdated} />

  <WhatsNewBanner updates={recentUpdates} />

  <QuickActionTiles />

  <QuickAccessStrip
    oneSentencePitch={oneSentencePitch}
    ftcShortDisclosure={ftcShortDisclosure}
    promoCodeTemplate={promoCodeTemplate}
  />

  <!-- ═══════════════════════════════════════════════════════
       MOBILE TOC  (visible below lg breakpoint)
       ═══════════════════════════════════════════════════════ -->
  <details
    id="toc-mobile"
    class="lg:hidden border-b border-zinc-100 dark:border-zinc-800 bg-zinc-50/70 dark:bg-zinc-900 print:hidden mt-8"
  >
    <summary class="px-6 py-3.5 text-sm font-medium text-zinc-700 dark:text-zinc-300 cursor-pointer list-none flex items-center justify-between select-none">
      <span>Jump to section</span>
      <svg class="w-4 h-4 text-zinc-400 transition-transform [[open]_&]:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <nav aria-label="Section navigation (mobile)" class="px-6 pb-4 grid grid-cols-2 gap-1">
      {tocItems.map((item) => (
        <a
          href={`#${item.id}`}
          class="flex items-center gap-2 py-2 px-3 rounded-lg text-sm text-zinc-500 dark:text-zinc-400 hover:bg-white dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors"
        >
          <span class="text-xs font-mono text-emerald-600 dark:text-emerald-400 w-5 shrink-0">{item.icon}</span>
          {item.label}
        </a>
      ))}
    </nav>
  </details>

  <!-- ═══════════════════════════════════════════════════════
       TWO-COLUMN LAYOUT
       ═══════════════════════════════════════════════════════ -->
  <div class="max-w-6xl mx-auto px-6 flex gap-10 pt-8 pb-28">

    <!-- Sidebar TOC (hidden on mobile, sticky on desktop) -->
    <aside
      class="hidden lg:block w-56 shrink-0 print:hidden"
      aria-label="Section navigation"
    >
      <nav class="sticky top-24 space-y-3" id="toc-nav">

        <!-- Search trigger -->
        <KitSearch />

        <div class="border-t border-zinc-100 dark:border-zinc-800 pt-3 space-y-0.5">
          {tocItems.map((item) => (
            <a
              href={`#${item.id}`}
              data-toc-target={item.id}
              class="toc-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors"
            >
              <span class="text-xs font-mono text-zinc-300 dark:text-zinc-600 w-5 shrink-0 toc-icon" aria-hidden="true">{item.icon}</span>
              {item.label}
            </a>
          ))}
        </div>

        {zipAvailable && (
          <div class="pt-3 border-t border-zinc-100 dark:border-zinc-800">
            <a
              href="/partner-kit/meridian-creator-kit.zip"
              download
              class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-semibold text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 transition-colors"
            >
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download all assets
            </a>
          </div>
        )}
      </nav>
    </aside>

    <!-- Main content -->
    <main id="main-content" class="flex-1 min-w-0 space-y-5">

      <!-- ── § 1 Your Personal Details ───────────────────── -->
      <CollapsibleSection id="s1" numLabel="01" title="Your Personal Details" subtitle="Save your code and link once — every template auto-fills from here." defaultOpen={true}>

        <!-- One-time personalization setup form -->
        <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 p-5 mb-7" id="kit-setup-panel">
          <p class="text-xs font-medium uppercase tracking-widest text-zinc-400 mb-4">Auto-fill your templates</p>
          <div class="grid sm:grid-cols-3 gap-3">
            <div>
              <label for="setup-name" class="block text-xs text-zinc-500 mb-1.5">Your name</label>
              <input id="setup-name" type="text" placeholder="Gary" autocomplete="off" class="w-full px-3 py-2 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 text-sm text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 focus:border-emerald-400" />
            </div>
            <div>
              <label for="setup-code" class="block text-xs text-zinc-500 mb-1.5">Promo code</label>
              <input id="setup-code" type="text" placeholder="YOURNAME10" autocomplete="off" class="w-full px-3 py-2 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 text-sm text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 focus:border-emerald-400" />
            </div>
            <div>
              <label for="setup-link" class="block text-xs text-zinc-500 mb-1.5">Affiliate link</label>
              <input id="setup-link" type="text" placeholder="whop.com/meridian/?a=yourname" autocomplete="off" class="w-full px-3 py-2 rounded-lg border border-zinc-200 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 text-sm text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 focus:border-emerald-400" />
            </div>
          </div>
          <div class="flex items-center gap-3 mt-4">
            <button id="setup-save" type="button" class="px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500/40">
              Save &amp; apply
            </button>
            <p id="setup-status" class="text-xs text-zinc-400 opacity-0 transition-opacity">Saved — all templates updated.</p>
          </div>
        </div>

        <div class="prose prose-zinc dark:prose-invert max-w-none prose-sm">
          {PersonalContent ? <PersonalContent /> : <p class="text-zinc-400 italic">Content coming soon.</p>}
        </div>
      </CollapsibleSection>

      <!-- ── § 2 Get Started ─────────────────────────────── -->
      <CollapsibleSection id="s2" numLabel="02" title="Get Started with Meridian" subtitle="Install, configure, and understand the product before you make content about it.">
        <div class="space-y-10">
          <div>
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-3">Install Meridian</h3>
            <div class="prose prose-zinc dark:prose-invert max-w-none prose-sm">
              {InstallContent ? <InstallContent /> : <p class="text-zinc-400 italic">Content coming soon.</p>}
            </div>
          </div>

          <div>
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-3">Your first 30 minutes</h3>
            <div class="prose prose-zinc dark:prose-invert max-w-none prose-sm">
              {First30Content ? <First30Content /> : <p class="text-zinc-400 italic">Content coming soon.</p>}
            </div>
          </div>

          <div>
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-3">Product deep dive</h3>
            <div class="prose prose-zinc dark:prose-invert max-w-none prose-sm">
              {DeepDiveContent ? <DeepDiveContent /> : <p class="text-zinc-400 italic">Content coming soon.</p>}
            </div>
          </div>
        </div>
      </CollapsibleSection>

      <!-- ── § 3 Talking Points ──────────────────────────── -->
      <CollapsibleSection id="s3" numLabel="03" title="Talking Points" subtitle="Use these verbatim, paraphrase them, or use them to calibrate the right level of precision. Accuracy matters more than matching word-for-word." defaultOpen={true}>
        <div class="space-y-10">

          <!-- 3.1 Core Positioning -->
          <div>
            <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-4">Core positioning</h3>
            {positioningCopyables.length > 0 ? (
              <div class="space-y-3">
                {positioningCopyables.map((item: { label: string; content: string }) => (
                  <div class="rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 overflow-hidden">
                    <div class="flex items-center justify-between px-4 py-2.5 border-b border-zinc-100 dark:border-zinc-800">
                      <span class="text-xs font-medium text-zinc-400 uppercase tracking-widest">{item.label}</span>
                      <div class="flex items-center gap-3">
                        <button type="button" class="pin-btn flex items-center gap-1 text-xs text-zinc-400 hover:text-emerald-700 dark:hover:text-emerald-400 transition-colors focus-visible:outline-none" data-pin-label={item.label} data-pin-content={item.content} data-pin-source="Core positioning" aria-label={`Pin ${item.label}`} aria-pressed="false">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" /></svg>
                          <span class="pin-label">Pin</span>
                        </button>
