    </main>
  </div>

  <!-- Pinned drawer (global overlay) -->
  <PinnedDrawer />

  <!-- ═══════════════════════════════════════════════════════
       STICKY BOTTOM BAR
       ═══════════════════════════════════════════════════════ -->
  <div
    id="sticky-bar"
    class="fixed bottom-0 left-0 right-0 z-30 border-t border-zinc-200 dark:border-zinc-700 bg-white/90 dark:bg-zinc-950/90 backdrop-blur-sm px-6 py-3 print:hidden"
    role="complementary"
    aria-label="Quick actions"
  >
    <div class="max-w-6xl mx-auto flex items-center justify-between gap-4">
      <p class="text-xs text-zinc-400 dark:text-zinc-500 hidden sm:block">
        Questions? <a href="mailto:garycaffrey@meridian-partnership.com" class="underline hover:text-zinc-600 dark:hover:text-zinc-300">garycaffrey@meridian-partnership.com</a>
      </p>
      <div class="flex items-center gap-3 ml-auto">
        <a
          href="mailto:garycaffrey@meridian-partnership.com"
          class="sm:hidden inline-flex items-center gap-1.5 px-4 py-2 rounded-full border border-zinc-200 dark:border-zinc-700 text-xs font-medium text-zinc-500 hover:text-zinc-700 hover:border-zinc-300 transition-colors"
        >
          Questions?
        </a>
        <button
          type="button"
          id="sticky-search-trigger"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-zinc-200 dark:border-zinc-700 text-xs font-medium text-zinc-500 hover:text-zinc-700 hover:border-zinc-300 transition-colors"
          aria-label="Open kit search"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <span class="hidden sm:inline">Search</span>
          <kbd class="hidden md:inline text-xs font-mono opacity-50">⌘K</kbd>
        </button>
      </div>
    </div>
  </div>

</Layout>

<style>
  /* Print styles */
  @media print {
    #sticky-bar,
    #toc-nav,
    #toc-mobile,
    .copy-btn,
    .pin-btn { display: none !important; }
    /* Force all sections open in print */
    .kit-section { display: block !important; }
    .kit-section[open],
    .kit-section:not([open]) > div { display: block !important; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    * { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
  }

  /* Copy button copied state */
  .copy-btn.copied .copy-label { color: rgb(5 150 105); }
  .copy-btn.copied .copy-icon { color: rgb(5 150 105); }

  /* TOC active link */
  .toc-link.active {
    color: rgb(5 150 105);
    background-color: rgb(240 253 244 / 0.7);
    font-weight: 600;
  }
  .dark .toc-link.active {
    color: rgb(52 211 153);
    background-color: rgb(6 78 59 / 0.25);
  }
  .toc-link.active .toc-icon {
    color: rgb(5 150 105);
  }
  .dark .toc-link.active .toc-icon {
    color: rgb(52 211 153);
  }
</style>

<script>
  /* ── 1. Scroll-spy: highlight active TOC link ───────────── */
  (function () {
    const sections = document.querySelectorAll<HTMLElement>('.kit-section');
    const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-target]');
    if (!sections.length || !links.length) return;

    let current = '';

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            current = entry.target.id;
            links.forEach((link) => {
              const active = link.dataset.tocTarget === current;
              link.classList.toggle('active', active);
            });
          }
        });
      },
      { rootMargin: '-15% 0px -75% 0px', threshold: 0 }
    );

    sections.forEach((s) => observer.observe(s));
  })();

  /* ── 2. Personalization: seed localStorage from URL params & setup form ── */
  (function () {
    const KEYS = { name: 'meridian-kit:name', code: 'meridian-kit:code', link: 'meridian-kit:link' };

    // Seed from URL params (welcome-email link)
    const params = new URLSearchParams(window.location.search);
    if (params.get('name')) localStorage.setItem(KEYS.name, decodeURIComponent(params.get('name')!));
    if (params.get('code')) localStorage.setItem(KEYS.code, decodeURIComponent(params.get('code')!));
    if (params.get('link')) localStorage.setItem(KEYS.link, decodeURIComponent(params.get('link')!));

    // Populate setup form fields from localStorage
    const nameEl = document.getElementById('setup-name') as HTMLInputElement | null;
    const codeEl = document.getElementById('setup-code') as HTMLInputElement | null;
    const linkEl = document.getElementById('setup-link') as HTMLInputElement | null;
    if (nameEl) nameEl.value = localStorage.getItem(KEYS.name) ?? '';
    if (codeEl) codeEl.value = localStorage.getItem(KEYS.code) ?? '';
    if (linkEl) linkEl.value = localStorage.getItem(KEYS.link) ?? '';

    // Save button
    document.getElementById('setup-save')?.addEventListener('click', () => {
      if (nameEl) localStorage.setItem(KEYS.name, nameEl.value.trim());
      if (codeEl) localStorage.setItem(KEYS.code, codeEl.value.trim().toUpperCase());
      if (linkEl) localStorage.setItem(KEYS.link, linkEl.value.trim());
      const status = document.getElementById('setup-status');
      if (status) {
        status.style.opacity = '1';
        setTimeout(() => { status.style.opacity = '0'; }, 2500);
      }
    });
  })();

  /* ── Personalization helper ─────────────────────────────── */
  function applyPersonalization(text: string): string {
    const code = localStorage.getItem('meridian-kit:code') ?? '';
    const link = localStorage.getItem('meridian-kit:link') ?? '';
    const name = localStorage.getItem('meridian-kit:name') ?? '';
    if (!code && !link && !name) return text;
    return text
      .replace(/\[YOURCODE\]/g, code || '[YOURCODE]')
      .replace(/\[YOUR AFFILIATE LINK\]/g, link || '[YOUR AFFILIATE LINK]')
      .replace(/\[YOURNAME\]/g, name || '[YOURNAME]');
  }

  /* ── 3. Copy-to-clipboard buttons ──────────────────────── */
  (function () {
    document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const raw = btn.getAttribute('data-copy') ?? '';
        const text = applyPersonalization(raw);
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.focus();
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        const label = btn.querySelector<HTMLElement>('.copy-label');
        if (label) {
          const original = label.textContent;
          label.textContent = 'Copied';
          btn.classList.add('copied');
          setTimeout(() => {
            label.textContent = original;
            btn.classList.remove('copied');
          }, 1500);
        }
      });
    });
  })();

  /* ── 4. Sticky-bar search shortcut ─────────────────────── */
  (function () {
    document.getElementById('sticky-search-trigger')?.addEventListener('click', () => {
      document.getElementById('kit-search-trigger')?.click();
    });
  })();
</script>
