---
import Layout from '~/layouts/PageLayout.astro';

// ─────────────────────────────────────────────────────────────────────────────
// CONTACT US — deliberately simple: a short header, the Formspree contact form,
// and the email. Low friction by design (no "please include X" checklist).
// The fuller help hub with resource links lives at /support.
// ─────────────────────────────────────────────────────────────────────────────

const SUPPORT_EMAIL = 'contactmeridianpsi@gmail.com';

const metadata = {
  title: 'Contact Us',
  description:
    'Contact the Meridian team — installation help, bug reports, billing, or any question. Send a message and we reply within 24 hours.',
  robots: { index: true, follow: true },
};

const contactJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Meridian',
  url: 'https://www.meridianpsi.com/contact',
  description: 'Contact the Meridian team. We reply within 24 hours.',
  publisher: {
    '@type': 'Organization',
    name: 'Meridian',
    url: 'https://www.meridianpsi.com',
    email: SUPPORT_EMAIL,
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer support',
      email: SUPPORT_EMAIL,
      availableLanguage: 'English',
    },
  },
};
const contactJsonLdHtml = JSON.stringify(contactJsonLd).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={contactJsonLdHtml} />

  <section class="halo">
    <div class="max-w-2xl mx-auto px-6 pt-20 md:pt-24 pb-10 text-center" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">CONTACT US</p>
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-[1.05]">Get in touch.</h1>
      <p class="mt-6 text-lg text-zinc-600 leading-relaxed max-w-xl mx-auto">
        Send us a message &mdash; we respond as quickly as we can, and promise to reply within
        <span class="font-semibold text-zinc-800">24 hours</span>. A real reply from the team, not an auto-responder.
      </p>
      <a href={`mailto:${SUPPORT_EMAIL}`} class="mt-6 inline-block font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3 rounded-xl transition">
        {SUPPORT_EMAIL}
      </a>
    </div>
  </section>

  <section class="max-w-xl mx-auto px-6 pb-24">
    <div class="rounded-2xl border border-zinc-200 bg-white p-7 md:p-8 shadow-sm" data-reveal>
      <form action="https://formspree.io/f/xaqalank" method="POST" class="space-y-5" id="contact-form">
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-medium text-zinc-700 mb-1.5">Name</label>
            <input type="text" name="name" id="name" required placeholder="Your name"
              class="w-full rounded-xl border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-zinc-700 mb-1.5">Email</label>
            <input type="email" name="email" id="email" required placeholder="your@email.com"
              class="w-full rounded-xl border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition" />
          </div>
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium text-zinc-700 mb-1.5">Topic</label>
          <select name="subject" id="subject" required
            class="w-full rounded-xl border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition">
            <option value="" disabled selected>Select a topic</option>
            <option value="Installation help">Installation help</option>
            <option value="Platform / early access">Platform / early access</option>
            <option value="Bug report">Bug report</option>
            <option value="Subscription / billing">Subscription / billing</option>
            <option value="Feature question">Feature question</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-zinc-700 mb-1.5">Message</label>
          <textarea name="message" id="message" required rows="5" placeholder="How can we help?"
            class="w-full rounded-xl border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition resize-none"></textarea>
        </div>

        <button type="submit" class="w-full font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm">
          Send message
        </button>

        <p class="text-xs text-center text-zinc-500">
          We reply within 24 hours. You can also email
          <a href={`mailto:${SUPPORT_EMAIL}`} class="underline underline-offset-2 hover:text-zinc-700">{SUPPORT_EMAIL}</a>.
        </p>
      </form>

      <div id="contact-success" class="hidden text-center py-12">
        <div class="mx-auto mb-4 inline-flex items-center justify-center w-14 h-14 rounded-full bg-emerald-50 border border-emerald-200">
          <svg class="w-7 h-7 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7" /></svg>
        </div>
        <h3 class="text-xl font-semibold text-zinc-900 mb-2">Message sent.</h3>
        <p class="text-zinc-600 text-sm">Thanks &mdash; we'll get back to you within 24 hours.</p>
      </div>
    </div>
  </section>
</Layout>

<script>
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const successDiv = document.getElementById('contact-success');
    if (!form || !successDiv) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      try {
        const response = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
        if (response.ok) {
          form.classList.add('hidden');
          successDiv.classList.remove('hidden');
        } else {
          alert('Something went wrong. Please email us directly at contactmeridianpsi@gmail.com.');
        }
      } catch {
        alert('Network error. Please email us directly at contactmeridianpsi@gmail.com.');
      }
    });
  }
  document.addEventListener('astro:page-load', initContactForm);
</script>
