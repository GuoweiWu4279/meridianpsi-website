---
import Layout from '~/layouts/PageLayout.astro';
import pricing from '~/data/pricing.json';
import geoHooks from '~/data/geo-hooks.json';
import guardData from '~/data/guard.json';

const coreTier = pricing.tiers[0]!;
const guardTier = pricing.tiers[1]!;
const usd = (n: number) => n.toFixed(2);

const metadata = {
  // Brand already leads the title — suppress the site-wide "— Meridian" suffix.
  title: 'Meridian Guard — Behavioral Trade Lockout for NinjaTrader 8, Tradovate & Ironbeam',
  ignoreTitleTemplate: true,
  description: `${geoHooks.meridianGuardHook} You write the rules when calm; Guard enforces them when you are not — six triggers, an escalating enforcement ladder (five levels on NinjaTrader 8, six tiers on the standalone Tradovate & Ironbeam apps), standing Hard limits, and a Strict Lock your tilted self cannot switch off. After a 14-day free trial: $${usd(guardTier.monthlyPrice)}/mo or $${usd(guardTier.annualPrice)}/yr. Trading involves substantial risk.`,
  robots: { index: true, follow: true },
};

const guardCheckout = guardTier.monthlyCtaHref ?? 'https://whop.com/checkout/plan_ZHX4ySB65fahf';

const guardOffers = [
  {
    '@type': 'Offer',
    name: 'Meridian Guard — monthly (after trial)',
    price: usd(guardTier.monthlyPrice),
    priceCurrency: guardTier.currency,
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: usd(guardTier.monthlyPrice),
      priceCurrency: guardTier.currency,
      billingDuration: 'P1M',
    },
  },
  {
    '@type': 'Offer',
    name: 'Meridian Guard — annual (after trial)',
    price: usd(guardTier.annualPrice),
    priceCurrency: guardTier.currency,
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: usd(guardTier.annualPrice),
      priceCurrency: guardTier.currency,
      billingDuration: 'P1Y',
    },
  },
];

const guardSchemaJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Meridian Guard',
  applicationCategory: 'FinanceApplication',
  applicationSubCategory: 'TradingApplication',
  operatingSystem: 'Windows 10 or later',
  description: geoHooks.schemaSoftwareGuard,
  keywords: geoHooks.geoSearchAssociate,
  url: 'https://www.meridianpsi.com/guard',
  featureList: [
    'Six trigger conditions: PSI Below, Consecutive Losses, Session P&L Below, Unrealized P&L Below, Single Trade Loss, Session Time Over',
    'Five response levels on NinjaTrader 8: Notify (L1), Risk Alert (L2, a non-blocking persistent banner), Acknowledge (L3, the level that blocks the entry), Trading Pause (L4), Disconnect (L5)',
    'Six-tier ladder on the standalone Tradovate/Ironbeam apps: Notify, Alert, Acknowledge, Pause, Cool-down Wall, Cut',
    'Trading Pause (L4): blocks new entries by cancelling orders while staying connected; Disconnect (L5): severs the broker connection',
    'Cool-down Wall (standalone): full-screen guided cool-down with breathing pacing; soft or hard wall, never traps an open position',
    "Cut (standalone): Windows-firewall block of the broker's order servers — an order physically cannot leave the PC; auto-lifts when the window ends",
    'Hard limits (Guard tier, off by default; both NinjaTrader 8 and the standalone apps): a standing max-contracts cap and blocked entry order types — over-cap or blocked entries are stopped at submission, a slipped market order is trimmed back, and closing or reducing is never blocked',
    "Broker-level lock (standalone, Tradovate demo and eval accounts only): Guard writes Tradovate's own liquidate-only lock — enforcement at the broker that holds even if you close the app, reboot, or log in from another device",
    'Auto-flatten (opt-in, off by default): on a Trading Pause (L4) or Disconnect (L5) rule, optionally close all open positions the moment that rule fires',
    'Strict Lock: one switch set while calm — every pause or disconnect Guard fires holds for its full window with no in-app early exit, force-reset, or Guard-off, rules frozen; survives a NinjaTrader restart',
    'Anonymous by design — no name, credentials, or funds collected',
  ],
  offers: guardOffers,
  softwareVersion: '1.5.5',
  requirements:
    'NinjaTrader 8 (64-bit) or the standalone Windows app for Tradovate/Ironbeam; Windows 10 or later, 4 GB RAM',
  publisher: {
    '@type': 'Organization',
    name: 'Meridian',
    url: 'https://www.meridianpsi.com',
  },
  isPartOf: {
    '@type': 'SoftwareApplication',
    name: 'Meridian',
    url: 'https://www.meridianpsi.com',
  },
});

/** Intel Layer — black 16:9 frame, image only (no in-frame captions). */
const intelSlides = [
  { img: '/screenshots/psi-performance.png', alt: 'PSI × Performance' },
  { img: '/screenshots/digest-march.png', alt: 'Monthly Digest' },
  { img: '/screenshots/intel-weekdaypattern.png', alt: 'Weekday Patterns' },
  { img: '/screenshots/intel-risk-brief.png', alt: "Today's Risk Brief" },
  {
    img: '/screenshots/intel-stats-showcase.png',
    alt: 'Stats — custom date ranges with win rate, profit factor, and breakdowns by time of day, hold time, instrument, and long/short',
  },
];

const { triggers, levels, examples, standaloneExamples } = guardData;
const v2 = guardData.standalone;
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={guardSchemaJson} />

  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="halo">
    <div class="max-w-5xl mx-auto px-6 pt-20 md:pt-24 pb-10 text-center" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-6">MERIDIAN GUARD &middot; THE ENFORCEMENT LAYER</p>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tight text-zinc-900 leading-[1.04]">
        Willpower is not<br />a risk strategy.
      </h1>
      <p class="mt-7 max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 leading-relaxed">
        You write the rules when you're calm. Guard enforces them when you're not &mdash; escalating exactly as far as
        you decide, from a quiet nudge to a hard cutoff between you and the next order. No decision required from the
        tilted version of you.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href={guardCheckout}
          class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm"
          >Start 14-day free trial</a
        >
        <a
          href="#ladder"
          class="font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3.5 rounded-xl transition"
          >See how it enforces</a
        >
      </div>
      <p class="mt-4 text-xs text-zinc-500">
        No charge until day 14 &middot; ${usd(guardTier.monthlyPrice)}/mo after trial &middot; Cancel anytime
      </p>
    </div>
    <div class="max-w-5xl mx-auto px-6 pb-16 md:pb-20" data-reveal>
      <div class="win">
        <img
          src="/m/guard.png"
          alt="Meridian Guard configuration — your own rules with an escalating enforcement ladder and a Strict Lock your tilted self cannot switch off"
        />
      </div>
    </div>
  </section>

  <!-- ───────────────────────── TRUST STRIP ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div
      class="max-w-6xl mx-auto px-6 py-4 flex flex-wrap items-center justify-center gap-x-7 gap-y-2 text-[13px] text-zinc-500"
    >
      <span class="inline-flex items-center gap-1.5 text-emerald-700 font-bold text-sm">
        <svg
          class="w-4 h-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="M9 12l2 2 4-4"></path><circle cx="12" cy="12" r="9"></circle></svg
        >
        Official NinjaTrader Ecosystem Vendor
      </span>
      <span class="text-zinc-300">|</span><span
        >A lockout your tilted self can't switch off &mdash; and that survives a restart</span
      >
    </div>
  </section>

  <!-- ───────────────────────── THE PREMISE / COMMITMENT DEVICE ───────────────────────── -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div class="text-center mb-12" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">WHY GUARD EXISTS</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">
        Two different people make<br />these two decisions.
      </h2>
      <p class="mt-5 text-lg text-zinc-600 max-w-2xl mx-auto">
        The trader who sets a daily loss limit at 8am is calm, rested, and rational. The trader who wants to override it
        at 11am &mdash; three losses deep &mdash; is not. Guard puts the calm one in charge of the day.
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto" data-reveal>
      <div class="rounded-2xl border border-zinc-200 bg-white p-7">
        <div class="text-sm font-semibold text-zinc-500 mb-4">You — at 8am, calm</div>
        <ul class="space-y-3 text-zinc-700">
          <li class="flex gap-3">
            <span class="text-emerald-600 font-bold">&check;</span><span
              >Pick the triggers that mean "I'm done for today"</span
            >
          </li>
          <li class="flex gap-3">
            <span class="text-emerald-600 font-bold">&check;</span><span>Choose how hard each one bites</span>
          </li>
          <li class="flex gap-3">
            <span class="text-emerald-600 font-bold">&check;</span><span>Optionally lock the settings shut</span>
          </li>
        </ul>
        <p class="mt-5 text-sm text-zinc-500">This version of you writes the rules.</p>
      </div>
      <div class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-7">
        <div class="text-sm font-semibold text-emerald-700 mb-4">You — at 11am, tilted</div>
        <ul class="space-y-3 text-zinc-800">
          <li class="flex gap-3">
            <span class="text-zinc-400">&times;</span> Wants to "make it back" with one more trade
          </li>
          <li class="flex gap-3"><span class="text-zinc-400">&times;</span> Wants to widen the stop just this once</li>
          <li class="flex gap-3"><span class="text-zinc-400">&times;</span> Wants to switch the limits off</li>
        </ul>
        <p class="mt-5 text-sm text-emerald-700 font-medium">This version doesn't get a vote.</p>
      </div>
    </div>
    <div class="max-w-3xl mx-auto mt-8 rounded-2xl calloutd text-zinc-100 px-7 py-6 text-center">
      <p class="text-lg md:text-xl leading-relaxed">
        Behavioral economists call this a <span class="text-emerald-400 font-semibold">commitment device</span> &mdash; a
        mechanism you set up in advance to constrain your future self.<br class="hidden md:block" />
        Institutional desks have compliance systems that do it automatically. Guard is that, for you.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── STEP 1 — TRIGGERS ───────────────────────── -->
  <section id="ladder" class="border-y border-zinc-200 bg-white scroll-mt-20">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="text-center mb-12" data-reveal>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">STEP 1 &middot; THE 6 TRIGGERS</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Decide what "too far" means.</h2>
        <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">
          Six conditions Guard watches every session &mdash; the same six on every platform. Pick the ones that matter
          to you and set the numbers. Each fires once on entry, then resets &mdash; no nagging.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto" data-reveal>
        {
          triggers.map((item) => (
            <div class="rounded-xl border border-zinc-200 bg-[#fafafa] p-5">
              <div class="flex items-start gap-2.5">
                <svg
                  class="w-4 h-4 mt-1 text-emerald-600 shrink-0"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <div>
                  <div class="font-semibold text-zinc-900">{item.name}</div>
                  <p class="mt-1 text-sm text-zinc-600 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
      <p class="text-center mt-6 text-sm text-zinc-500 max-w-2xl mx-auto">
        Five of these are the same hard numbers a traditional risk tool gives you &mdash; daily loss, single-trade loss,
        drawdown, loss streak, session length. The sixth, <span class="text-emerald-700 font-semibold">PSI Below</span>,
        fires on the behavior itself, before the money moves.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── STEP 2 — THE ESCALATION LADDER (PLATFORM TOGGLE) ───────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-10" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">STEP 2 &middot; THE ESCALATION LADDER</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Then decide how hard it bites.</h2>
      <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">
        The same trigger can be a whisper or a wall &mdash; you set the level. The ladder differs by where Guard runs:
        five response levels inside NinjaTrader&nbsp;8, six tiers on the standalone Tradovate &amp; Ironbeam apps. Same
        engine, honest differences.
      </p>
    </div>

    <!-- Platform toggle -->
    <div class="flex justify-center mb-10" data-reveal>
      <div
        class="inline-flex rounded-xl border border-zinc-300 bg-white p-1 shadow-sm"
        role="tablist"
        aria-label="Choose platform"
      >
        <button
          type="button"
          role="tab"
          data-ladder-tab
          data-ladder-idx="0"
          aria-selected="true"
          class="px-4 sm:px-5 py-2.5 rounded-lg text-sm font-semibold transition text-white bg-emerald-600"
        >
          NinjaTrader 8 <span class="font-normal opacity-80">&middot; 5 levels</span>
        </button>
        <button
          type="button"
          role="tab"
          data-ladder-tab
          data-ladder-idx="1"
          aria-selected="false"
          class="px-4 sm:px-5 py-2.5 rounded-lg text-sm font-semibold transition text-zinc-700 hover:text-zinc-900"
        >
          Standalone &middot; Tradovate &amp; Ironbeam <span class="font-normal opacity-70">&middot; 6 tiers</span>
        </button>
      </div>
    </div>

    <div data-ladder-root>
      <!-- NT8 PANEL -->
      <div data-ladder-panel data-ladder-idx="0" class="max-w-5xl mx-auto">
        <div class="flex h-2 rounded-full overflow-hidden mb-3 gap-0.5">
          {levels.map((l) => <div class="flex-1 rounded-full" style={`background:${l.color};`} />)}
        </div>
        <div class="flex justify-between text-xs text-zinc-500 mb-8 px-0.5">
          <span>Softest &mdash; a nudge</span>
          <span>Hardest &mdash; broker disconnect</span>
        </div>
        <ol class="space-y-3">
          {
            levels.map((item) => (
              <li class="rounded-2xl border border-zinc-200 bg-white p-5 md:p-6 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5 shadow-sm">
                <div class="flex items-center gap-3 sm:w-56 shrink-0">
                  <span
                    class="text-[11px] font-bold tracking-widest px-2 py-1 rounded text-white tnum"
                    style={`background:${item.color};`}
                  >
                    {item.level}
                  </span>
                  <span class="font-semibold text-zinc-900">{item.name}</span>
                </div>
                <p class="text-zinc-600 text-sm leading-relaxed">{item.desc}</p>
              </li>
            ))
          }
        </ol>
        <p class="mt-5 text-sm text-zinc-500 text-center max-w-2xl mx-auto">
          Inside NinjaTrader&nbsp;8, the hardest stop is a broker <strong class="text-zinc-700">Disconnect</strong> &mdash;
          Guard severs the connection and cancels working orders. There is no firewall Cut or broker-side lock here; those
          are standalone-only.
        </p>
      </div>

      <!-- STANDALONE PANEL -->
      <div data-ladder-panel data-ladder-idx="1" class="max-w-5xl mx-auto" hidden>
        <div class="flex h-2 rounded-full overflow-hidden mb-3 gap-0.5">
          {v2.tiers.map((l) => <div class="flex-1 rounded-full" style={`background:${l.color};`} />)}
        </div>
        <div class="flex justify-between text-xs text-zinc-500 mb-8 px-0.5">
          <span>Softest &mdash; a nudge</span>
          <span>Hardest &mdash; a firewall Cut</span>
        </div>
        <ol class="space-y-3">
          {
            v2.tiers.map((item) => (
              <li class="rounded-2xl border border-zinc-200 bg-white p-5 md:p-6 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5 shadow-sm">
                <div class="flex items-center gap-3 sm:w-56 shrink-0">
                  <span
                    class="text-[11px] font-bold tracking-widest px-2 py-1 rounded text-white tnum"
                    style={`background:${item.color};`}
                  >
                    T{item.tier}
                  </span>
                  <span class="font-semibold text-zinc-900">{item.name}</span>
                </div>
                <div>
                  <p class="text-zinc-800 text-sm font-medium">{item.short}</p>
                  <p class="text-zinc-600 text-sm leading-relaxed mt-1">{item.desc}</p>
                </div>
              </li>
            ))
          }
        </ol>
        <p class="mt-5 text-sm text-zinc-500 text-center max-w-2xl mx-auto">
          The standalone apps connect straight to your Tradovate or Ironbeam account &mdash; no NinjaTrader &mdash; so
          the top two tiers go where an in-platform add-on can't: a full-screen <strong class="text-zinc-700"
            >Cool-down Wall</strong
          > and a Windows-firewall <strong class="text-zinc-700">Cut</strong>. There is no broker Disconnect tier here.
        </p>
      </div>
    </div>

    <!-- L3 spotlight (applies to both) -->
    <div class="max-w-3xl mx-auto mt-10 rounded-2xl calloutd text-zinc-100 px-7 py-8 md:px-10" data-reveal>
      <p class="text-[11px] font-bold tracking-[0.2em] text-emerald-400 uppercase mb-4">
        The most underrated level &mdash; Acknowledge
      </p>
      <blockquote class="text-xl md:text-2xl font-semibold text-white leading-[1.4]">
        "I will not revenge trade. My plan is my edge."
      </blockquote>
      <p class="mt-5 text-zinc-400 leading-relaxed">
        You write that phrase yourself, when you're calm, before the session. In the moment, Guard makes you type it
        back &mdash; word for word, against a countdown &mdash; before it lets you continue. Your own words, at the
        exact second you need them most. Often that's all it takes to break the loop.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── ENFORCEMENT SPINE — WHAT ACTUALLY HOLDS ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-zinc-950 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="text-center mb-12" data-reveal>
        <p class="eyebrow text-[11px] font-bold text-emerald-400 mb-3">THE HONEST PART &middot; WHAT ACTUALLY HOLDS</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-white">
          A lock is only as strong as where it lives.
        </h2>
        <p class="mt-5 text-lg text-zinc-400 max-w-3xl mx-auto">
          Every Guard action sits at one of three layers &mdash; and the layer is exactly what a determined, tilting
          trader can or can't get around. We'd rather you know this up front than find out at the worst moment.
        </p>
      </div>

      <div class="space-y-4 max-w-4xl mx-auto" data-reveal>
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <span class="text-sm font-bold text-white">In-app friction</span>
            <span class="text-[11px] font-semibold text-amber-400/90 bg-amber-400/10 px-2 py-0.5 rounded-full"
              >bypass: close the app &middot; another device</span
            >
          </div>
          <p class="text-sm text-zinc-400 leading-relaxed">
            Notify, Alert/Risk Alert, Acknowledge, Pause, Cool-down Wall, Strict Lock and Hard limits all live in the
            app. They put hard, deliberate friction between you and a tilt trade &mdash; the kind your in-the-moment
            self won't push through. They don't pretend to stop someone who closes the app and trades from their phone.
          </p>
        </div>

        <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6">
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <span class="text-sm font-bold text-white">OS / machine</span>
            <span class="text-[11px] font-semibold text-amber-400/90 bg-amber-400/10 px-2 py-0.5 rounded-full"
              >bypass: another device &middot; admin</span
            >
          </div>
          <p class="text-sm text-zinc-400 leading-relaxed">
            <strong class="text-zinc-200">Cut</strong> (standalone) blocks your broker's order servers in the Windows firewall.
            It's machine-wide: an order physically cannot leave that PC &mdash; the one stop that holds even a market order
            <em>from that machine</em>. A phone or a second device is outside it.
          </p>
        </div>

        <div class="rounded-2xl border-2 border-emerald-500 bg-emerald-500/[0.07] p-6">
          <div class="flex flex-wrap items-center gap-3 mb-2">
            <span class="text-sm font-bold text-emerald-300">Broker-level &mdash; the one device-proof stop</span>
            <span class="text-[11px] font-bold text-emerald-300 bg-emerald-400/15 px-2 py-0.5 rounded-full"
              >holds across close &middot; reboot &middot; phone</span
            >
          </div>
          <p class="text-sm text-zinc-300 leading-relaxed">
            On <strong class="text-white">Tradovate demo and eval accounts</strong>, the standalone app writes
            Tradovate's
            <strong class="text-white"> own liquidate-only lock</strong> &mdash; enforcement at the broker, not in our app.
            That one holds even if you close the app, reboot, or log in from another device. It's the real answer to "can
            a tilting trader just keep going?" <span class="text-zinc-400"
              >(Funded/live Tradovate and Ironbeam don't expose this API; NinjaTrader has no broker-side lock &mdash;
              there, enforcement is app/connection-level only.)</span
            >
          </p>
        </div>
      </div>

      <p class="text-center mt-8 text-sm text-zinc-500 max-w-2xl mx-auto" data-reveal>
        So when we say <em>un-bypassable</em>, we mean exactly one thing: the broker-level lock. Everywhere else, Guard
        sells honest friction &mdash; the version of you that's tilting can't talk its way past it, and that's usually
        all it takes.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── HARD LIMITS ───────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div data-reveal>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">STANDING ENFORCEMENT &middot; HARD LIMITS</p>
        <h2 class="text-3xl md:text-[2.6rem] font-bold tracking-tight text-zinc-900 leading-[1.1]">
          A ceiling that's<br />always on.
        </h2>
        <p class="mt-5 text-lg text-zinc-600 leading-relaxed">
          The triggers above react to a session going wrong. Hard limits don't wait for anything &mdash; they're a
          standing cap you set once while calm. A <strong class="text-zinc-900">max-contracts ceiling</strong> and
