        <a href="/pricing" class="inline-block font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-8 py-4 rounded-xl text-lg transition">Compare all plans</a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">${usd(guardTier.monthlyPrice)}/mo after trial &middot; Cancel anytime &middot; NinjaTrader 8 required</p>
    </div>
  </section>

  <style>
    .guard-intel-view {
      opacity: 0;
      z-index: 0;
      transition: opacity 0.32s ease;
      pointer-events: none;
    }
    .guard-intel-view.is-active {
      opacity: 1;
      z-index: 1;
      pointer-events: auto;
    }
  </style>

  <script>
    function initGuardIntel() {
      const root = document.querySelector('[data-guard-intel]');
      if (!root || root.dataset.guardIntelInit === '1') return;
      root.dataset.guardIntelInit = '1';

      const tabs = Array.from(root.querySelectorAll('[data-guard-intel-tab]'));
      const views = Array.from(root.querySelectorAll('[data-guard-intel-view]'));
      const prevBtn = root.querySelector('[data-guard-intel-prev]');
      const nextBtn = root.querySelector('[data-guard-intel-next]');
      if (!tabs.length || !views.length) return;
      const panel = document.getElementById('guard-intel-panel');

      const activeCard = ['border-emerald-400', 'bg-white', 'shadow-sm', 'shadow-emerald-100'];
      const inactiveCard = ['border-zinc-200', 'bg-white/60'];

      let current = 0;

      function applyTabStyles(next) {
        tabs.forEach((tab, i) => {
          const on = i === next;
          tab.setAttribute('aria-selected', on ? 'true' : 'false');
          tab.tabIndex = on ? 0 : -1;
          tab.classList.remove(...activeCard, ...inactiveCard, 'hover:border-zinc-300', 'hover:bg-white');
          if (on) tab.classList.add(...activeCard);
          else tab.classList.add(...inactiveCard, 'hover:border-zinc-300', 'hover:bg-white');
        });
      }

      function goTo(index) {
        const n = views.length;
        const next = ((index % n) + n) % n;
        if (next === current) return;
        current = next;
        applyTabStyles(current);
        if (panel && tabs[current] && tabs[current].id) panel.setAttribute('aria-labelledby', tabs[current].id);
        views.forEach((view, i) => {
          const on = i === current;
          view.classList.toggle('is-active', on);
          view.setAttribute('aria-hidden', on ? 'false' : 'true');
        });
      }

      tabs.forEach((tab, i) => {
        tab.addEventListener('click', () => {
          goTo(i);
          tab.focus();
        });
        tab.addEventListener('keydown', (e) => {
          let target = null;
          if (e.key === 'ArrowDown' || e.key === 'ArrowRight') target = (i + 1) % tabs.length;
          else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') target = (i - 1 + tabs.length) % tabs.length;
          else if (e.key === 'Home') target = 0;
          else if (e.key === 'End') target = tabs.length - 1;
          if (target === null) return;
          e.preventDefault();
          goTo(target);
          tabs[target].focus();
        });
      });
      prevBtn?.addEventListener('click', () => goTo(current - 1));
      nextBtn?.addEventListener('click', () => goTo(current + 1));
    }

    function bootGuardIntel() {
      initGuardIntel();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootGuardIntel);
    } else {
      bootGuardIntel();
    }
    if (!(window).hasOwnProperty('__meridianGuardIntelSwap')) {
      (window).__meridianGuardIntelSwap = true;
      document.addEventListener('astro:after-swap', bootGuardIntel);
    }
  </script>

</Layout>
