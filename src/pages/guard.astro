        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Guard is Core, plus enforcement.</h2>
        <p class="mt-4 text-lg text-zinc-600">Everything the monitor does &mdash; and the layer that acts on it.</p>
      </div>
      <div class="rounded-2xl border border-zinc-200 overflow-hidden shadow-sm" data-reveal>
        <div class="grid grid-cols-3 text-sm font-semibold bg-zinc-900 text-white">
          <div class="px-5 py-4 text-zinc-400"></div>
          <div class="px-5 py-4 border-l border-zinc-700/60">
            Meridian Core<br />
            <span class="font-normal text-zinc-400 text-xs tnum">${usd(coreTier.monthlyPrice)}/mo</span>
          </div>
          <div class="px-5 py-4 border-l border-zinc-700/60 text-emerald-400">
            Meridian Guard<br />
            <span class="font-normal text-emerald-400 text-xs tnum">${usd(guardTier.monthlyPrice)}/mo</span>
          </div>
        </div>
        {[
          ['Real-time PSI score',                         true,  true],
          ['7 behavioral signal bars',                    true,  true],
          ['Personal baselines',                          true,  true],
          ['Session history (5 years)',                   true,  true],
          ['Local-first; anonymized opt-out telemetry',   true,  true],
          ['Guard System (6 triggers, 5-level ladder)',   false, true],
          ['Trading Pause & broker Disconnect',           false, true],
          ['Strict Lock — makes every pause un-bypassable',false, true],
          ['Intel Layer — monthly digest',               false, true],
          ['PSI × P&L correlation',                       false, true],
          ["Today's Risk Brief",                          false, true],
          ['Stats & breakdowns (custom date ranges)',     false, true],
        ].map(([feature, core, guard], i) => (
          <div class="grid grid-cols-3 border-t border-zinc-100 text-sm" style={i % 2 === 1 ? 'background:#fafafa;' : ''}>
            <div class="px-5 py-3.5 text-zinc-700">{feature}</div>
            <div class="px-5 py-3.5 border-l border-zinc-100">
              {core
                ? <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                : <span class="text-zinc-300 text-base leading-none">&mdash;</span>}
            </div>
            <div class="px-5 py-3.5 border-l border-zinc-100">
              {guard
                ? <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                : <span class="text-zinc-300 text-base leading-none">&mdash;</span>}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── FINAL CTA ───────────────────────── -->
  <section class="halo">
    <div class="max-w-3xl mx-auto px-6 py-28 text-center" data-reveal>
      <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-[1.05]">Set the rules once.<br />Let them hold the line.</h2>
