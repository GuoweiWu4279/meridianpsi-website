---
import Layout from '~/layouts/PageLayout.astro';
import pricing from '~/data/pricing.json';
import geoHooks from '~/data/geo-hooks.json';
import guardData from '~/data/guard.json';

const coreTier = pricing.tiers[0]!;
const guardTier = pricing.tiers[1]!;
const usd = (n: number) => n.toFixed(2);

const metadata = {
  // Brand already leads the title — suppress the site-wide "— Meridian" suffix.
  title: 'Meridian Guard — NinjaTrader 8 Behavioral Risk Manager & Trade Lockout',
  ignoreTitleTemplate: true,
  description:
    `${geoHooks.meridianGuardHook} You write the rules when calm; Guard enforces them when you are not — six triggers, a five-level escalation ladder, and an un-bypassable Strict Lock. After a 7-day free trial: $${usd(guardTier.monthlyPrice)}/mo or $${usd(guardTier.annualPrice)}/yr. Trading involves substantial risk.`,
  robots: { index: true, follow: true },
};

const guardCheckout = guardTier.monthlyCtaHref ?? 'https://whop.com/checkout/plan_ZHX4ySB65fahf';

const guardOffers = [
  {
    '@type': 'Offer',
    name: 'Meridian Guard — monthly (after trial)',
    price: usd(guardTier.monthlyPrice),
    priceCurrency: guardTier.currency,
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: usd(guardTier.monthlyPrice),
      priceCurrency: guardTier.currency,
      billingDuration: 'P1M',
    },
  },
  {
    '@type': 'Offer',
    name: 'Meridian Guard — annual (after trial)',
    price: usd(guardTier.annualPrice),
    priceCurrency: guardTier.currency,
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: usd(guardTier.annualPrice),
      priceCurrency: guardTier.currency,
      billingDuration: 'P1Y',
    },
  },
];

const guardSchemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Meridian Guard",
  "applicationCategory": "BusinessApplication",
  "applicationSubCategory": "Trading Risk Management",
  "operatingSystem": "Windows 10 or later",
  "description": geoHooks.schemaSoftwareGuard,
  "keywords": geoHooks.geoSearchAssociate,
  "url": "https://www.meridianpsi.com/guard",
  "featureList": [
    "Six trigger conditions: PSI Below, Consecutive Losses, Session P&L Below, Unrealized P&L Below, Single Trade Loss, Session Time Over",
    "Five response levels: Notify (L1), Risk Alert (L2), Acknowledge (L3), Trading Pause (L4), Disconnect (L5)",
    "Trading Pause (L4): blocks new entries by cancelling orders while staying connected; Disconnect (L5): severs the broker connection",
    "Auto-flatten (opt-in, off by default): on a Trading Pause (L4) or Disconnect (L5) rule, optionally close all open positions the moment that rule fires",
    "Strict Lock: one switch set while calm — every pause or disconnect Guard fires becomes un-bypassable for its full window, rules frozen; survives NinjaTrader restart",
    "Pause persistence: lockout survives NinjaTrader restart or crash",
    "Intel Layer: monthly behavioral digest, weekday patterns, PSI × P&L correlation",
    "Anonymous by design — no name, credentials, or funds collected"
  ],
  "offers": guardOffers,
  "softwareVersion": "1.5.0",
  "requirements": "NinjaTrader 8 (64-bit), Windows 10 or later, 4 GB RAM",
  "publisher": {
    "@type": "Organization",
    "name": "Meridian",
    "url": "https://www.meridianpsi.com"
  },
  "isPartOf": {
    "@type": "SoftwareApplication",
    "name": "Meridian",
    "url": "https://www.meridianpsi.com"
  }
});

/** Intel Layer — black 16:9 frame, image only (no in-frame captions). */
const intelSlides = [
  { img: '/screenshots/psi-performance.png', alt: 'PSI × Performance' },
  { img: '/screenshots/digest-march.png', alt: 'Monthly Digest' },
  { img: '/screenshots/intel-weekdaypattern.png', alt: 'Weekday Patterns' },
  { img: '/screenshots/intel-risk-brief.png', alt: "Today's Risk Brief" },
  { img: '/screenshots/intel-stats-showcase.png', alt: 'Stats — custom date ranges with win rate, profit factor, and breakdowns by time of day, hold time, instrument, and long/short' },
];

const { triggers, levels, examples } = guardData;
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={guardSchemaJson} />

  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="halo">
    <div class="max-w-5xl mx-auto px-6 pt-20 md:pt-24 pb-10 text-center" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-6">MERIDIAN GUARD &middot; THE ENFORCEMENT LAYER</p>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tight text-zinc-900 leading-[1.04]">
        Willpower is not<br />a risk strategy.
      </h1>
      <p class="mt-7 max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 leading-relaxed">
        You write the rules when you're calm. Guard enforces them when you're not &mdash; escalating exactly as far as you
        decide, from a quiet nudge to a full broker disconnect. No decision required from the tilted version of you.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={guardCheckout} class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm">Start 7-day free trial</a>
        <a href="#ladder" class="font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3.5 rounded-xl transition">See how it enforces</a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">No charge until day 7 &middot; ${usd(guardTier.monthlyPrice)}/mo after trial &middot; Cancel anytime</p>
    </div>
    <div class="max-w-5xl mx-auto px-6 pb-16 md:pb-20" data-reveal>
      <div class="win"><img src="/m/guard.png" alt="Meridian Guard configuration — your own rules with an escalating enforcement ladder and an un-bypassable Strict Lock" /></div>
    </div>
  </section>

  <!-- ───────────────────────── TRUST STRIP ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-wrap items-center justify-center gap-x-7 gap-y-2 text-[13px] text-zinc-500">
      <span class="inline-flex items-center gap-1.5 text-emerald-700 font-bold text-sm">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4" /><circle cx="12" cy="12" r="9" /></svg>
        Official NinjaTrader Ecosystem Vendor
      </span>
      <span class="text-zinc-300">|</span><span>Un-bypassable lockout that survives a restart</span>
    </div>
  </section>

  <!-- ───────────────────────── THE PREMISE / COMMITMENT DEVICE ───────────────────────── -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div class="text-center mb-12" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">WHY GUARD EXISTS</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">
        Two different people make<br />these two decisions.
      </h2>
      <p class="mt-5 text-lg text-zinc-600 max-w-2xl mx-auto">
        The trader who sets a daily loss limit at 8am is calm, rested, and rational. The trader who wants to override it at 11am &mdash; three losses deep &mdash; is not. Guard puts the calm one in charge of the day.
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto" data-reveal>
      <div class="rounded-2xl border border-zinc-200 bg-white p-7">
        <div class="text-sm font-semibold text-zinc-500 mb-4">You — at 8am, calm</div>
        <ul class="space-y-3 text-zinc-700">
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Pick the triggers that mean "I'm done for today"</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Choose how hard each one bites</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Optionally lock the settings shut</span></li>
        </ul>
        <p class="mt-5 text-sm text-zinc-500">This version of you writes the rules.</p>
      </div>
      <div class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-7">
        <div class="text-sm font-semibold text-emerald-700 mb-4">You — at 11am, tilted</div>
        <ul class="space-y-3 text-zinc-800">
          <li class="flex gap-3"><span class="text-zinc-400">&times;</span> Wants to "make it back" with one more trade</li>
          <li class="flex gap-3"><span class="text-zinc-400">&times;</span> Wants to widen the stop just this once</li>
          <li class="flex gap-3"><span class="text-zinc-400">&times;</span> Wants to switch the limits off</li>
        </ul>
        <p class="mt-5 text-sm text-emerald-700 font-medium">This version doesn't get a vote.</p>
      </div>
    </div>
    <div class="max-w-3xl mx-auto mt-8 rounded-2xl calloutd text-zinc-100 px-7 py-6 text-center">
      <p class="text-lg md:text-xl leading-relaxed">
        Behavioral economists call this a <span class="text-emerald-400 font-semibold">commitment device</span> &mdash; a mechanism you set up in advance to constrain your future self.<br class="hidden md:block" />
        Institutional desks have compliance systems that do it automatically. Guard is that, for you.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── STEP 1 — TRIGGERS ───────────────────────── -->
  <section id="ladder" class="border-y border-zinc-200 bg-white scroll-mt-20">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="text-center mb-12" data-reveal>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">STEP 1 &middot; THE 6 TRIGGERS</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Decide what "too far" means.</h2>
        <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">
          Six conditions Guard watches every session. Pick the ones that matter to you and set the numbers. Each fires once on entry, then resets &mdash; no nagging.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto" data-reveal>
        {triggers.map((item) => (
          <div class="rounded-xl border border-zinc-200 bg-[#fafafa] p-5">
            <div class="flex items-start gap-2.5">
              <svg class="w-4 h-4 mt-1 text-emerald-600 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <div>
                <div class="font-semibold text-zinc-900">{item.name}</div>
                <p class="mt-1 text-sm text-zinc-600 leading-relaxed">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
      <p class="text-center mt-6 text-sm text-zinc-500 max-w-2xl mx-auto">
        Five of these are the same hard numbers a traditional risk tool gives you &mdash; daily loss, single-trade loss, drawdown, loss streak, session length. The sixth, <span class="text-emerald-700 font-semibold">PSI Below</span>, fires on the behavior itself, before the money moves.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── STEP 2 — THE ESCALATION LADDER ───────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-12" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">STEP 2 &middot; THE 5-LEVEL LADDER</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Then decide how hard it bites.</h2>
      <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">
        The same trigger can be a whisper or a wall. You set the level. Severity climbs from a quiet toast to severing the broker connection &mdash; you choose exactly how far Guard goes.
      </p>
    </div>

    <!-- Severity bar -->
    <div class="max-w-5xl mx-auto" data-reveal>
      <div class="flex h-2 rounded-full overflow-hidden mb-3 gap-0.5">
        {levels.map((l) => (
          <div class="flex-1 rounded-full" style={`background:${l.color};`}></div>
        ))}
      </div>
      <div class="flex justify-between text-xs text-zinc-500 mb-8 px-0.5">
        <span>Softest &mdash; a nudge</span>
        <span>Hardest &mdash; broker disconnect</span>
      </div>

      <ol class="space-y-3">
        {levels.map((item) => (
          <li class="rounded-2xl border border-zinc-200 bg-white p-5 md:p-6 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5 shadow-sm">
            <div class="flex items-center gap-3 sm:w-56 shrink-0">
              <span class="text-[11px] font-bold tracking-widest px-2 py-1 rounded text-white tnum" style={`background:${item.color};`}>{item.level}</span>
              <span class="font-semibold text-zinc-900">{item.name}</span>
            </div>
            <p class="text-zinc-600 text-sm leading-relaxed">{item.desc}</p>
          </li>
        ))}
      </ol>
    </div>

    <!-- L3 spotlight -->
    <div class="max-w-3xl mx-auto mt-8 rounded-2xl calloutd text-zinc-100 px-7 py-8 md:px-10" data-reveal>
      <p class="text-[11px] font-bold tracking-[0.2em] text-emerald-400 uppercase mb-4">The most underrated level &mdash; L3, Acknowledge</p>
      <blockquote class="text-xl md:text-2xl font-semibold text-white leading-[1.4]">
        "I will not revenge trade. My plan is my edge."
      </blockquote>
      <p class="mt-5 text-zinc-400 leading-relaxed">
        You write that phrase yourself, when you're calm, before the session. In the moment, Guard makes you type it back &mdash; word for word, against a countdown &mdash; before the platform lets you continue. Your own words, at the exact second you need them most. Often that's all it takes to break the loop.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── HONESTY — GUARD NEVER CLOSES POSITIONS ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-4xl mx-auto px-6 py-24" data-reveal>
      <div class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-8 md:p-10">
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">WHAT GUARD WILL NOT DO</p>
        <h2 class="text-2xl md:text-4xl font-bold tracking-tight text-zinc-900 leading-[1.15]">
          Guard never closes your live<br class="hidden md:block" /> positions for you.
        </h2>
        <p class="mt-5 text-lg text-zinc-700 leading-relaxed">
          It only blocks you from <strong class="text-zinc-900">adding</strong> risk &mdash; new entries, more size. Your open trades stay yours: a close order is never cancelled, at any level. Even Disconnect, if you hold a position, first shows a countdown with a one-click <em>Flatten All</em> before it severs the connection &mdash; and your position itself lives at your broker, never locked away. Guard stops the next bad decision; it never makes a trading decision for you.
        </p>
        <p class="mt-4 text-sm text-zinc-600 leading-relaxed">
          The one exception is explicit and off by default: on a Trading Pause (L4) or Disconnect (L5) rule, you <em>may</em> tick a single checkbox &mdash; <em>Close all open positions immediately</em> &mdash; to auto-flatten the moment that rule fires. If you don't enable it, nothing closes &mdash; positions stay open and fully under your control.
        </p>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── STRICT LOCK ───────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-24 grid lg:grid-cols-2 gap-14 items-center">
    <div data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">STRICT LOCK</p>
      <h2 class="text-3xl md:text-[2.7rem] font-bold tracking-tight text-zinc-900 leading-[1.1]">
        A lock only your calm self<br />can set &mdash; and your tilted<br />self can't undo.
      </h2>
      <p class="mt-5 text-lg text-zinc-600 leading-relaxed">
        Any rule you can switch off in the moment isn't really a rule. Strict Lock is the fix: one switch, set <em>while you're calm</em>. With it on, every pause or disconnect Guard fires is absolute for its full window &mdash; no early exit, no force-reset, your rules are frozen, and neither Guard nor the switch itself can be turned off until the clock releases you.
      </p>
      <ul class="mt-6 space-y-3 text-zinc-700">
        <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Your rule decides how long &mdash; 15 minutes or the rest of the day &mdash; Strict Lock makes that window inescapable</span></li>
        <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span><strong class="text-zinc-900">It survives a NinjaTrader restart</strong> &mdash; closing the platform doesn't reset it</span></li>
        <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Built for the moment the tilted version of you goes looking for the off switch</span></li>
      </ul>
      <p class="mt-5 text-sm text-zinc-500">Lockout state persists across restarts and crashes &mdash; there's no "just reopen it" loophole.</p>
    </div>
    <div class="win" data-reveal><img src="/m/guard.png" alt="Meridian Guard — Strict Lock makes every Guard pause un-bypassable and survives a NinjaTrader restart" /></div>
  </section>

  <!-- ───────────────────────── EXAMPLE CONFIGS ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="text-center mb-12" data-reveal>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">PUT TOGETHER</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">A trigger, a level, a rule.</h2>
        <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">Pair any trigger with any level and you've written an enforceable rule. Here's how traders actually set Guard up.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-5xl mx-auto" data-reveal>
        {examples.map((item) => (
          <div class="rounded-xl border border-zinc-200 bg-[#fafafa] p-5">
            <p class="font-semibold text-zinc-900 text-sm mb-3">{item.name}</p>
            <div class="space-y-1.5">
              <p class="text-xs font-mono text-zinc-500">When: <span class="text-zinc-700">{item.rule}</span></p>
              <p class="text-xs font-mono font-medium text-emerald-700">Then: {item.action}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Utility features -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 mt-5 max-w-5xl mx-auto">
        {guardData.utility.map((item) => (
          <div class="rounded-xl border border-dashed border-zinc-300 bg-white p-4">
            <p class="font-semibold text-zinc-900 text-sm mb-1">{item.name}</p>
            <p class="text-zinc-500 text-xs leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── INTEL LAYER ───────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="max-w-2xl mb-12" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">GUARD EXCLUSIVE &middot; INTEL LAYER</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">
        Your session history,<br />turned into decisions.
      </h2>
      <p class="mt-4 text-lg text-zinc-600 leading-relaxed">
        Guard keeps 5 years of session history locally and surfaces the patterns no single session reveals &mdash; so the rules you set tomorrow are sharper than the ones you set today.
      </p>
    </div>

    <div class="grid md:grid-cols-[2fr_3fr] gap-8 items-start" data-guard-intel>
      <!-- Left: tab nav cards -->
      <div class="flex flex-col gap-3" role="tablist" aria-label="Intel Layer views">
        {[
          { idx: 0, title: 'PSI × Performance',  desc: 'Your P&L mapped against PSI zone — see exactly what Stable sessions average versus Critical.' },
          { idx: 1, title: 'Monthly Digest',      desc: 'Composure trend, stable days, win rate, avg P&L, best and worst days — every month.' },
          { idx: 2, title: 'Weekday Patterns',    desc: 'Find your weakest trading day and track 6-month Composure progress.' },
          { idx: 3, title: "Today's Risk Brief",  desc: 'A pre-session summary built from your own history — personalized before your first trade.' },
          { idx: 4, title: 'Stats & Breakdowns',  desc: 'New in v1.5.0 — pick any date range and break your edge down by time of day, hold time, instrument, and long vs short.' },
        ].map((card) => (
          <button
            type="button"
            role="tab"
            data-guard-intel-tab
            data-guard-intel-idx={card.idx}
            id={`guard-intel-tab-${card.idx}`}
            aria-controls="guard-intel-panel"
            aria-selected={card.idx === 0 ? 'true' : 'false'}
            tabindex={card.idx === 0 ? 0 : -1}
            class:list={[
              'text-left rounded-xl p-4 border transition-all duration-200',
              card.idx === 0
                ? 'border-emerald-400 bg-white shadow-sm shadow-emerald-100'
                : 'border-zinc-200 bg-white/60 hover:border-zinc-300 hover:bg-white',
            ]}
          >
            <h3 class="font-semibold text-zinc-900 mb-1 text-sm">{card.title}</h3>
            <p class="text-zinc-600 text-xs leading-relaxed">{card.desc}</p>
          </button>
        ))}
      </div>

      <!-- Right: fixed 16:9 frame + stacked views -->
      <div class="relative group/guard-intel min-w-0">
        <div
          id="guard-intel-panel"
          class="guard-media-frame relative overflow-hidden rounded-xl shadow-sm ring-1 ring-zinc-900/[0.06] w-full"
          style="position: relative; isolation: isolate; z-index: 0; width: 100%; aspect-ratio: 16 / 9; min-height: 0; background: #1C1C1E;"
          role="tabpanel"
          aria-labelledby="guard-intel-tab-0"
        >
          {intelSlides.map((slide, i) => (
            <div
              class:list={['guard-intel-view', { 'is-active': i === 0 }]}
              data-guard-intel-view
              style="position: absolute; inset: 0; overflow: hidden;"
              aria-hidden={i === 0 ? 'false' : 'true'}
            >
              <img
                src={slide.img}
                alt={slide.alt}
                class="absolute inset-0 h-full w-full"
                style="object-fit: contain; object-position: center;"
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
              />
            </div>
          ))}

          <button
            type="button"
            data-guard-intel-prev
            class="absolute left-2.5 top-1/2 z-20 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-black/40 text-white opacity-0 backdrop-blur-sm transition-all hover:bg-black/70 focus-visible:opacity-100 group-hover/guard-intel:opacity-100"
            aria-label="Previous Intel view"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
            </svg>
          </button>
          <button
            type="button"
            data-guard-intel-next
            class="absolute right-2.5 top-1/2 z-20 flex h-9 w-9 -translate-y-1/2 items-center justify-center rounded-full bg-black/40 text-white opacity-0 backdrop-blur-sm transition-all hover:bg-black/70 focus-visible:opacity-100 group-hover/guard-intel:opacity-100"
            aria-label="Next Intel view"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 1 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── COMPARISON: CORE vs GUARD ───────────────────────── -->
  <section id="comparison" class="border-y border-zinc-200 bg-white">
