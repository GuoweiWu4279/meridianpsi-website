---
import Layout from '~/layouts/PageLayout.astro';
import EcosystemVendorBadge from '~/components/widgets/EcosystemVendorBadge.astro';

import pricing from '~/data/pricing.json';
import geoHooks from '~/data/geo-hooks.json';

const { tiers, footnote } = pricing;
const [core, guard] = tiers;

// Disambiguate the Guard tier's "Everything in Meridian" line on the card:
// "Meridian" is the brand, "Meridian Core" is the tier the user sees in the other column.
const guardFeatures = guard.features.map((f) =>
  f === 'Everything in Meridian' ? `Everything in ${core.name}` : f
);

const usd = (n: number) => n.toFixed(2);

// SEO description — sharpened toward the superset positioning, kept price- and keyword-rich.
const pricingPageDescription = `Meridian is the complete risk manager for serious futures traders — every limit a traditional risk tool has, plus real-time behavioral detection. Native in NinjaTrader 8; Tradovate & Ironbeam apps in early access, one license. Core: $${usd(core.monthlyPrice)}/mo or $${usd(core.annualPrice)}/yr. Guard: $${usd(guard.monthlyPrice)}/mo or $${usd(guard.annualPrice)}/yr. 7-day free trial, cancel anytime. Trading involves substantial risk.`;

const metadata = {
  title: 'Pricing — Meridian Risk Management for Futures Traders',
  ignoreTitleTemplate: true,
  description: pricingPageDescription,
};

function tierToPricingPageOffers(tier: (typeof tiers)[number]) {
  const monthly = usd(tier.monthlyPrice);
  const annual = usd(tier.annualPrice);
  return [
    {
      '@type': 'Offer',
      name: `${tier.name} — monthly (after trial)`,
      price: monthly,
      priceCurrency: tier.currency,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: monthly,
        priceCurrency: tier.currency,
        billingDuration: 'P1M',
      },
    },
    {
      '@type': 'Offer',
      name: `${tier.name} — annual (after trial)`,
      price: annual,
      priceCurrency: tier.currency,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: annual,
        priceCurrency: tier.currency,
        billingDuration: 'P1Y',
      },
    },
  ];
}

const pricingPageJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      name: 'Pricing — Meridian',
      url: 'https://www.meridianpsi.com/pricing',
      description: pricingPageDescription,
    },
    {
      '@type': 'SoftwareApplication',
      name: core.name,
      url: 'https://www.meridianpsi.com/pricing',
      applicationCategory: 'FinanceApplication',
      operatingSystem: 'Windows',
      keywords: geoHooks.faqMetaExtra,
      offers: tierToPricingPageOffers(core),
    },
    {
      '@type': 'SoftwareApplication',
      name: guard.name,
      url: 'https://www.meridianpsi.com/pricing',
      applicationCategory: 'FinanceApplication',
      operatingSystem: 'Windows',
      keywords: geoHooks.faqMetaExtra,
      offers: tierToPricingPageOffers(guard),
    },
  ],
}).replace(/</g, '\\u003c');

// Objection-handling FAQ — kept short and concrete at the wallet moment.
const faqs = [
  {
    q: 'When am I charged?',
    a: 'Not for seven days. The trial gives you full access from day one, and your card is not charged until day 7. Cancel any time before then and you pay nothing — no partial charge, no fine print.',
  },
  {
    q: 'Can I cancel anytime?',
    a: 'Yes. Cancel during the trial and you are never charged. Cancel an active subscription whenever you like and you keep access through the end of the period you have already paid for. Manage it yourself from the Account page (top right of this site) using your checkout email.',
  },
  {
    q: 'Core or Guard — which do I need?',
    a: 'Core is the full real-time monitor plus analytics: the live PSI score, all seven behavioral signals, 5-year session history, and the complete Intel workspace (monthly digest, PSI × P&L correlation, weekday patterns, breakdowns, and a pre-session Risk Brief). Guard adds the enforcement layer on top — rules that enforce themselves (6 triggers · 5 action levels) and Strict Lock. If you want the tool to step in when you are tilting, choose Guard: it blocks you from adding risk (you can always exit) and never closes positions for you unless you turn that on. You can switch tiers any time.',
  },
  {
    q: 'Do I need NinjaTrader 8?',
    a: 'Not necessarily. Meridian runs today as a native NinjaTrader 8 add-on — inside the platform, no separate login account. Standalone Meridian apps that connect directly to Tradovate and Ironbeam accounts are in early access; if you trade through one of those, download the app from the Platforms page and skip NinjaTrader entirely — same 7-day free trial.',
  },
  {
    q: 'Do I pay more for Tradovate or Ironbeam?',
    a: 'No. One subscription covers every platform we support. NinjaTrader 8 is available now; the Tradovate and Ironbeam apps are in early access and included in the same license as they roll out.',
  },
  {
    q: 'Monthly or annual?',
    a: `Same product, same features. Annual is billed once a year at a lower effective monthly rate — about $${core.annualSavings}/yr less on Core and about $${guard.annualSavings}/yr less on Guard. Both include the 7-day free trial. Use the toggle above to compare.`,
  },
  {
    q: 'Does Meridian place trades for me?',
    a: 'No. Meridian never opens a position and never provides signals. The only orders it ever touches are the ones its Guard rules act on — cancelling a new entry or flattening a position — and only under rules you configured in advance. Exits and protective stops are never blocked.',
  },
  {
    q: 'Can I override a lock mid-session?',
    a: 'Standard Guard responses are configurable — you choose how firm each trigger is, from a quiet alert to a typed acknowledgment to an entry block. Strict Lock is the exception by design: once armed for a window, it cannot be bypassed mid-session. That is the entire point — you set it when you are calm, for the moment the tilted version of you wants to switch it off.',
  },
  {
    q: 'Does Meridian see my account credentials or funds?',
    a: 'The NinjaTrader 8 add-on reads execution data inside the platform — your broker credentials never touch Meridian. The standalone early-access apps sign in to your own account locally on your PC; credentials are used to open your session and are never transmitted to us. Meridian never holds, moves, or has any access to funds.',
  },
];
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={pricingPageJsonLd} />

  <!-- ───────────────────────── HERO / RISK REVERSAL ───────────────────────── -->
  <section class="halo">
    <div data-reveal class="max-w-3xl mx-auto px-6 pt-20 md:pt-24 pb-10 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-4">PRICING</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-[1.06]">
        Try it free for 7 days.<br />No charge until day 7.
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-lg text-zinc-600 leading-relaxed">
        Full access from day one — the live monitor and every behavioral signal, running on your own sessions. Decide
        with a week of your real data in hand. Cancel any time before the trial ends and you pay nothing.
      </p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-zinc-500">
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          7-day free trial
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          No charge until day 7
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Cancel anytime
        </span>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── PLANS ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div data-reveal class="max-w-5xl mx-auto px-6 py-24">

      <!-- Billing toggle -->
      <div class="flex items-center justify-center mb-12">
        <div class="relative flex items-center bg-zinc-100 rounded-full p-1 gap-1">
          <button id="btn-monthly" class="relative z-10 px-5 py-2 text-sm font-semibold rounded-full transition-all duration-200 bg-white text-zinc-900 shadow-sm">
            Monthly
          </button>
          <button id="btn-annual" class="relative z-10 px-5 py-2 text-sm font-semibold rounded-full transition-all duration-200 text-zinc-500">
            Annual
            <span class="ml-2 inline-block rounded-full bg-emerald-100 text-emerald-700 text-xs font-semibold px-2 py-0.5">Save up to ${guard.annualSavings}/yr</span>
          </button>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-6 items-start max-w-4xl mx-auto">

        <!-- Meridian Core -->
        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-8">
          <div class="mb-5">
            <h2 class="text-xl font-bold text-zinc-900">{core.name}</h2>
            <p class="mt-1 text-sm text-zinc-600">{core.description}</p>
          </div>

          <div class="mb-6 min-h-[88px]">
            <div id="core-monthly-price" class="flex items-baseline gap-1.5">
              <span class="text-5xl font-extrabold text-zinc-900 tnum">${core.monthlyPrice}</span>
              <span class="text-zinc-500 text-sm">/month</span>
            </div>
            <div id="core-annual-price" class="hidden items-baseline gap-1.5">
              <span class="text-5xl font-extrabold text-zinc-900 tnum">${core.annualMonthly}</span>
              <span class="text-zinc-500 text-sm">/month</span>
            </div>
            <p id="core-monthly-note" class="text-xs text-zinc-500 mt-2">Billed monthly · 7-day free trial</p>
            <p id="core-annual-note" class="text-xs text-zinc-500 mt-2 hidden">
              Billed <span class="tnum">${core.annualPrice}</span>/year · saves ~<span class="tnum">${core.annualSavings}</span>/yr · 7-day free trial
            </p>
          </div>

          <a
            id="core-cta"
            href={core.monthlyCtaHref}
            target="_blank"
            rel="noopener"
            class="block w-full text-center font-semibold text-zinc-900 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3.5 rounded-xl transition mb-7"
          >
            Start free trial
          </a>

          <ul class="space-y-3">
            {core.features.map((f) => (
              <li class="flex items-start gap-2.5 text-sm text-zinc-700">
                <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>

        <!-- Meridian Guard (recommended) -->
        <div class="rounded-2xl border-2 border-emerald-500 bg-white p-8 relative shadow-sm">
          <div class="absolute -top-3 left-8 text-[11px] font-bold text-white bg-emerald-600 px-2.5 py-1 rounded-full tracking-wide">RECOMMENDED</div>
          <div class="mb-5">
            <h2 class="text-xl font-bold text-zinc-900">{guard.name}</h2>
            <p class="mt-1 text-sm text-zinc-600">{guard.description}</p>
          </div>

          <div class="mb-6 min-h-[88px]">
            <div id="guard-monthly-price" class="flex items-baseline gap-1.5">
              <span class="text-5xl font-extrabold text-zinc-900 tnum">${guard.monthlyPrice}</span>
              <span class="text-zinc-500 text-sm">/month</span>
            </div>
            <div id="guard-annual-price" class="hidden items-baseline gap-1.5">
              <span class="text-5xl font-extrabold text-zinc-900 tnum">${guard.annualMonthly}</span>
              <span class="text-zinc-500 text-sm">/month</span>
            </div>
            <p id="guard-monthly-note" class="text-xs text-zinc-500 mt-2">Billed monthly · 7-day free trial</p>
            <p id="guard-annual-note" class="text-xs text-zinc-500 mt-2 hidden">
              Billed <span class="tnum">${guard.annualPrice}</span>/year · saves ~<span class="tnum">${guard.annualSavings}</span>/yr · 7-day free trial
            </p>
          </div>

          <a
            id="guard-cta"
            href={guard.monthlyCtaHref}
            target="_blank"
            rel="noopener"
            class="block w-full text-center font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm mb-7"
          >
            Start free trial
          </a>

          <ul class="space-y-3">
            {guardFeatures.map((f) => (
              <li class="flex items-start gap-2.5 text-sm text-zinc-700">
                <svg class="w-4 h-4 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                {f}
              </li>
            ))}
          </ul>
        </div>

      </div>

      <!-- Trust strip -->
      <div class="mt-10 flex flex-wrap items-center justify-center gap-x-7 gap-y-2 text-xs text-zinc-500 max-w-3xl mx-auto">
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Checkout secured by Whop
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Native NT8 add-on &middot; Tradovate &amp; Ironbeam apps in early access
        </span>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Anonymized, opt-out telemetry — never your name, broker credentials, account numbers, or funds
        </span>
      </div>

      <div class="mt-6 flex justify-center">
        <EcosystemVendorBadge variant="compact" />
      </div>
    </div>
  </section>

  <!-- ───────────────────────── WHAT YOU'RE BUYING (superset) ───────────────────────── -->
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div data-reveal class="text-center mb-12">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">WHAT EVERY PLAN INCLUDES</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">More than a risk tool. The complete one.</h2>
      <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto leading-relaxed">
        Both plans do everything a traditional NinjaTrader 8 risk tool does — daily loss limits, P&amp;L and drawdown
        caps, loss-streak cutoffs. Then they add the layer none of them have: real-time behavioral detection that catches
        the mistake before the order, not after the loss.
      </p>
    </div>
    <div data-reveal class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto">
      <div class="rounded-2xl border border-zinc-200 bg-white p-7">
        <div class="text-sm font-semibold text-zinc-500 mb-4">What every risk tool does</div>
        <ul class="space-y-3 text-zinc-700">
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>Daily loss limit</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>Single-trade loss cap</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>P&amp;L / drawdown caps</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>Loss-streak cutoff</span></li>
        </ul>
        <p class="mt-5 text-sm text-zinc-500">Included in both plans.</p>
      </div>
      <div class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-7">
        <div class="text-sm font-semibold text-emerald-700 mb-4">What only Meridian adds</div>
        <ul class="space-y-3 text-zinc-800">
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Real-time <strong>behavior</strong> detection — 7 signals (revenge, oversizing, tilt&hellip;)</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>A baseline that learns how <em>you</em> trade — not a generic average</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>It steps in <em>before</em> the order, not after the loss</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>The whole loop: monitor · guard · journal · review</span></li>
        </ul>
        <p class="mt-5 text-sm text-emerald-700 font-medium">Guard adds the enforcement layer on top.</p>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── RISK REVERSAL / REFUND ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <div data-reveal class="text-center mb-12">
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">THE RISK IS OURS</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Try it on your own sessions, then decide.</h2>
        <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto leading-relaxed">
          You should not have to pay to find out whether a tool works for you. So you don't.
        </p>
      </div>
      <div data-reveal class="grid md:grid-cols-3 gap-5 max-w-4xl mx-auto">
        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-7">
          <div class="font-semibold text-zinc-900 mb-2">7 days, on the house</div>
          <p class="text-sm text-zinc-600 leading-relaxed">Full access from day one. Your card is not charged until day 7 — cancel before then and you pay nothing at all.</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-7">
          <div class="font-semibold text-zinc-900 mb-2">Cancel in two clicks</div>
          <p class="text-sm text-zinc-600 leading-relaxed">Manage your plan yourself through Whop, any time. Cancel and you keep access through the period you have already paid for.</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-7">
          <div class="font-semibold text-zinc-900 mb-2">An honest refund</div>
          <p class="text-sm text-zinc-600 leading-relaxed">If Meridian won't run on a supported NinjaTrader 8 setup and we can't fix it, we refund you in full. Email <a href="mailto:contactmeridianpsi@gmail.com" class="underline text-emerald-800 hover:text-emerald-900">contactmeridianpsi@gmail.com</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── FAQ ───────────────────────── -->
  <section class="max-w-3xl mx-auto px-6 py-24">
    <div data-reveal class="text-center mb-12">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">BEFORE YOU CHECK OUT</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Straight answers.</h2>
    </div>
    <div data-reveal class="space-y-4">
      {faqs.map((item) => (
        <div class="rounded-2xl border border-zinc-200 bg-white p-7">
          <h3 class="font-semibold text-zinc-900">{item.q}</h3>
          <p class="mt-2 text-zinc-600 leading-relaxed">{item.a}</p>
        </div>
      ))}
    </div>

    <!-- Billing terms (verbatim footnote) -->
    <p class="mt-12 text-center text-xs text-zinc-500 leading-relaxed max-w-2xl mx-auto">
      {footnote}
      <a href="/disclaimer" class="underline text-emerald-800 hover:text-emerald-900"> Risk disclaimer</a>.
    </p>
  </section>

  <!-- ───────────────────────── FINAL CTA ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div data-reveal class="max-w-3xl mx-auto px-6 py-24 text-center">
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 leading-[1.08]">Start the trial. Let your own data decide.</h2>
      <p class="mt-5 text-lg text-zinc-600">Guard ${guard.monthlyPrice}/mo &middot; Core ${core.monthlyPrice}/mo &middot; No charge until day 7. Cancel anytime.</p>
      <p class="mt-3 text-sm text-zinc-500">Do the math: a single evaluation reset runs $100+, and one tilted session usually costs more than a month of Guard.</p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={guard.monthlyCtaHref} target="_blank" rel="noopener" class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-8 py-4 rounded-xl text-lg transition shadow-sm">Start Guard free trial</a>
        <a href="/download#requirements" class="font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-8 py-4 rounded-xl text-lg transition">System requirements</a>
      </div>
      <p class="mt-5 text-xs text-zinc-500 max-w-xl mx-auto leading-relaxed">
        Native in NinjaTrader 8 today &middot; Tradovate &amp; Ironbeam apps in early access. Trading involves substantial risk of loss. Meridian does not provide trading signals or investment advice.
      </p>
    </div>
  </section>
</Layout>

<script>
  // Astro View Transitions (ClientRouter) replaces the DOM on SPA navigation,
  // so listeners must be re-attached on `astro:page-load` (fires for both
  // initial load and every subsequent client-side navigation).
  function initPricingToggle() {
    const btnMonthly = document.getElementById('btn-monthly') as HTMLButtonElement | null;
    const btnAnnual  = document.getElementById('btn-annual')  as HTMLButtonElement | null;
    if (!btnMonthly || !btnAnnual) return;

    const coreMonthlyPrice = document.getElementById('core-monthly-price');
    const coreAnnualPrice  = document.getElementById('core-annual-price');
    const coreMonthlyNote  = document.getElementById('core-monthly-note');
    const coreAnnualNote   = document.getElementById('core-annual-note');
    const coreCta          = document.getElementById('core-cta') as HTMLAnchorElement | null;

    const guardMonthlyPrice = document.getElementById('guard-monthly-price');
    const guardAnnualPrice  = document.getElementById('guard-annual-price');
    const guardMonthlyNote  = document.getElementById('guard-monthly-note');
    const guardAnnualNote   = document.getElementById('guard-annual-note');
    const guardCta          = document.getElementById('guard-cta') as HTMLAnchorElement | null;

    // Canonical Whop checkout links (mirror src/data/pricing.json).
    const CORE_MONTHLY_URL  = 'https://whop.com/checkout/plan_4Z0XZqQl7TaDH';
    const CORE_ANNUAL_URL   = 'https://whop.com/checkout/plan_JhWetoQ39OCNz';
    const GUARD_MONTHLY_URL = 'https://whop.com/checkout/plan_ZHX4ySB65fahf';
    const GUARD_ANNUAL_URL  = 'https://whop.com/checkout/plan_frPOgHtDTvBkR';

    function setMonthly() {
      btnMonthly!.classList.add('bg-white', 'text-zinc-900', 'shadow-sm');
      btnMonthly!.classList.remove('text-zinc-500');
      btnAnnual!.classList.remove('bg-white', 'text-zinc-900', 'shadow-sm');
      btnAnnual!.classList.add('text-zinc-500');

      coreMonthlyPrice?.classList.remove('hidden');
      coreMonthlyPrice?.classList.add('flex');
      coreAnnualPrice?.classList.add('hidden');
      coreAnnualPrice?.classList.remove('flex');
      coreMonthlyNote?.classList.remove('hidden');
      coreAnnualNote?.classList.add('hidden');
      if (coreCta) coreCta.href = CORE_MONTHLY_URL;

      guardMonthlyPrice?.classList.remove('hidden');
      guardMonthlyPrice?.classList.add('flex');
      guardAnnualPrice?.classList.add('hidden');
      guardAnnualPrice?.classList.remove('flex');
      guardMonthlyNote?.classList.remove('hidden');
      guardAnnualNote?.classList.add('hidden');
      if (guardCta) guardCta.href = GUARD_MONTHLY_URL;
    }

    function setAnnual() {
      btnAnnual!.classList.add('bg-white', 'text-zinc-900', 'shadow-sm');
      btnAnnual!.classList.remove('text-zinc-500');
      btnMonthly!.classList.remove('bg-white', 'text-zinc-900', 'shadow-sm');
      btnMonthly!.classList.add('text-zinc-500');

      coreMonthlyPrice?.classList.add('hidden');
      coreMonthlyPrice?.classList.remove('flex');
      coreAnnualPrice?.classList.remove('hidden');
      coreAnnualPrice?.classList.add('flex');
      coreMonthlyNote?.classList.add('hidden');
      coreAnnualNote?.classList.remove('hidden');
      if (coreCta) coreCta.href = CORE_ANNUAL_URL;

      guardMonthlyPrice?.classList.add('hidden');
      guardMonthlyPrice?.classList.remove('flex');
      guardAnnualPrice?.classList.remove('hidden');
      guardAnnualPrice?.classList.add('flex');
      guardMonthlyNote?.classList.add('hidden');
      guardAnnualNote?.classList.remove('hidden');
      if (guardCta) guardCta.href = GUARD_ANNUAL_URL;
    }

    btnMonthly.addEventListener('click', setMonthly);
    btnAnnual.addEventListener('click', setAnnual);
  }

  document.addEventListener('astro:page-load', initPricingToggle);
</script>
