---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import products from '~/data/products.json';

const metadata = {
  // "Meridian" comes from the site-wide title template — don't repeat it here.
  title: 'Download — Latest Builds & Release Notes',
  description:
    'Download Meridian for NinjaTrader 8, read system requirements, and see release notes for every version. Standalone Tradovate and Ironbeam apps are in early access.',
};

const allEntries = await getCollection('changelog');
const entries = allEntries.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
const latest = entries.find((e) => e.data.isLatest) ?? entries[0];
const older = entries.filter((e) => e.id !== latest?.id);

const req = products.systemRequirements;

const typeBadge: Record<string, string> = {
  major: 'bg-emerald-100 text-emerald-800',
  minor: 'bg-zinc-100 text-zinc-700',
  patch: 'bg-green-100 text-green-800',
  hotfix: 'bg-red-100 text-red-800',
};

const { Content: LatestContent } = await render(latest);
---

<Layout metadata={metadata}>
  <HeroText
    title="Download"
    subtitle={`NinjaTrader 8 add-on, v${latest?.data.version} — tick the disclaimer and the .zip is yours.`}
  />

  <!-- Primary action: download box first, everything else below.
       The button used to sit BELOW the full release notes — Clarity replays
       showed a real visitor spending 41s hunting for it. Never bury it again. -->
  {latest && (
    <section id={`v${latest.data.version}`} class="max-w-4xl mx-auto px-6 mb-14">
      <div class="grid md:grid-cols-3 gap-4 items-start">
        <!-- Download card (NT8) -->
        <div class="md:col-span-2 rounded-2xl border-2 border-emerald-600/25 bg-gradient-to-b from-white to-emerald-50/20 p-6 shadow-md">
          <div class="flex flex-wrap items-center gap-2 mb-1.5">
            <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800">Latest</span>
            <span class={`px-2.5 py-0.5 rounded-full text-xs font-semibold capitalize ${typeBadge[latest.data.type]}`}>
              {latest.data.type}
            </span>
            <span class="text-xs text-zinc-400">
              {latest.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}
            </span>
          </div>
          <h2 class="text-xl font-bold text-zinc-900 mb-4">Meridian v{latest.data.version} — NinjaTrader 8 add-on</h2>

          <label class="flex items-start gap-3 cursor-pointer mb-4">
            <input
              type="checkbox"
              id="disclaimer-confirm"
              class="mt-0.5 w-4 h-4 rounded border-zinc-300 text-emerald-600 cursor-pointer shrink-0"
            />
            <span class="text-xs text-zinc-600 leading-relaxed">
              I have read the <a href="/disclaimer" class="text-emerald-800 underline font-medium">risk disclaimer</a>.
              I understand Meridian is a behavioral monitor only, does not provide trading advice, and that futures and
              forex trading involve substantial risk of loss. I consent to Meridian collecting anonymized trading and
              behavioral data to improve the product and for research, per the
              <a href="/data-research" class="text-emerald-800 underline font-medium">Data &amp; Research Notice</a>
              (no personally identifying information; opt out anytime).
            </span>
          </label>

          <div class="flex flex-wrap items-center gap-4">
            <a
              id="download-btn"
              href={latest.data.downloadUrl ?? '#'}
              class="inline-flex items-center gap-2 px-7 py-3 rounded-full bg-emerald-600 text-white font-semibold transition-all hover:bg-emerald-700 text-sm"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              Download v{latest.data.version} (.zip)
            </a>
            <span class="text-xs text-zinc-400">
              Need a license? <a href="/pricing" class="text-emerald-700 font-medium hover:underline">Start free trial</a>
            </span>
          </div>
          <p id="download-hint" class="mt-3 text-xs text-zinc-500">Tick the risk-disclaimer box above, then click Download.</p>
          <p class="mt-2 text-xs text-zinc-500">
            Your license key arrives by email from Whop at checkout — activate it in the <strong>License</strong> tab after install.
          </p>

          <details class="mt-5 pt-4 border-t border-zinc-200 group">
            <summary class="flex items-center gap-2 cursor-pointer list-none text-sm font-semibold text-zinc-700 hover:text-zinc-900">
              <svg class="w-4 h-4 text-zinc-400 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              What's new in v{latest.data.version} — {latest.data.title}
            </summary>
            <div class="prose prose-sm max-w-none prose-headings:font-semibold prose-headings:text-zinc-900 prose-headings:text-base prose-li:text-zinc-600 prose-p:text-zinc-600 mt-4">
              <LatestContent />
            </div>
          </details>
        </div>

        <!-- Standalone apps (early access) -->
        <div class="rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm">
          <h2 class="text-sm font-bold text-zinc-900 mb-1">Standalone app</h2>
          <p class="text-xs text-zinc-500 leading-relaxed mb-4">
            Trade through Tradovate or Ironbeam without NinjaTrader? The standalone Windows app is in early access —
            apply and we send you the signed installer.
          </p>
          <div class="space-y-2.5">
            <a href="/installation-guide#tradovate" class="flex items-center justify-between gap-2 rounded-xl border border-zinc-200 hover:border-emerald-300 bg-zinc-50/60 px-3.5 py-2.5 transition group">
              <span class="text-sm font-semibold text-zinc-900">Tradovate</span>
              <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wide bg-amber-100 text-amber-800">Early access</span>
            </a>
            <a href="/installation-guide#ironbeam" class="flex items-center justify-between gap-2 rounded-xl border border-zinc-200 hover:border-emerald-300 bg-zinc-50/60 px-3.5 py-2.5 transition group">
              <span class="text-sm font-semibold text-zinc-900">Ironbeam</span>
              <span class="px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wide bg-amber-100 text-amber-800">Early access</span>
            </a>
          </div>
          <p class="mt-4 text-xs text-zinc-500">One subscription activates every platform — you never pay twice.</p>
        </div>
      </div>
    </section>
  )}

  <!-- System requirements + Installation -->
  <section id="requirements" class="max-w-4xl mx-auto px-6 mb-14">
    <div class="grid md:grid-cols-2 gap-6">
      <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-4 text-zinc-900">System requirements (NinjaTrader 8 add-on)</h2>
        <ul class="space-y-2.5 text-sm text-zinc-600">
          <li class="flex gap-2">
            <span class="text-zinc-400 w-24 shrink-0">OS</span>
            <span class="font-medium text-zinc-900 text-right ml-auto">{req.os}</span>
          </li>
          <li class="flex gap-2">
            <span class="text-zinc-400 w-24 shrink-0">NinjaTrader</span>
            <span class="font-medium text-zinc-900 text-right ml-auto">{req.ninjaTrader}</span>
          </li>
          <li class="flex gap-2">
            <span class="text-zinc-400 w-24 shrink-0">RAM</span>
            <span class="font-medium text-zinc-900 text-right ml-auto">{req.ram}</span>
          </li>
          <li class="flex gap-2">
            <span class="text-zinc-400 w-24 shrink-0">Disk</span>
            <span class="font-medium text-zinc-900 text-right ml-auto">{req.disk}</span>
          </li>
        </ul>
        {req.note && <p class="mt-4 text-xs text-zinc-500 leading-relaxed">{req.note}</p>}
      </div>

      <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
        <h2 class="text-base font-semibold mb-1 text-zinc-900">Step-by-step install guides</h2>
        <p class="text-xs text-zinc-500 mb-4">Pick your version — each guide walks the whole setup, with screenshots.</p>
        <div class="space-y-3">
          <a href="/installation-guide#ninjatrader" class="flex items-center justify-between gap-3 rounded-xl border border-zinc-200 hover:border-emerald-300 bg-zinc-50/60 px-4 py-3 transition group">
            <span>
              <span class="block text-sm font-semibold text-zinc-900">NinjaTrader 8 add-on</span>
              <span class="block text-xs text-zinc-500">Import the .zip, activate, configure — ~10 min</span>
            </span>
            <span class="text-emerald-700 font-semibold text-sm group-hover:translate-x-0.5 transition-transform">&rarr;</span>
          </a>
          <a href="/installation-guide#tradovate" class="flex items-center justify-between gap-3 rounded-xl border border-zinc-200 hover:border-emerald-300 bg-zinc-50/60 px-4 py-3 transition group">
            <span>
              <span class="block text-sm font-semibold text-zinc-900">Standalone app — Tradovate &amp; Ironbeam</span>
              <span class="block text-xs text-zinc-500">Early access — request it and we send you the signed installer</span>
            </span>
            <span class="text-emerald-700 font-semibold text-sm group-hover:translate-x-0.5 transition-transform">&rarr;</span>
          </a>
        </div>
        <p class="mt-4 text-xs text-zinc-500">
          Stuck? Visit <a href="/support" class="underline text-zinc-600 hover:text-zinc-900">support</a> or read the <a href="/faq" class="underline text-zinc-600 hover:text-zinc-900">FAQ</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Older versions -->
  {older.length > 0 && (
    <section class="max-w-4xl mx-auto px-6 pb-24">
      <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-widest mb-4">Release notes — previous versions</h2>
      <div class="rounded-xl border border-zinc-200 bg-white overflow-hidden divide-y divide-zinc-100">
        {older.map(async (entry) => {
          const { Content: OldContent } = await render(entry);
          return (
            <details id={`v${entry.data.version}`} class="group">
              <summary class="flex items-center justify-between px-5 py-3.5 cursor-pointer hover:bg-zinc-50 transition-colors list-none">
                <div class="flex items-center gap-3">
                  <span class="font-semibold text-sm text-zinc-900">v{entry.data.version}</span>
                  <span class={`px-2 py-0.5 rounded-full text-xs font-medium capitalize ${typeBadge[entry.data.type]}`}>
                    {entry.data.type}
                  </span>
                  <span class="text-xs text-zinc-400">
                    {entry.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' })}
                  </span>
                </div>
                <svg class="w-4 h-4 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 pt-2">
                <div class="prose prose-sm max-w-none prose-headings:font-semibold prose-headings:text-zinc-800 prose-headings:text-sm prose-li:text-zinc-600 mb-4">
                  <OldContent />
                </div>
                {entry.data.downloadUrl && entry.data.downloadUrl !== '/download' && entry.data.downloadUrl !== '/releases' && (
                  <a
                    href={entry.data.downloadUrl}
                    class="inline-flex items-center gap-1.5 text-xs font-medium text-zinc-600 hover:text-zinc-900 border border-zinc-200 hover:border-zinc-400 rounded-lg px-3 py-1.5 transition-all"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                    Download v{entry.data.version}
                  </a>
                )}
              </div>
            </details>
          );
        })}
      </div>
    </section>
  )}
</Layout>

<script>
  // The download button is ALWAYS clickable (never greyed out). If the
  // risk-disclaimer box isn't ticked, the click is intercepted and the user is
  // nudged to the checkbox instead of silently doing nothing — that dead-button
  // state is what sent people wandering off to /pricing. Re-attaches on every
  // Astro client navigation (View Transitions).
  function initDownloadGate() {
    const checkbox = document.getElementById('disclaimer-confirm') as HTMLInputElement | null;
    const btn = document.getElementById('download-btn');
    const hint = document.getElementById('download-hint');
    if (!checkbox || !btn || (btn as HTMLElement).dataset.gateBound === '1') return;
    (btn as HTMLElement).dataset.gateBound = '1';

    btn.addEventListener('click', (e) => {
      if (!checkbox.checked) {
        e.preventDefault();
        if (hint) {
          hint.textContent = 'Please tick the box above to confirm you have read the risk disclaimer — then your download starts.';
          hint.classList.remove('text-zinc-500', 'text-emerald-700');
          hint.classList.add('text-rose-600', 'font-medium');
        }
        checkbox.classList.add('ring-2', 'ring-rose-400', 'ring-offset-1');
        checkbox.focus();
      }
    });

    checkbox.addEventListener('change', () => {
      if (!hint) return;
      if (checkbox.checked) {
        hint.textContent = 'Thanks — your download is ready. Click Download above.';
        hint.classList.remove('text-rose-600', 'font-medium', 'text-zinc-500');
        hint.classList.add('text-emerald-700');
        checkbox.classList.remove('ring-2', 'ring-rose-400', 'ring-offset-1');
      } else {
        hint.textContent = 'Tick the risk-disclaimer box above, then click Download.';
        hint.classList.remove('text-emerald-700', 'text-rose-600', 'font-medium');
        hint.classList.add('text-zinc-500');
      }
    });
  }

  document.addEventListener('astro:page-load', initDownloadGate);
</script>
