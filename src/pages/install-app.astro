---
import Layout from '~/layouts/PageLayout.astro';

// ─────────────────────────────────────────────────────────────────────────────
// INSTALL GUIDE — the STANDALONE app (Tradovate / Ironbeam), the non-NinjaTrader
// path. Mirrors the quality of installation-guide.astro (which is NT8-only).
// Flow: download the signed installer → run it → "Sign in with <broker>" (OAuth,
// credentials stay on your PC) → activate your license → configure → go live.
// Early access, paid: 7-day free trial built into the app; license gates it.
// ─────────────────────────────────────────────────────────────────────────────

const metadata = {
  title: 'Install the Meridian App for Tradovate & Ironbeam — Setup Guide',
  ignoreTitleTemplate: true,
  description:
    'Step-by-step setup for the standalone Meridian app: download the signed Windows installer, run it, sign in to your Tradovate or Ironbeam account, activate your license, and configure your trading profile. No NinjaTrader required.',
  robots: { index: true, follow: true },
};

const INSTALLER = '/releases/Meridian-win-Setup.exe';
const DOWNLOAD = '/download';

const howToSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: 'How to Install the Meridian Standalone App (Tradovate / Ironbeam)',
  description: 'Download the installer, sign in to your broker account, activate your license, and configure your profile.',
  tool: [{ '@type': 'HowToTool', name: 'Windows 10 or later (64-bit)' }, { '@type': 'HowToTool', name: 'A Tradovate or Ironbeam account' }],
  step: [
    { '@type': 'HowToStep', name: 'Download', text: 'Download the signed Meridian installer from meridianpsi.com/download.' },
    { '@type': 'HowToStep', name: 'Run the installer', text: 'Run Meridian-win-Setup.exe. It installs in seconds and updates itself from then on.' },
    { '@type': 'HowToStep', name: 'Sign in to your broker', text: 'Click Sign in with Tradovate (or Ironbeam). You authorize on the broker’s own page; your credentials stay on your PC.' },
    { '@type': 'HowToStep', name: 'Activate your license', text: 'Open the License tab, paste your Meridian key from Whop, and click Activate. A 7-day free trial runs before you activate.' },
    { '@type': 'HowToStep', name: 'Configure', text: 'Set your trading profile and, on Guard, your rules. Optionally test on a demo account first.' },
  ],
}).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={howToSchema} />

  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="halo">
    <div data-reveal class="max-w-5xl mx-auto px-6 pt-20 md:pt-24 pb-12 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-4">APP SETUP &middot; ~5 MINUTES &middot; WINDOWS</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-[1.05]">
        Install the Meridian app for<br />Tradovate &amp; Ironbeam.
      </h1>
      <p class="mt-6 max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 leading-relaxed">
        No NinjaTrader required. Download the installer, sign in to your broker account, activate, and you're monitoring
        your live session. A 7-day free trial is built in. <span class="font-semibold text-amber-700">Early access</span> —
        the app is validated and signed; you'll be among the first on it.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={INSTALLER} class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm">Download the app</a>
        <a href="#steps" class="font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3.5 rounded-xl transition">Jump to the steps</a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">
        On NinjaTrader 8 instead? Use the <a href="/installation-guide" class="text-emerald-700 underline underline-offset-2">add-on install guide</a>.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── BEFORE YOU START ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <div class="grid lg:grid-cols-2 gap-12 items-start">
        <div data-reveal>
          <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">BEFORE YOU START</p>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-zinc-900">What you'll need.</h2>
          <p class="mt-5 text-lg text-zinc-600 leading-relaxed">
            The same Meridian engine that runs inside NinjaTrader, as a standalone Windows app that connects straight to
            your broker. Setup takes about five minutes.
          </p>
          <ul class="mt-7 space-y-3 text-zinc-700">
            <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Windows 10 or later (64-bit) &mdash; the installer bundles everything else</span></li>
            <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>A <strong>Tradovate</strong> or <strong>Ironbeam</strong> account (including the ones your prop firm issues)</span></li>
            <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>A Meridian subscription &mdash; or just start the built-in 7-day free trial</span></li>
          </ul>
          <p class="mt-7 text-sm text-zinc-600 border-l-2 border-emerald-500 pl-4 py-1 leading-relaxed">
            One license covers every platform. The same Meridian subscription that runs your NinjaTrader 8 add-on activates
            this app &mdash; you do not pay twice.
          </p>
        </div>

        <!-- Quick Start card -->
        <div data-reveal class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-7">
          <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-4">QUICK START</p>
          <ol class="space-y-3 text-zinc-700 leading-relaxed">
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">1</span><span>Download <a class="text-emerald-700 underline font-medium" href={INSTALLER}>Meridian-win-Setup.exe</a> and run it.</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">2</span><span>Launch Meridian and click <strong>Sign in with Tradovate</strong> (or Ironbeam).</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">3</span><span>Authorize on your broker's page &mdash; the app picks the connection back up automatically.</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">4</span><span>Open the <strong>License</strong> tab, paste your key from Whop, click <strong>Activate</strong> (or run the 7-day trial first).</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">5</span><span>Set your profile in <strong>Settings</strong>; on Guard, add your rules.</span></li>
            <li class="flex gap-3"><span class="font-bold text-emerald-600 tnum">6</span><span><em>Optional:</em> connect a demo account first to see it run.</span></li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── THE STEPS ───────────────────────── -->
  <section id="steps" class="max-w-3xl mx-auto px-6 py-24">
    <div data-reveal class="space-y-14">

      <div>
        <div class="flex items-center gap-3 mb-3"><span class="text-2xl font-extrabold text-emerald-600 tnum">1</span><h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Download &amp; install</h3></div>
        <p class="text-zinc-600 leading-relaxed">
          Download <a href={INSTALLER} class="text-emerald-700 underline underline-offset-2 font-medium">Meridian-win-Setup.exe</a> from
          <a href={DOWNLOAD} class="text-emerald-700 underline underline-offset-2">meridianpsi.com/download</a> and run it. The installer is
          code-signed and self-contained &mdash; no separate runtime to install. It sets up in a few seconds and keeps itself
          up to date automatically after that.
        </p>
        <p class="mt-3 text-sm text-zinc-600 border-l-2 border-amber-400 pl-4 py-1 leading-relaxed">
          If Windows shows a SmartScreen prompt on a brand-new build, choose <strong>More info &rarr; Run anyway</strong> &mdash; the
          file is signed; the warning clears as the signature builds reputation.
        </p>
      </div>

      <div>
        <div class="flex items-center gap-3 mb-3"><span class="text-2xl font-extrabold text-emerald-600 tnum">2</span><h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Sign in to your broker</h3></div>
        <p class="text-zinc-600 leading-relaxed">
          Open Meridian and click <strong>Sign in with Tradovate</strong> (or <strong>Sign in with Ironbeam</strong>). You authorize
          on your broker's own page &mdash; Meridian never sees your password. It detects Demo vs Live for you and starts reading your
          session. Your credentials are used locally on your PC to open the connection and are never transmitted to us.
        </p>
      </div>

      <div>
        <div class="flex items-center gap-3 mb-3"><span class="text-2xl font-extrabold text-emerald-600 tnum">3</span><h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Activate your license</h3></div>
        <p class="text-zinc-600 leading-relaxed">
          A <strong>7-day free trial</strong> runs from first launch &mdash; full access, no key needed. To keep going, open the
          <strong>License</strong> tab, paste the key from your Whop membership (the Software / License Key section), and click
          <strong>Activate</strong>. The same key works here and in NinjaTrader 8.
        </p>
        <p class="mt-3 text-sm text-zinc-600 border-l-2 border-emerald-500 pl-4 py-1 leading-relaxed">
          Don't have a key yet? <a href="/pricing" class="text-emerald-700 underline underline-offset-2">Start a subscription</a> &mdash; the
          first 7 days are free, and early-access members lock in a rate that never goes up.
        </p>
      </div>

      <div>
        <div class="flex items-center gap-3 mb-3"><span class="text-2xl font-extrabold text-emerald-600 tnum">4</span><h3 class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900">Configure &amp; go</h3></div>
        <p class="text-zinc-600 leading-relaxed">
          In <strong>Settings</strong>, set your trading profile &mdash; typical size, session window, signal weights. On the Guard
          tier, add the rules you want enforced (Guard is off until you turn it on). Connect a demo account first if you want to
          watch the HUD and signals respond before you go live.
        </p>
      </div>

    </div>
  </section>

  <!-- ───────────────────────── GOOD TO KNOW ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-3xl mx-auto px-6 py-20">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">GOOD TO KNOW</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 mb-8">A few honest notes.</h2>
      <dl class="space-y-6">
        <div>
          <dt class="font-semibold text-zinc-900">It's early access &mdash; and labeled that way.</dt>
          <dd class="mt-1 text-zinc-600 leading-relaxed">The engine is the same one that's shipped in NinjaTrader 8 for months, validated against the Tradovate and Ironbeam demo environments. The app wrapper is newer &mdash; you may meet a rough edge. Found one? Tell us; early-access members get a direct line to the builder.</dd>
        </div>
        <div>
          <dt class="font-semibold text-zinc-900">It updates itself.</dt>
          <dd class="mt-1 text-zinc-600 leading-relaxed">Once installed, Meridian checks for new builds on launch and updates quietly in the background &mdash; you won't re-download installers for every version.</dd>
        </div>
        <div>
          <dt class="font-semibold text-zinc-900">Your funds and credentials stay yours.</dt>
          <dd class="mt-1 text-zinc-600 leading-relaxed">Meridian never holds or moves money, and never sees your broker password &mdash; you authorize through the broker's own sign-in. The license check sends only a license identifier, nothing about your account.</dd>
        </div>
        <div>
          <dt class="font-semibold text-zinc-900">Works with funded accounts.</dt>
          <dd class="mt-1 text-zinc-600 leading-relaxed">If your prop firm issues a Tradovate or Ironbeam account, this app connects to it directly. Always confirm your firm's rules on third-party tools before arming enforcement.</dd>
        </div>
      </dl>
      <div class="mt-10 flex flex-wrap gap-3">
        <a href={INSTALLER} class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-semibold text-white" style="background:var(--aw-color-primary);">Download the app</a>
        <a href="/platforms" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-semibold border border-zinc-300 text-zinc-700 hover:border-zinc-500 transition-colors">What runs on each platform &rarr;</a>
      </div>
    </div>
  </section>
</Layout>
