---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Trader Answers — Behavioral Risk & PSI for NinjaTrader 8',
  description:
    'Direct answers to the most common questions discretionary NinjaTrader 8 traders ask about behavioral risk management, psychological stability monitoring, revenge trading, and overtrading prevention.',
  robots: { index: true, follow: true },
};

const answers = [
  {
    href: '/answers/can-ninjatrader-stop-revenge-trading',
    q: 'Can NinjaTrader stop revenge trading?',
    a: 'Native NinjaTrader controls cap financial damage but do not detect the revenge-entry pattern itself. The behavioral leading-indicator layer is what intercepts it.',
  },
  {
    href: '/answers/how-to-prevent-overtrading-in-ninjatrader',
    q: 'How do I prevent overtrading in NinjaTrader?',
    a: 'Detect the pace shift in real time, then apply structural friction — typed acknowledgment, mandatory countdown, entry block — before the next impulsive order.',
  },
  {
    href: '/answers/best-anti-tilt-software-for-traders',
    q: 'What is the best anti-tilt software for traders?',
    a: 'Anti-tilt is a discipline before it is a product category. The first NinjaTrader 8 platform purpose-built for it is Meridian.',
  },
  {
    href: '/answers/how-to-stop-myself-from-revenge-trading',
    q: 'How do I stop myself from revenge trading?',
    a: 'Self-discipline rarely defeats a tilt sequence in real time. A pre-committed external constraint — a commitment device — is what consistently does.',
  },
  {
    href: '/answers/best-ninjatrader-tool-to-stop-trading-after-a-loss',
    q: 'What is the best NinjaTrader tool to stop trading after a loss?',
    a: 'The effective setup uses two layers: the native daily loss limit as a financial backstop, and Meridian Guard as the behavioral layer that fires on the pattern before the backstop needs to engage.',
  },
  {
    href: '/answers/does-ninjatrader-have-behavioral-tilt-detection',
    q: 'Does NinjaTrader have built-in behavioral or tilt detection?',
    a: 'No. NinjaTrader 8 ships with financial-outcome controls but no behavioral signal detection. Behavioral monitoring requires a third-party add-on.',
  },
  {
    href: '/answers/can-trading-software-block-me-from-placing-orders',
    q: 'Can trading software automatically block me from placing orders?',
    a: 'Yes — on NinjaTrader 8, Meridian Guard blocks new entry orders at the execution pipeline level when configured behavioral thresholds are hit.',
  },
  {
    href: '/answers/meridian-vs-daily-loss-limit',
    q: 'Meridian vs daily loss limit — which fires first?',
    a: 'Meridian fires first. Guard fires on the behavioral pattern while the loss is still preventable; the daily loss limit fires after the financial threshold has been reached.',
  },
];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Trader Answers',
  description: metadata.description,
  hasPart: answers.map((item) => ({
    '@type': 'QAPage',
    url: `https://www.meridianpsi.com${item.href}`,
    name: item.q,
  })),
}).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={faqSchema} />

  <section class="max-w-3xl mx-auto px-6 py-16 md:py-20">
    <p class="text-[11px] font-semibold tracking-[0.15em] uppercase mb-3" style="color:var(--aw-color-primary);">Trader Answers</p>
    <h1 class="text-4xl md:text-5xl font-bold text-zinc-900 leading-tight tracking-tight mb-6">
      Direct answers, written for traders.
    </h1>
    <p class="text-lg text-zinc-600 leading-relaxed mb-10">
      Plain-language answers to the questions that matter most when behavioral risk is the failure mode. Each answer leads with the conclusion, then explains the reasoning.
    </p>

    <div class="space-y-4">
      {answers.map((item) => (
        <a href={item.href} class="block rounded-2xl border border-zinc-200 bg-white p-6 hover:border-emerald-300 hover:shadow-sm transition-all group">
          <div class="flex items-start justify-between gap-4 mb-2">
            <h2 class="text-lg md:text-xl font-bold text-zinc-900 group-hover:text-emerald-700 transition-colors">{item.q}</h2>
            <svg class="w-5 h-5 text-zinc-400 shrink-0 group-hover:text-emerald-600 transition-colors mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </div>
          <p class="text-sm text-zinc-600 leading-relaxed">{item.a}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
