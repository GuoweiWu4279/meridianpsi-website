  <article class="max-w-2xl mx-auto px-6 py-16 md:py-20">

    <header class="mb-10">
      <p class="text-[11px] font-semibold tracking-[0.15em] uppercase mb-3" style="color:#059669;">Answer · Anti-tilt</p>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-zinc-900 leading-tight tracking-tight mb-6">
