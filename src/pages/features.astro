---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const checkoutUrl = 'https://meridianpsi.lemonsqueezy.com/checkout/buy/b7b8b514-fefa-4a34-8cad-d2e68f564d25';

const metadata = {
  title: 'Features — Meridian',
  description:
    'See how Meridian works: live PSI, seven behavioral signals, session review, personal baselines, adaptable profiles, and fully local privacy.',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="How Meridian works"
    title="See behavioral pressure live. Review it after the session."
    subtitle="Meridian is built for active traders who want more than P&amp;L. It shows PSI in real time, reveals what is driving the score, and gives you review tools built around discipline and stability."
  />

  <Features
    id="live-psi"
    tagline="Live PSI"
    title="See your trading stability while the session is still unfolding."
    subtitle="PSI updates during the session as fills, holding behavior, and rule pressure change. The goal is not just to show that something changed, but to show when behavioral pressure is building before the next decision."
    items={[
      {
        title: 'Live PSI updates in under 100ms',
        description:
          'Meridian refreshes PSI immediately after fills and continues tracking conditions such as holds and rule compliance during the session. You get feedback in the decision window, not just after the trade closes.',
        icon: 'tabler:gauge',
      },
      {
        title: 'Three zones with clear meaning',
        description:
          'Stable (PSI ≥ 88) means your behavior is consistent with your history. Caution (55–87) signals emerging pressure — one or more patterns are active. Critical (below 55) is a clear signal to pause and reassess before compounding mistakes.',
        icon: 'tabler:alert-triangle',
      },
      {
        title: 'Every score has visible drivers',
        description:
          'Each drop in PSI maps to one or more behavioral dimensions. Instead of a single opaque number, you can see which pattern is creating pressure and why the score moved.',
        icon: 'tabler:math-function',
      },
    ]}
  />

  <Features
    id="seven-dimensions"
    tagline="Behavioral signals"
    title="Seven signals tied to recognizable trading failure modes"
    subtitle="Meridian turns familiar lapses in discipline into visible signals, so you can see which pattern is creating pressure instead of guessing from P&amp;L alone."
    columns={2}
    items={[
      {
        title: 'Revenge Entry (D1) — re-entering after a loss',
        description:
          'Flags rapid re-entry after a loss with elevated size in the same direction. Direction reversals are weighted less heavily to distinguish technical flips from emotional retaliation.',
        icon: 'tabler:arrow-back-up',
      },
      {
        title: 'Stop Manipulation (D2) — moving risk wider',
        description:
          'Tracks stop distance over time and detects widening in the adverse direction after price moves against you. This captures the classic impulse to give a losing trade more room than planned.',
        icon: 'tabler:arrows-maximize',
      },
      {
        title: 'Size Spike (D3) — sizing above your rule',
        description:
          'Penalizes size that exceeds your declared rule, with heavier weight during losing streaks when the impulse to make it back is strongest. Personal history is used to avoid generic thresholds.',
        icon: 'tabler:trending-up',
      },
      {
        title: 'Hold Bias (D4) — abnormal hold duration',
        description:
          'Compares your current hold times against your personal baseline to detect both cutting winners too early and holding losers too long. Both are behavioral signatures of pressure — and both are detected against your own history, not a generic benchmark.',
        icon: 'tabler:clock-bolt',
      },
      {
        title: 'Position Overstay (D5) — holding losers too long',
        description:
          'Monitors open positions every 30 seconds and activates when a losing trade exceeds your historical tolerance window. Deep adverse excursion is recorded even if the trade later recovers.',
        icon: 'tabler:hourglass',
      },
      {
        title: 'Rule Violations (D6) — breaking declared session rules',
        description:
          'Checks your declared session rules, including time windows, stop-loss range, and loss-streak behavior. Violations apply scored penalties with cooldowns to prevent noisy double-counting.',
        icon: 'tabler:shield-x',
      },
      {
        title: 'Overtrading Pace (D7) — accelerating entry frequency',
        description:
          'Measures both intra-session acceleration and deviation from your historical entry rhythm. A cold-start ramp helps avoid false positives on the first trade of the session.',
        icon: 'tabler:activity',
      },
    ]}
  />

  <Features
    id="session-review"
    tagline="Session review"
    title="Review behavior after the session, not just the outcome."
    subtitle="Meridian keeps a usable history of PSI, alerts, and behavioral pressure so you can study how a session unfolded, not just whether it finished green or red."
    items={[
      {
        title: 'Session-level PSI and discipline review',
        description:
          'Review each session with more context than P&amp;L alone. Meridian helps you inspect stability, behavioral pressure, and rule alignment so you can see whether a good result was actually disciplined.',
        icon: 'tabler:report-analytics',
      },
      {
        title: 'Behavioral timeline and alert history',
        description:
          'PSI snapshots and alert history make it easier to see when pressure built, when it eased, and which signals were active along the way. That gives you a usable review path instead of a vague memory of the session.',
        icon: 'tabler:timeline-event',
      },
      {
        title: 'Rolling history built for repeated patterns',
        description:
          'Session history stores up to 365 days of daily summaries, up to 200 executions per session, and up to 600 PSI timeline snapshots. Older entries are pruned automatically, so history stays usable without manual cleanup.',
        icon: 'tabler:history',
      },
    ]}
  />

  <Features
    id="baselines"
    tagline="Personalization"
    title="Built around your history, your rules, and your trading style."
    subtitle="Meridian does not compare you to a generic industry average. It learns from your own sessions and can be configured to fit different workflows, rules, and execution styles."
    items={[
      {
        title: 'Your baseline updates automatically',
        description:
          'Running statistics are updated after every session, so Meridian keeps learning what normal looks like for you. The baseline stays current without treating every trader as if they should behave the same way.',
        icon: 'tabler:chart-dots',
      },
      {
        title: 'Early history is gentler. Mature profiles are sharper.',
        description:
          'Signal weighting becomes more confident as your sample size grows. Early sessions stay less aggressive; more mature profiles become more precise because the plugin has better evidence for what is normal for you.',
        icon: 'tabler:math-xy',
      },
      {
        title: 'Profile settings fit different styles and rule sets',
        description:
          'Detailed profile settings let you tune time windows, stop conventions, size rules, and workflow assumptions so Meridian can fit different trading styles instead of forcing a one-size-fits-all setup.',
        icon: 'tabler:adjustments-horizontal',
      },
      {
        title: 'Test Mode and Market Replay stay out of live history',
        description:
          'Test Mode can run PSI in real time without writing to your baseline, and Market Replay sessions are excluded automatically. You can practice, explore settings, or replay markets without polluting your live profile.',
        icon: 'tabler:player-play',
      },
    ]}
  />

  <Features
    id="pressure-dynamics"
    tagline="Scoring model"
    title="Pressure builds quickly. Recovery takes time."
    subtitle="Meridian treats behavioral pressure as something that accumulates under stress and fades only through time and consistent discipline."
    items={[
      {
        title: 'Fast rise, slower recovery',
        description:
          'Each dimension uses separate attack and recovery behavior. Pressure from a violation builds quickly, while recovery requires sustained discipline, so one mistake can fade but repeated behavior stays visible.',
        icon: 'tabler:wave-sine',
      },
      {
        title: 'Overnight carry keeps unresolved pressure visible',
        description:
          'Behavioral pressure does not automatically reset at midnight. Meridian carries unresolved pressure forward with time decay, so a rough Tuesday can still matter on Wednesday while longer breaks allow more recovery.',
        icon: 'tabler:moon',
      },
      {
        title: 'Persistent size violations stop recovery',
        description:
          'When position size remains above your declared limit, recovery is held in place until size comes back into line. The system reflects the reality that ongoing violations should not look resolved just because time passed.',
        icon: 'tabler:lock',
      },
    ]}
  />

  <Features
    id="privacy"
    tagline="Privacy and deployment"
    title="Runs locally. Works with real-world account setups."
    subtitle="Meridian is a native NinjaTrader 8 add-on. Your fills, baseline, and session history stay on your machine while the plugin monitors connected accounts in real time."
    items={[
      {
        title: 'No accounts, no cloud, no telemetry',
        description:
          'There are zero HTTP calls in the codebase. No analytics, no crash reporting, and no license-check pings. Computation happens on your PC, and data stays under your control.',
        icon: 'tabler:cloud-off',
      },
      {
        title: 'Multi-account and Replikanto support',
        description:
          'Meridian monitors all connected NinjaTrader accounts simultaneously. Replikanto copy-fills are deduplicated within a 250ms window to prevent double-counting, and prop firm disconnects are handled gracefully.',
        icon: 'tabler:layout-grid',
      },
      {
        title: 'Local storage you control',
        description:
          'Configuration, baseline data, and session history are stored locally in XML files on your machine. You keep the practical benefits of review history without depending on a web service.',
        icon: 'tabler:database',
      },
    ]}
  />

  <section class="py-10 px-6 bg-zinc-50/80 border-t border-zinc-100">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-zinc-500 leading-relaxed text-center">
        PSI is a behavioral proxy index derived from your trading activity inside NinjaTrader. It does not measure physiology (for example heart rate or stress hormones), and it is not validated as a predictor of trading profits or losses. Meridian is designed to improve self-awareness and discipline during a session; outcomes still depend on many factors beyond psychology.
      </p>
    </div>
  </section>

  <!-- Composure vs PSI Clarification -->
  <section class="py-20 px-6 bg-white border-t border-zinc-100">
    <div class="max-w-4xl mx-auto">
      <p class="text-xs font-semibold tracking-[0.15em] text-emerald-600 uppercase mb-4">Two distinct metrics</p>
      <h2 class="text-2xl md:text-3xl font-bold text-zinc-900 mb-4">PSI and Composure are not the same thing</h2>
      <p class="text-zinc-600 leading-relaxed mb-10 max-w-2xl">
        Meridian tracks two separate measures of your behavioral state. Understanding the difference helps you use both correctly.
      </p>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-zinc-50 border border-zinc-200 rounded-2xl p-6">
          <h3 class="font-bold text-zinc-900 text-lg mb-2">PSI — Real-time score</h3>
          <p class="text-zinc-600 text-sm leading-relaxed mb-4">
            0–100. Updates live after every fill and continuously during the session as holds, time, and rule compliance change. Three zones: <strong>Stable (≥88)</strong>, <strong>Caution (55–87)</strong>, <strong>Critical (&lt;55)</strong>.
          </p>
          <p class="text-xs text-zinc-400">Used for in-session decisions. Visible in the HUD and as a Guard trigger condition.</p>
        </div>
        <div class="bg-zinc-50 border border-zinc-200 rounded-2xl p-6">
          <h3 class="font-bold text-zinc-900 text-lg mb-2">Composure — Session quality score</h3>
          <p class="text-zinc-600 text-sm leading-relaxed mb-4">
            0–100%. Calculated at session end. It reflects how much time you spent in each PSI zone: time in Stable is weighted 1.0×, Caution 0.3×, Critical 0.05×. A long session in Caution will have low Composure even if your PSI looked acceptable.
          </p>
          <p class="text-xs text-zinc-400">Used in Intel Tab, session history, and monthly digest. Not displayed live during the session.</p>
        </div>
      </div>
      <p class="text-xs text-zinc-400 mt-6">
        Example: a trader whose PSI stayed around 75 (Caution) for a 4-hour session would show a Composure of approximately 30% — despite the PSI number looking moderate. The two metrics measure different things.
      </p>
    </div>
  </section>

  <!-- Guard System -->
  <section id="guard" class="py-24 px-6 bg-zinc-900 text-white">
    <div class="max-w-5xl mx-auto">
      <div class="mb-14">
        <p class="text-xs font-semibold tracking-[0.15em] text-emerald-400 uppercase mb-4">Meridian Guard — Commitment device</p>
        <h2 class="text-3xl md:text-4xl font-bold leading-[1.15] mb-5">
          Guard is a commitment device.
        </h2>
        <p class="text-zinc-400 text-base max-w-2xl leading-relaxed">
          When you are calm, you define the rules you want your future self to follow. When the moment comes, Guard enforces them — without you having to decide in real time.
        </p>
      </div>

      <!-- Trigger Conditions -->
      <h3 class="text-sm font-semibold uppercase tracking-widest text-zinc-400 mb-5">6 Trigger conditions</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-14">
        {[
          { name: 'PSI Below', desc: 'Psychological stability drops below a set threshold.' },
          { name: 'Consecutive Losses', desc: 'N losses in a row within the session.' },
          { name: 'Session P\u0026L Below', desc: 'Daily realized P\u0026L falls below your limit.' },
          { name: 'Unrealized P\u0026L Below', desc: 'Open position floating loss exceeds threshold \u2014 before you close.' },
          { name: 'Single Trade Loss Exceeds', desc: 'One trade loses more than a defined amount.' },
          { name: 'Session Time Over', desc: 'You have been trading longer than planned.' },
        ].map((item) => (
          <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-xl p-4">
            <p class="font-semibold text-white text-sm mb-1">{item.name}</p>
            <p class="text-zinc-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- Action Levels -->
      <h3 class="text-sm font-semibold uppercase tracking-widest text-zinc-400 mb-5">5 Action levels — lightest to hardest</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-10">
        {[
          { level: 'L1', name: 'Toast', desc: 'Quiet notification. No interruption.' },
          { level: 'L2', name: 'Acknowledge', desc: 'Type your own pre-written phrase to continue. Written by you, when calm.' },
          { level: 'L3', name: 'Countdown', desc: 'Forced waiting timer. Cannot be skipped.' },
          { level: 'L4', name: 'Risk Alert Mode', desc: 'Persistent banner shown at all times. Every entry requires active confirmation.' },
          { level: 'L5', name: 'Disconnect', desc: 'Disconnects your broker connection. Your positions are never closed by the system.' },
        ].map((item) => (
          <div class="bg-zinc-800/60 border border-zinc-700/50 rounded-xl p-4 flex flex-col gap-2">
            <span class="text-xs font-bold tracking-widest text-emerald-400">{item.level}</span>
            <span class="font-semibold text-white">{item.name}</span>
            <p class="text-zinc-400 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- L2 callout -->
      <div class="bg-zinc-800/40 border border-zinc-700/40 rounded-2xl p-6 mb-14 max-w-2xl">
        <p class="text-xs font-semibold tracking-widest text-emerald-400 uppercase mb-3">Why L2 works</p>
        <p class="text-zinc-300 leading-relaxed text-sm">
          You write the phrase yourself — when you're calm, before the session starts. In the moment, you have to type it to continue. Something like: <em class="text-white">"I will not revenge trade. My plan is my edge."</em> Typed in your own words, at the exact moment you need to hear them most.
        </p>
      </div>

      <!-- Example Guard Setups -->
      <h3 class="text-sm font-semibold uppercase tracking-widest text-zinc-400 mb-5">Example Guard setups</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        {[
          { name: 'Daily Loss Limit', rule: 'P&L below \u2212$500', action: '\u2192 Disconnect' },
          { name: 'Revenge Trade Check', rule: '3 consecutive losses', action: '\u2192 Countdown 60min + Acknowledge' },
          { name: 'Tilt Early Warning', rule: 'PSI below 65', action: '\u2192 Toast' },
          { name: 'Hard Tilt Stop', rule: 'PSI below 45 \u00b7 P&L below \u2212$300', action: '\u2192 Disconnect 30min' },
          { name: 'Position Risk Monitor', rule: 'Unrealized below \u2212$400', action: '\u2192 Risk Alert Mode' },
          { name: 'Session Length Rule', rule: 'Session over 180 minutes', action: '\u2192 Acknowledge required' },
        ].map((item) => (
          <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-xl p-4">
            <p class="font-semibold text-white text-sm mb-2">{item.name}</p>
            <p class="text-zinc-400 text-xs font-mono">{item.rule}</p>
            <p class="text-emerald-400 text-xs font-mono">{item.action}</p>
          </div>
        ))}
      </div>

      <!-- Guard Architecture notes -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { name: 'Edge-trigger', desc: 'Each condition triggers once per entry, no repeated alerts.' },
          { name: 'Cooldown', desc: 'Configurable cooldown period prevents rapid re-triggering.' },
          { name: 'Emergency Reset', desc: 'One-click clears all active Guard state.' },
          { name: 'Master switch', desc: 'Enable or disable Guard entirely without changing your rules.' },
        ].map((item) => (
          <div class="bg-zinc-800/30 border border-zinc-700/30 rounded-xl p-4">
            <p class="font-semibold text-white text-sm mb-1">{item.name}</p>
            <p class="text-zinc-500 text-xs">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intel Layer (Meridian Guard exclusive) -->
  <section id="intel" class="py-20 px-6 bg-white border-t border-zinc-100">
    <div class="max-w-5xl mx-auto">
      <p class="text-xs font-semibold tracking-[0.15em] text-emerald-600 uppercase mb-4">Meridian Guard — Intel Layer</p>
      <h2 class="text-2xl md:text-3xl font-bold text-zinc-900 mb-4">Your session data, turned into insight.</h2>
      <p class="text-zinc-600 leading-relaxed mb-10 max-w-2xl">
        Guard's Intel Layer surfaces patterns from your history that aren't visible in a single session — your weakest trading days, P&L by PSI zone, and a personalized risk brief before each session opens.
      </p>

      <!-- Feature list -->
      <div class="grid sm:grid-cols-2 gap-6 mb-10">
        {[
          {
            name: 'Monthly Digest',
            desc: 'Composure trend, stable days count, win rate, avg P&L, best and worst days, strongest and weakest behavioral dimensions — delivered at month end.',
          },
          {
            name: 'PSI × Performance Correlation',
            desc: 'Maps your actual P&L against PSI zone. Shows what your Stable sessions average versus your Critical sessions. The clearest ROI argument for self-monitoring.',
          },
          {
            name: 'Weekday Patterns & Composure Progress',
            desc: 'Identifies your weakest trading days, 6-month Composure trend, and the behavioral patterns common across your worst sessions.',
          },
          {
            name: "Today's Risk Brief",
            desc: "A personalized opening brief based on yesterday's session and recent behavioral trends — generated before you place your first trade.",
          },
        ].map((item) => (
          <div class="bg-zinc-50 border border-zinc-200 rounded-2xl p-5">
            <h3 class="font-bold text-zinc-900 mb-2">{item.name}</h3>
            <p class="text-zinc-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>

      <!-- Screenshot carousel placeholder -->
      <div class="relative rounded-2xl border-2 border-dashed border-zinc-200 bg-zinc-50/60 overflow-hidden" id="intel-carousel">
        <div class="flex items-center justify-between px-6 py-3 border-b border-zinc-200">
          <p class="text-xs font-semibold text-zinc-400 uppercase tracking-widest">Intel screenshots — coming soon</p>
          <div class="flex gap-2">
            <button class="w-7 h-7 rounded-full border border-zinc-300 flex items-center justify-center text-zinc-500 text-xs cursor-default">&#8249;</button>
            <button class="w-7 h-7 rounded-full border border-zinc-300 flex items-center justify-center text-zinc-500 text-xs cursor-default">&#8250;</button>
          </div>
        </div>
        <div class="flex h-52 items-center justify-center gap-3">
          <svg class="w-8 h-8 text-zinc-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <p class="text-sm text-zinc-400">Intel Layer screenshots will be added here</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-10 px-6 bg-zinc-50/80 border-t border-zinc-100">
    <div class="max-w-3xl mx-auto">
      <p class="text-xs text-zinc-500 leading-relaxed text-center">
        PSI is a behavioral proxy index derived from your trading activity inside NinjaTrader. It does not measure physiology (for example heart rate or stress hormones), and it is not validated as a predictor of trading profits or losses. Meridian is designed to improve self-awareness and discipline during a session; outcomes still depend on many factors beyond psychology.
      </p>
    </div>
  </section>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start free trial — 7 days',
        href: checkoutUrl,
        icon: 'tabler:player-play',
      },
      { text: 'See pricing', href: '/pricing' },
    ]}
  >
    <Fragment slot="title">See it in your own sessions.</Fragment>
    <Fragment slot="subtitle">
      7-day free trial · $24.99/month after · cancel any time · NinjaTrader 8 required.
      <span class="block text-xs text-muted mt-2">Trading involves substantial risk of loss. Meridian does not guarantee trading results.</span>
    </Fragment>
  </CallToAction>
</Layout>
