---
import Layout from '~/layouts/PageLayout.astro';
import pricing from '~/data/pricing.json';
import signalsData from '~/data/signals.json';

// ─────────────────────────────────────────────────────────────────────────────
// FEATURES — the primary "what is it" page for evaluators. Voice: TEACH /
// PRECISE. Teaches the SUPERSET at a glance: everything a traditional risk tool
// does, PLUS the behavioral layer none of them have. Header/Footer/RiskBanner
// come from PageLayout. Design-system classes (.win/.halo/.eyebrow/.tnum) are
// global (tailwind.css). Signals pulled from ~/data/signals.json; tier prices
// from ~/data/pricing.json — never hardcoded.
// ─────────────────────────────────────────────────────────────────────────────

const metadata = {
  title: 'Features — Everything Your Risk Tool Does, Plus Behavior',
  description:
    'Meridian is the complete risk manager for serious futures traders: every limit a traditional risk tool has — daily loss, P&L and drawdown caps, single-trade loss cap, loss-streak cutoff — plus real-time detection of seven trading behaviors (revenge entry, oversizing, stop manipulation, overtrading) scored against your own baseline, with intervention before the order. Native in NinjaTrader 8; Tradovate & Ironbeam in early access. 14-day free trial.',
  robots: { index: true, follow: true },
};

const TRIAL = '/pricing';

const signals = signalsData.signals;
const core = pricing.tiers.find((t) => t.id === 'meridian')!;
const guard = pricing.tiers.find((t) => t.id === 'guard')!;

// JSON-LD — GEO asset. SoftwareApplication featureList mirrors the superset so
// answer engines associate Meridian with both limits AND behavior detection.
const featuresJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'Meridian',
      applicationCategory: 'FinanceApplication',
      applicationSubCategory: 'TradingApplication',
      operatingSystem: 'Windows',
      softwareRequirements: 'NinjaTrader 8 (native add-on) — or a Tradovate / Ironbeam account (standalone app, early access)',
      description:
        'The complete behavioral risk manager for serious futures traders — every traditional limit (daily loss, P&L and drawdown caps, single-trade loss cap, loss-streak cutoff) plus real-time detection of seven trading behaviors scored against your personal baseline, with intervention before the order. Native in NinjaTrader 8; Tradovate and Ironbeam apps in early access.',
      url: 'https://www.meridianpsi.com/features',
      award: 'Official NinjaTrader Ecosystem Vendor',
      offers: [
        {
          '@type': 'Offer',
          name: `${core.name} — monthly (after trial)`,
          price: core.monthlyPrice.toFixed(2),
          priceCurrency: core.currency,
        },
        {
          '@type': 'Offer',
          name: `${guard.name} — monthly (after trial)`,
          price: guard.monthlyPrice.toFixed(2),
          priceCurrency: guard.currency,
        },
      ],
      featureList: [
        'Daily loss limit',
        'Single-trade loss cap',
        'P&L and drawdown caps',
        'Loss-streak cutoff',
        'Session-time stop',
        'Real-time Psychological Stability Index (PSI), 0–100, updated under 100ms',
        ...signals.map((s) => `${s.name} (${s.code}) detection — ${s.short}`),
        'Adaptive baseline calibrated from your own session history',
        'Meridian Guard — 6 trigger types on an escalating ladder (5 levels on NinjaTrader 8; 6-tier Guard v2 with Cool-down Wall and firewall Cut on the standalone apps)',
        'Strict Lock — makes every fired pause un-bypassable for its full window',
        'Intel & Stats — PSI × P&L correlation and behavioral breakdowns',
        'Local-first, anonymized, opt-out telemetry — never name, broker credentials, account numbers, or funds',
        'Native NinjaTrader 8 add-on',
        'Standalone apps for Tradovate and Ironbeam accounts (early access)',
        'Prop firm evaluation compatible',
      ],
      publisher: {
        '@type': 'Organization',
        name: 'Meridian',
        url: 'https://www.meridianpsi.com',
      },
    },
    {
      '@type': 'FAQPage',
      mainEntity: [
        {
          '@type': 'Question',
          name: 'Is Meridian a replacement for my existing NinjaTrader risk tool?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'It is the upgrade, not a competing category. Meridian does everything a traditional risk tool does — daily loss limit, P&L and drawdown caps, single-trade loss cap, loss-streak cutoff — and adds a behavioral layer no limit-based tool has: real-time detection of seven trading behaviors scored against your own baseline, with intervention before the order rather than after the loss.',
          },
        },
        {
          '@type': 'Question',
          name: 'Does Meridian Guard close my live positions?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'By default, no — Guard does not close a live position for you. It blocks you from adding risk, and you can always exit any position, any time. Auto-flatten is an opt-in checkbox: tick it on a Trading Pause or Disconnect rule and Guard will close your positions for you.',
          },
        },
        {
          '@type': 'Question',
          name: 'What data does Meridian collect?',
          acceptedAnswer: {
            '@type': 'Answer',
            text: 'Telemetry is local-first, anonymized, and opt-out. Meridian never collects your name, broker credentials, account numbers, or funds. Your fills, baseline, and session history stay on your machine.',
          },
        },
      ],
    },
  ],
};
const featuresJsonLdHtml = JSON.stringify(featuresJsonLd).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <!-- Structured data for GEO: SoftwareApplication (superset featureList) + FAQPage -->
  <script type="application/ld+json" set:html={featuresJsonLdHtml} />

  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="halo">
    <div data-reveal class="max-w-5xl mx-auto px-6 pt-20 md:pt-24 pb-12 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-6">THE COMPLETE FEATURE SET</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-[1.06]">
        Every limit your risk tool has.<br />Plus the layer that reads <span class="text-emerald-600">how you trade.</span>
      </h1>
      <p class="mt-7 max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 leading-relaxed">
        Meridian is a superset, not a competitor. It enforces every traditional limit — daily loss, P&amp;L and
        drawdown caps, single-trade loss cap, loss-streak cutoff — and then adds what none of them have: real-time detection of the seven
        behaviors that actually blow up accounts, scored against <em>your</em> baseline, stopping you <em>before</em> the order.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={TRIAL} class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm">Start 14-day free trial</a>
        <a href="#superset" class="font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3.5 rounded-xl transition">See the whole superset</a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">No charge until day 14 &middot; From <span class="tnum">${core.monthlyPrice.toFixed(2)}</span>/mo &middot; NinjaTrader 8 today &middot; Tradovate &amp; Ironbeam early access</p>
    </div>
    <div data-reveal class="max-w-5xl mx-auto px-6 pb-16 md:pb-20">
      <div class="win"><img src="/m/overview.png" alt="Meridian Overview — live PSI gauge, behavioral signal bars, and session context inside NinjaTrader 8" class="nozoom" /></div>
    </div>
  </section>

  <!-- ───────────────────────── TRUST STRIP ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-4 flex flex-wrap items-center justify-center gap-x-7 gap-y-2 text-[13px] text-zinc-500">
      <span class="inline-flex items-center gap-1.5 text-emerald-700 font-bold text-sm">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4" /><circle cx="12" cy="12" r="9" /></svg>
        Official NinjaTrader Ecosystem Vendor
      </span>
      <span class="text-zinc-300">|</span><span>Intervenes before the order, not after the loss</span>
    </div>
  </section>

  <!-- ───────────────────────── THE SUPERSET ───────────────────────── -->
  <section id="superset" class="max-w-6xl mx-auto px-6 py-24 scroll-mt-20">
    <div data-reveal class="text-center mb-12">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">THE SUPERSET</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">
        Tricycle vs car.<br />One is a strict subset of the other.
      </h2>
      <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">
        If you already use a risk tool, Meridian is the upgrade — it contains everything it does, then keeps going.
      </p>
    </div>
    <div data-reveal class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto">
      <div class="rounded-2xl border border-zinc-200 bg-white p-7">
        <div class="text-sm font-semibold text-zinc-500 mb-4">What every risk tool does</div>
        <ul class="space-y-3 text-zinc-700">
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>Daily loss limit</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>Single-trade loss cap</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>P&amp;L / drawdown caps</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>Loss-streak cutoff</span></li>
        </ul>
        <p class="mt-5 text-sm text-zinc-500">These literally are four of Guard's six trigger types &mdash; the other two are the session-time stop and the behavioral PSI floor. Meridian does all of it.</p>
      </div>
      <div class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-7">
        <div class="text-sm font-semibold text-emerald-700 mb-4">What only Meridian adds</div>
        <ul class="space-y-3 text-zinc-800">
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Real-time <strong>behavior</strong> detection across 7 signals (revenge entry, oversizing, stop manipulation, overtrading&hellip;)</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>An <strong>adaptive baseline</strong> that learns how <em>you</em> trade — never a generic average</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Intervention <em>before</em> the order — not after the loss</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>The whole loop: monitor &middot; guard &middot; journal &middot; review &middot; improve</span></li>
        </ul>
        <p class="mt-5 text-sm text-emerald-700 font-medium">No limit-based tool can do this.</p>
      </div>
    </div>
    <div data-reveal class="max-w-3xl mx-auto mt-8 rounded-2xl calloutd text-zinc-100 px-7 py-6 text-center">
      <p class="text-lg md:text-xl leading-relaxed">
        A <span class="tnum">&minus;$500</span> daily loss limit fires <em>at</em> &minus;$500 — after four revenge trades in twelve minutes.<br class="hidden md:block" />
        Meridian starts flagging the behavior at <span class="text-emerald-400 font-semibold">trade two.</span>
      </p>
    </div>
  </section>

  <!-- ───────────────────────── THE CATALOG ─────────────────────────
       This page is the directory, not a second homepage. Each surface gets one
       card and one link; the deep dive lives on its own page (the canonical
       host for that argument). The full pre-rebuild sales sections are in git
       history (435-line version) if ever needed. -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div data-reveal class="text-center mb-14">
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">SIX SURFACES, ONE LOOP</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Everything Meridian does, in six pages.</h2>
        <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">
          Plan, monitor, enforce, capture, review — each surface has its own deep dive. Start where your problem is.
        </p>
      </div>
      <div data-reveal class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
        <a href="/overview" class="group rounded-2xl border border-zinc-200 bg-[#fafafa] p-7 transition-all hover:border-emerald-600/40 hover:shadow-md hover:-translate-y-0.5 block">
          <p class="text-[11px] font-bold text-emerald-700 tnum mb-2">01 · PLAN &amp; DEBRIEF</p>
          <h3 class="text-lg font-bold text-zinc-900 mb-1.5">Overview</h3>
          <p class="text-sm text-zinc-600 leading-relaxed mb-4">Walk in briefed, walk out debriefed — the morning risk brief, the pre-session ritual, and the end-of-day report on one screen.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-700 group-hover:gap-2.5 transition-all">Explore <span aria-hidden="true">&rarr;</span></span>
        </a>
        <a href="/psi-monitor" class="group rounded-2xl border border-zinc-200 bg-[#fafafa] p-7 transition-all hover:border-emerald-600/40 hover:shadow-md hover:-translate-y-0.5 block">
          <p class="text-[11px] font-bold text-emerald-700 tnum mb-2">02 · LIVE MONITOR</p>
          <h3 class="text-lg font-bold text-zinc-900 mb-1.5">PSI Monitor</h3>
          <p class="text-sm text-zinc-600 leading-relaxed mb-4">Your discipline as one live number, 0&ndash;100 — seven behavioral signals folded into a score that updates in under 100ms after every fill.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-700 group-hover:gap-2.5 transition-all">Explore <span aria-hidden="true">&rarr;</span></span>
        </a>
        <a href="/guard" class="group rounded-2xl border-2 border-emerald-500/50 bg-white p-7 transition-all hover:border-emerald-600 hover:shadow-md hover:-translate-y-0.5 block">
          <p class="text-[11px] font-bold text-emerald-700 tnum mb-2">03 · ENFORCEMENT</p>
          <h3 class="text-lg font-bold text-zinc-900 mb-1.5">Meridian Guard</h3>
          <p class="text-sm text-zinc-600 leading-relaxed mb-4">Rules you write calm, enforced when you're not — 6 trigger types on an escalating ladder, plus Strict Lock for the moments that matter. On the standalone apps, Guard v2 goes further: a full-screen Cool-down Wall and a firewall-level order Cut.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-700 group-hover:gap-2.5 transition-all">Explore <span aria-hidden="true">&rarr;</span></span>
        </a>
        <a href="/journal" class="group rounded-2xl border border-zinc-200 bg-[#fafafa] p-7 transition-all hover:border-emerald-600/40 hover:shadow-md hover:-translate-y-0.5 block">
          <p class="text-[11px] font-bold text-emerald-700 tnum mb-2">04 · CAPTURE</p>
          <h3 class="text-lg font-bold text-zinc-900 mb-1.5">Session Journal</h3>
          <p class="text-sm text-zinc-600 leading-relaxed mb-4">A journal that writes itself while you're still trading — fills, PSI, and your one-tap notes compiled into the session report.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-700 group-hover:gap-2.5 transition-all">Explore <span aria-hidden="true">&rarr;</span></span>
        </a>
        <a href="/history-intel" class="group rounded-2xl border border-zinc-200 bg-[#fafafa] p-7 transition-all hover:border-emerald-600/40 hover:shadow-md hover:-translate-y-0.5 block">
          <p class="text-[11px] font-bold text-emerald-700 tnum mb-2">05 · REVIEW</p>
          <h3 class="text-lg font-bold text-zinc-900 mb-1.5">Intel &amp; Patterns</h3>
          <p class="text-sm text-zinc-600 leading-relaxed mb-4">A dollar figure on your discipline — PSI &times; P&amp;L correlation, weekday and time-of-day patterns, and a personalized pre-session brief.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-700 group-hover:gap-2.5 transition-all">Explore <span aria-hidden="true">&rarr;</span></span>
        </a>
        <a href="/adaptive-learning-settings" class="group rounded-2xl border border-zinc-200 bg-[#fafafa] p-7 transition-all hover:border-emerald-600/40 hover:shadow-md hover:-translate-y-0.5 block">
          <p class="text-[11px] font-bold text-emerald-700 tnum mb-2">06 · CALIBRATION</p>
          <h3 class="text-lg font-bold text-zinc-900 mb-1.5">Adaptive Learning &amp; Settings</h3>
          <p class="text-sm text-zinc-600 leading-relaxed mb-4">A baseline calibrated to you, not a generic trader — it learns your normal after every session, and practice never pollutes it.</p>
          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-emerald-700 group-hover:gap-2.5 transition-all">Explore <span aria-hidden="true">&rarr;</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── PRIVACY LINE ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div data-reveal class="max-w-3xl mx-auto px-6 py-16 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">ANONYMOUS BY DESIGN</p>
      <p class="text-xl md:text-2xl text-zinc-800 leading-relaxed">
        No login, no accounts. Your fills, baseline, and session history stay on your machine. Telemetry is
        <span class="font-semibold text-zinc-900">local-first, anonymized, and opt-out</span> — never your name, broker
        credentials, account numbers, or funds.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── FINAL CTA ───────────────────────── -->
  <section class="halo">
    <div data-reveal class="max-w-3xl mx-auto px-6 py-28 text-center">
      <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-[1.05]">See the tilt before<br />the next entry.</h2>
      <p class="mt-6 text-lg text-zinc-600">Everything your risk tool does — plus the layer that actually saves the account.</p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={TRIAL} class="inline-block font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-8 py-4 rounded-xl text-lg transition shadow-sm">Start your 14-day free trial</a>
        <a href="/pricing" class="inline-block font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-8 py-4 rounded-xl text-lg transition">See pricing</a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">No charge until day 14 &middot; <span class="tnum">${core.monthlyPrice.toFixed(2)}</span>/month after &middot; Cancel anytime &middot; NinjaTrader 8 today &middot; Tradovate &amp; Ironbeam early access</p>
    </div>
  </section>
</Layout>
