---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';

const metadata = {
  title: 'Refund Policy',
  description: '14-day free trial, 14-day money-back guarantee on your first charge, and a full refund anytime Meridian won\'t run on a supported setup.',
};
---

<Layout metadata={metadata}>
  <HeroText
    title="Refund Policy"
    subtitle="14-day free trial — no charge until day 14. After that, a 14-day money-back guarantee on your first charge."
  />

  <!-- ───────────────────────── POLICY AT A GLANCE ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-5xl mx-auto px-6 py-16 md:py-20">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">POLICY AT A GLANCE</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900">Three ways you're covered.</h2>
      <p class="mt-4 text-lg text-zinc-600 leading-relaxed max-w-3xl">
        14-day free trial &mdash; no charge until day 14. After that: a 14-day money-back guarantee on your first charge,
        and a full refund anytime it won't run on a supported setup &mdash; NinjaTrader 8 today, Tradovate or Ironbeam in early access.
      </p>
      <div class="mt-8 grid sm:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-6">
          <div class="text-emerald-600 text-xs font-bold mb-2 tnum">01</div>
          <div class="font-semibold text-zinc-900 mb-1">14-day free trial</div>
          <p class="text-sm text-zinc-600 leading-relaxed">Full access. No charge until day 14. Cancel before then and pay nothing.</p>
        </div>
        <div class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-6">
          <div class="text-emerald-600 text-xs font-bold mb-2 tnum">02</div>
          <div class="font-semibold text-zinc-900 mb-1">14-day money-back</div>
          <p class="text-sm text-zinc-700 leading-relaxed">Change your mind within 14 days of your first charge? Full refund.</p>
        </div>
        <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-6">
          <div class="text-emerald-600 text-xs font-bold mb-2 tnum">03</div>
          <div class="font-semibold text-zinc-900 mb-1">Won't run? Full refund</div>
          <p class="text-sm text-zinc-600 leading-relaxed">If it won't run on a supported NT8 setup and we can't fix it &mdash; anytime.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── THE TERMS ───────────────────────── -->
  <section class="max-w-3xl mx-auto px-6 py-20 md:py-24">

    <div class="space-y-12">
      <div>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">FREE TRIAL</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900">Try it before you pay.</h2>
        <p class="mt-4 text-lg text-zinc-600 leading-relaxed">
          Every plan starts with a <strong class="text-zinc-800">14-day free trial</strong> — you get full access, and your
          card is not charged until day 14. If Meridian isn't for you, cancel before the trial ends and you will not be
          charged. You can cancel anytime.
        </p>
      </div>

      <div>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">14-DAY MONEY-BACK GUARANTEE</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900">Change your mind? You're covered.</h2>
        <p class="mt-4 text-lg text-zinc-600 leading-relaxed">
          After your trial converts, your <strong class="text-zinc-800">first charge</strong> is covered by a
          <strong class="text-zinc-800">14-day money-back guarantee</strong>. If you change your mind within 14 days of that
          first charge, contact us and we will issue a full refund.
        </p>
      </div>

      <div>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">WON'T RUN ON A SUPPORTED SETUP</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900">If it won't run, you don't pay.</h2>
        <p class="mt-4 text-lg text-zinc-600 leading-relaxed">
          You are also eligible for a <strong class="text-zinc-800">full refund — anytime</strong> if Meridian won't run on a
          supported setup (NinjaTrader 8, or an early-access Tradovate/Ironbeam configuration) and our support team can't resolve it, including when:
        </p>
        <ul class="mt-5 space-y-3 text-zinc-700">
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Meridian fails to install correctly on a system meeting the published minimum requirements</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>The software produces a consistent, reproducible critical error that prevents basic functionality</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>You have contacted support and we have been unable to resolve the issue</span></li>
        </ul>
        <p class="mt-5 text-base text-zinc-500 leading-relaxed">
          Refund requests are not accepted for dissatisfaction with trading outcomes or P&amp;L results — Meridian is a
          risk-management and behavioral-monitoring tool, not a signal provider or a guarantee of trading results.
        </p>
      </div>

      <div>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">HOW TO REQUEST A REFUND</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900">One email. We handle the rest.</h2>
        <p class="mt-4 text-lg text-zinc-600 leading-relaxed">
          To request a refund, email
          <a href="mailto:contactmeridianpsi@gmail.com" class="text-emerald-700 underline underline-offset-2 hover:text-emerald-900">contactmeridianpsi@gmail.com</a>
          with:
        </p>
        <ol class="mt-5 space-y-3 text-zinc-700">
          <li class="flex gap-3"><span class="text-emerald-600 font-bold tnum">1.</span> Your order number or receipt</li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold tnum">2.</span> A brief description of the issue you encountered</li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold tnum">3.</span> Your platform and version (NinjaTrader 8 build number, or standalone app version) and Windows version</li>
        </ol>
        <p class="mt-5 text-lg text-zinc-600 leading-relaxed">
          We will respond within 24 hours and process approved refunds within 5–10 business days via the original payment
          method.
        </p>
      </div>

      <div>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">SUBSCRIPTION CANCELLATION</p>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900">Cancel anytime, no lock-in.</h2>
        <p class="mt-4 text-lg text-zinc-600 leading-relaxed">
          Monthly and annual subscriptions can be cancelled at any time from your Whop account
          (<a href="https://whop.com/@me/settings/memberships" class="text-emerald-700 underline underline-offset-2 hover:text-emerald-900">whop.com/@me/settings/memberships</a>),
          using the email you used at checkout. Cancellation stops
          future billing. You retain access to the software until the end of your current paid period. Cancellation does not
          automatically trigger a refund — refund eligibility follows the criteria above.
        </p>
      </div>
    </div>

    <p class="text-sm text-zinc-500 mt-12 border-t border-zinc-200 pt-6">
      Last updated: June 2026.
    </p>

  </section>
</Layout>
