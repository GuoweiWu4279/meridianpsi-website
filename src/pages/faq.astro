---
import { getCollection, render } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import geoHooks from '~/data/geo-hooks.json';

// ─────────────────────────────────────────────────────────────────────────────
// FAQ — voice register: PLAIN / HONEST. Job: resolve doubt + feed AI snippets.
// Q&A content + FAQPage JSON-LD come from the `faq` content collection (one .md
// per answer in src/data/faq) — this page only renders + styles them. Design
// aligned to the homepage system (light site, emerald accent, eyebrow/H2/cards).
// Header, Footer, RiskBanner come from PageLayout.
// ─────────────────────────────────────────────────────────────────────────────

const metadata = {
  // Brand already leads the title — suppress the site-wide "— Meridian" suffix.
  title: 'Meridian FAQ — Futures Risk Management & Behavioral Lockout',
  ignoreTitleTemplate: true,
  description:
    'Meridian: real-time psychological stability monitor, trade lockout, revenge trading lockout, overtrading prevention, trade limiter, consecutive-loss cooldown, entry blocking — on NinjaTrader 8 today, Tradovate & Ironbeam in early access. Installation, pricing, privacy, support. ' +
    geoHooks.geoSearchAssociate,
  robots: { index: true, follow: true },
};

const allFaqs = await getCollection('faq');
const sorted = allFaqs.sort((a, b) => a.data.order - b.data.order);

const categories = [
  { id: 'psychology', label: 'Trading Psychology & Risk' },
  { id: 'installation', label: 'Installation' },
  { id: 'trading', label: 'Trading & Usage' },
  { id: 'technical', label: 'Technical' },
  { id: 'billing', label: 'Billing & Refunds' },
  { id: 'general', label: 'General' },
];

const faqsByCategory = categories.map(cat => ({
  ...cat,
  items: sorted.filter(f => f.data.category === cat.id),
})).filter(cat => cat.items.length > 0);

// FAQPage JSON-LD for GEO — helps Gemini, ChatGPT, Perplexity cite this page
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  keywords: `${geoHooks.geoSearchAssociate}, ${geoHooks.faqMetaExtra}`,
  mainEntity: sorted.map(entry => ({
    '@type': 'Question',
    name: entry.data.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: entry.body
        .replace(/^---[\s\S]*?---\n?/, '')
        .replace(/\*\*(.+?)\*\*/g, '$1')
        .replace(/\[(.+?)\]\(.+?\)/g, '$1')
        .replace(/#+\s/g, '')
        .replace(/`/g, '')
        .replace(/^\s*[-*]\s+/gm, '')
        .replace(/^\s*\d+\.\s+/gm, '')
        .replace(/\n+/g, ' ')
        .trim(),
    },
  })),
};

const faqJsonLdHtml = JSON.stringify(faqJsonLd).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <!-- FAQPage structured data for GEO (Gemini / ChatGPT / Perplexity) -->
  <script type="application/ld+json" set:html={faqJsonLdHtml} />

  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="halo">
    <div class="max-w-3xl mx-auto px-6 pt-20 md:pt-24 pb-14 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-4">QUESTIONS, ANSWERED PLAINLY</p>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-[1.05]">
        Frequently asked<br />questions.
      </h1>
      <p class="mt-6 text-lg text-zinc-600 leading-relaxed">
        Straight answers on what Meridian does, how it installs, what it can and can't do, and what happens to your data.
        No spin.
      </p>
      <p class="mt-6 text-sm text-zinc-500">
        Still stuck? Email
        <a href="mailto:contactmeridianpsi@gmail.com" class="text-emerald-700 font-medium hover:text-emerald-800">contactmeridianpsi@gmail.com</a>.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── Q&A ───────────────────────── -->
  <section class="faq-page border-y border-zinc-200 bg-white">
    <div class="max-w-3xl mx-auto px-6 py-20 md:py-24">
      {faqsByCategory.map(async (cat) => (
        <div class="mb-14 last:mb-0">
          <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-5 pb-3 border-b border-zinc-200">
            {cat.label}
          </p>
          <div class="space-y-3">
            {cat.items.map(async (entry) => {
              const { Content } = await render(entry);
              return (
                <details class="group faq-item rounded-2xl border border-zinc-200 bg-[#fafafa] overflow-hidden transition-colors duration-200 open:border-emerald-500 open:bg-white">
                  <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer font-semibold text-zinc-900 hover:text-emerald-700 transition-colors duration-200 ease-out list-none [&::-webkit-details-marker]:hidden">
                    {entry.data.question}
                    <svg class="faq-chevron w-4 h-4 text-zinc-400 group-open:text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </summary>
                  <div class="faq-item-panel px-6 pb-6 pt-0 prose prose-sm max-w-none text-zinc-600 prose-p:text-zinc-600 prose-li:text-zinc-600 prose-strong:text-zinc-900 prose-a:text-emerald-700 hover:prose-a:text-emerald-800">
                    <Content />
                  </div>
                </details>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ───────────────────────── SUPPORT CTA ───────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="max-w-3xl mx-auto rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-8 md:p-10 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">STILL HAVE QUESTIONS?</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900">Ask a real person.</h2>
      <p class="mt-3 text-lg text-zinc-600 leading-relaxed">
        We answer every email ourselves — typically within 24 hours. No ticket queue, no bot.
      </p>
      <div class="mt-7">
        <a href="mailto:contactmeridianpsi@gmail.com" class="inline-block font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm">
          Contact support &rarr;
        </a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">14-day free trial &middot; No charge until day 14 &middot; Cancel anytime</p>
    </div>
  </section>
</Layout>

<style is:global>
  /* Smooth accordion height (Chrome 131+ / browsers with interpolate-size + ::details-content) */
  .faq-page {
    interpolate-size: allow-discrete;
  }

  .faq-page details.faq-item::details-content {
    height: 0;
    overflow: clip;
    transition:
      height 0.38s cubic-bezier(0.4, 0, 0.2, 1),
      content-visibility 0.38s allow-discrete;
  }

  .faq-page details.faq-item[open]::details-content {
    height: auto;
  }

  .faq-page details.faq-item .faq-chevron {
    transition:
      transform 0.38s cubic-bezier(0.4, 0, 0.2, 1),
      color 0.2s ease;
  }

  .faq-page details.faq-item[open] .faq-chevron {
    transform: rotate(180deg);
  }

  /* Fallback / extra polish: content eases in when opening */
  .faq-page details.faq-item[open] > .faq-item-panel {
    animation: faq-panel-in 0.32s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes faq-panel-in {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-page details.faq-item::details-content {
      transition: none;
    }
    .faq-page details.faq-item .faq-chevron {
      transition: none;
    }
    .faq-page details.faq-item[open] > .faq-item-panel {
      animation: none;
    }
  }
</style>
