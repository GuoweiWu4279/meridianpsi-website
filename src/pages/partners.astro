---
import Layout from '~/layouts/PageLayout.astro';
import EcosystemVendorBadge from '~/components/widgets/EcosystemVendorBadge.astro';

const metadata = {
  // Brand already appears in the title — suppress the site-wide "— Meridian" suffix.
  title: 'Partner with Meridian — 30% Lifetime Recurring for Futures-Trading Creators',
  ignoreTitleTemplate: true,
  description:
    'Promote the most complete risk management for NinjaTrader 8 — the superset that does what every risk tool does, plus the behavioral layer none of them have. 30% lifetime recurring commission, 10% permanent audience discount, free Meridian Guard license. Official NinjaTrader Ecosystem Vendor. We respond to applications within 24 hours.',
  robots: { index: true, follow: true },
};

// Single canonical creator-program page. /affiliate 301-redirects here.
// Apply form posts to the same Formspree endpoint as /support — emails are
// distinguished by the hidden _subject field "Partner Application".
const formspreeEndpoint = 'https://formspree.io/f/xaqalank';

const dealCards = [
  {
    headline: '30%',
    label: 'Lifetime recurring',
    sub: 'On every payment, for as long as they stay subscribed. Paid monthly via Whop.',
  },
  {
    headline: '10%',
    label: 'Audience discount',
    sub: 'Permanent — applies to every renewal, not just first month.',
  },
  {
    headline: 'Free',
    label: 'Guard license',
    sub: 'Full Meridian Guard at no cost while the partnership is active.',
  },
];

const fitCards = [
  {
    icon: 'wallet',
    title: 'Audience already pays for NT8 software',
    body: 'Indicators, add-ons, risk tools — paid utility is the norm in this niche. No price objection to overcome.',
  },
  {
    icon: 'shield',
    title: 'Software, not a guru',
    body: 'No course, no Discord, no founder face. Easy to recommend without picking sides in the mentor wars.',
  },
  {
    icon: 'flash',
    title: 'The trial does the convincing',
    body: 'Audience installs, sees their own behavioral signals fire on their own session, decides for themselves.',
  },
];

const earningsTiers = [
  { subs: '20 active subs', amount: '$4,536', note: 'Illustrative annual run-rate · assumes no churn' },
  { subs: '100 active subs', amount: '$22,680', note: 'Illustrative annual run-rate · assumes no churn' },
  { subs: '200 active subs', amount: '$45,360', note: 'Illustrative annual run-rate · assumes no churn' },
];

const kitItems = [
  'Meridian logo — SVG (vector) + 4 PNG variants (16:9 and square, light and dark)',
  '20+ product screenshots — HUD states (Stable / Warning / Critical), all 4 Guard intervention levels, Session Report, Intel analytics, Journal, History, Settings',
  'B-roll demo video (1080p MP4)',
  '6 content templates — 60-sec hook, 3-min walkthrough, 30-sec short, YouTube description, Twitter/X thread, newsletter section',
  'Core positioning copy in 4 formats — one sentence, three sentences, full paragraph, 60-sec verbal',
  'Audience FAQ — 15 accurate answers for comments and DMs',
  'FTC disclosure language for every format — video, Shorts, Twitter, newsletter',
  'Audience angles + objection handling by segment — prop firm, psychology, systematic',
];

const payoutItems = [
  'You receive a unique affiliate link — your own Whop URL like whop.com/meridian/?a=yourname. Anyone who completes checkout through that link is automatically attributed to you.',
  'Your audience also receives a permanent 10%-off promo code in your name. Discount and attribution are two independent mechanisms, but both are managed from your Whop affiliate panel.',
  'Commission is 30% of the amount each subscriber actually pays after the discount, recurring on every billing cycle (enabled as a "Recurring payments" override on your partner account).',
  'Earnings dashboard, attribution tracking, and monthly payouts all run through your Whop affiliate panel.',
  'Standard 30-day waiting period from a referred purchase to commission release (industry-standard refund-protection window).',
];

const finePrintItems = [
  '14-day free trial · credit card required at checkout · auto-cancels if not converted',
  'Pricing after trial: Meridian Core $49.99/mo or $479.90/yr · Meridian Guard $69.99/mo or $671.90/yr',
  'Commission tracked and paid monthly through Whop',
  'Affiliates required to disclose the partnership per FTC and other applicable regulations',
  'Not all applications are accepted — fit with audience matters more than audience size',
  'Program terms subject to change with reasonable notice to active partners',
];
---

<Layout metadata={metadata}>

  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="halo">
    <div class="max-w-5xl mx-auto px-6 pt-20 md:pt-24 pb-16 md:pb-20 text-center" data-reveal>
      <div class="flex flex-wrap items-center justify-center gap-2 mb-7">
        <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full border"
              style="border-color:rgba(5,150,105,0.35); background:rgba(5,150,105,0.07);">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-600" aria-hidden="true"></span>
          <span class="text-[10px] md:text-[11px] font-semibold tracking-[0.15em] uppercase text-emerald-800">Partner Program · NT8 Creators</span>
        </span>
        <EcosystemVendorBadge variant="compact" />
      </div>

      <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tight text-zinc-900 leading-[1.04]">
        Promote the tool that<br />actually <span class="text-emerald-600">catches the behavior.</span>
      </h1>

      <p class="mt-7 max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 leading-relaxed">
        Meridian is the most complete risk management for serious futures traders &mdash; native in NinjaTrader 8,
        Tradovate &amp; Ironbeam apps in early access &mdash; everything a risk tool does, plus the
        behavioral layer none of them have. Recommend a product your audience can install and see firing on their own session on day one.
      </p>
      <p class="mt-5 max-w-2xl mx-auto text-lg text-zinc-700 leading-relaxed">
        <strong class="text-zinc-900">30% lifetime recurring.</strong> 10% permanent audience discount. A free Guard license while you&rsquo;re a partner.
        We respond in 24 hours.
      </p>

      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href="#apply" class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm">Apply now</a>
        <a href="#details" class="font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3.5 rounded-xl transition">See the details</a>
      </div>

      <p class="mt-7 max-w-2xl mx-auto text-sm text-zinc-500 leading-relaxed">
        You&rsquo;ll be promoting an <strong class="text-zinc-700">Official NinjaTrader Ecosystem Vendor</strong> &mdash; audited and approved by NinjaTrader&rsquo;s Compliance, QA, and Executive teams.
        <a href="https://ninjatraderecosystem.com/search-results/?fwp_vendors=meridian" target="_blank" rel="noopener" class="underline text-zinc-600 hover:text-zinc-900">Your audience can verify in the NinjaTrader Ecosystem</a>.
      </p>
    </div>

    <div class="max-w-5xl mx-auto px-6 pb-16 md:pb-20" data-reveal>
      <div class="relative">
        <div class="win"><img src="/m/overview.png" alt="Meridian Overview dashboard — what your audience installs" class="nozoom" /></div>
        <div
          class="absolute -bottom-7 right-3 w-32 md:w-44 hidden sm:block rounded-2xl overflow-hidden"
          style="box-shadow:0 30px 70px -20px rgba(0,0,0,.5);border:1px solid rgba(0,0,0,.06)"
        >
          <img src="/m/ring.png" alt="Meridian live risk gauge (PSI)" class="block w-full" />
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── THE DEAL ───────────────────────── -->
  <section id="details" class="border-y border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="text-center mb-12" data-reveal>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">THE DEAL</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">
          Set up once. Earn for the<br />lifetime of every subscriber.
        </h2>
        <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">Three numbers, no asterisks. This is the whole offer.</p>
      </div>

      <div class="grid sm:grid-cols-3 gap-5 max-w-4xl mx-auto" data-reveal>
        {dealCards.map((card) => (
          <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-7">
            <p class="text-4xl font-extrabold text-zinc-900 mb-1.5 tracking-tight tnum">{card.headline}</p>
            <p class="text-sm font-semibold text-emerald-700 mb-3">{card.label}</p>
            <p class="text-sm text-zinc-600 leading-relaxed">{card.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── WHAT YOU CAN EARN ───────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-12" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">WHAT YOU CAN EARN</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">The recurring math compounds.</h2>
      <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">
        Every active Guard subscriber pays you <span class="font-semibold text-zinc-900 tnum">$18.90/month</span> in recurring
        commission &mdash; for as long as they stay on the plan.
      </p>
    </div>

    <div class="grid sm:grid-cols-3 gap-5 max-w-4xl mx-auto" data-reveal>
      {earningsTiers.map((tier) => (
        <div class="rounded-2xl border border-zinc-200 bg-white p-7">
          <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">{tier.subs}</p>
          <p class="text-3xl font-extrabold text-zinc-900 tracking-tight tnum">{tier.amount}<span class="text-base font-medium text-zinc-400"> / yr</span></p>
          <p class="text-xs text-emerald-700 font-semibold mt-2">{tier.note}</p>
        </div>
      ))}
    </div>

    <div class="max-w-4xl mx-auto mt-8 rounded-2xl calloutd text-zinc-100 px-7 py-8 md:px-10 md:py-9" data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-400 mb-3">HOW THIS SCALES</p>
      <p class="text-lg md:text-xl leading-relaxed">
        A single 10,000-view video at 1% conversion = <span class="text-emerald-400 font-semibold tnum">100 trial installs.</span>
        How many of those convert varies widely by audience and offer &mdash; credit-card-required trials like ours tend to convert better than free ones.
      </p>
      <p class="mt-3 text-base md:text-lg leading-relaxed text-zinc-400">
        And this is a long-term partnership &mdash; you publish multiple pieces over time. Commission stacks across content
        cycles, not per video. Subscribers from a video you posted last quarter still pay you next quarter.
      </p>
    </div>

    <p class="text-xs text-zinc-400 leading-relaxed mt-6 max-w-4xl mx-auto">
      Examples assume Meridian Guard monthly ($69.99) with the 10% audience discount applied. Per-subscriber commission = $69.99 × 0.90 × 0.30 = $18.90/mo. Annual plans, Core plans, and churn shift the actual numbers. Illustrative figures, not earnings guarantees.
    </p>
  </section>

  <!-- ───────────────────────── WHY THIS WORKS ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="text-center mb-12" data-reveal>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">WHY THIS WORKS</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Why Meridian converts on<br />NT8 audiences.</h2>
        <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">It recommends itself &mdash; because the trial makes the case for you.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-5 max-w-5xl mx-auto" data-reveal>
        {fitCards.map((card) => (
          <div class="rounded-2xl border border-zinc-200 bg-[#fafafa] p-7">
            <div class="w-10 h-10 rounded-full bg-emerald-50 border border-emerald-200 flex items-center justify-center mb-5">
              {card.icon === 'wallet' && (
                <svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a2 2 0 00-2-2h-2a2 2 0 100 4h2a2 2 0 002-2zM3 7a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                </svg>
              )}
              {card.icon === 'shield' && (
                <svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {card.icon === 'flash' && (
                <svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              )}
            </div>
            <h3 class="text-base font-bold text-zinc-900 mb-2 leading-snug">{card.title}</h3>
            <p class="text-sm text-zinc-600 leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ───────────────────────── DETAILS ON DEMAND ───────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12" data-reveal>
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">DETAILS ON DEMAND</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Everything else, only<br />if you want it.</h2>
        <p class="mt-4 text-lg text-zinc-600">The full kit, payout mechanics, and program terms &mdash; read them before you apply.</p>
      </div>

      <div class="space-y-3" data-reveal>

        <details class="group rounded-2xl border border-zinc-200 bg-white overflow-hidden">
          <summary class="flex items-center justify-between px-7 py-5 cursor-pointer list-none hover:bg-[#fafafa] transition-colors">
            <span class="text-base font-semibold text-zinc-900">What&rsquo;s in the creator kit?</span>
            <svg class="w-5 h-5 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-7 pb-7 pt-1">
            <p class="text-sm text-zinc-500 leading-relaxed mb-4">
              Delivered as a zip the moment your application is accepted. Custom asset requests accommodated where possible.
            </p>
            <ul class="space-y-2.5">
              {kitItems.map((item) => (
                <li class="flex items-start gap-3 text-sm text-zinc-700">
                  <svg class="w-4 h-4 mt-0.5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </details>

        <details class="group rounded-2xl border border-zinc-200 bg-white overflow-hidden">
          <summary class="flex items-center justify-between px-7 py-5 cursor-pointer list-none hover:bg-[#fafafa] transition-colors">
            <span class="text-base font-semibold text-zinc-900">How tracking &amp; payouts work</span>
            <svg class="w-5 h-5 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-7 pb-7 pt-1">
            <ul class="space-y-2.5">
              {payoutItems.map((item) => (
                <li class="flex items-start gap-3 text-sm text-zinc-700">
                  <span class="mt-2 w-1 h-1 rounded-full bg-emerald-500 shrink-0" aria-hidden="true"></span>
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </details>

        <details class="group rounded-2xl border border-zinc-200 bg-white overflow-hidden">
          <summary class="flex items-center justify-between px-7 py-5 cursor-pointer list-none hover:bg-[#fafafa] transition-colors">
            <span class="text-base font-semibold text-zinc-900">Brand-safe partnership</span>
            <svg class="w-5 h-5 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-7 pb-7 pt-1">
            <p class="text-sm text-zinc-700 leading-relaxed mb-3">
              Your audience trusts you. We do not take that lightly.
            </p>
            <p class="text-sm text-zinc-500 leading-relaxed">
              If the response to your first piece of content is not what either of us hoped for, either side can close the partnership clean &mdash; no-fault, no performance bar, no awkward follow-up. Closing ends new promotion and asset use only; your recurring commission on subscribers you already referred keeps paying for as long as they stay subscribed. The lifetime-recurring promise is not revoked.
            </p>
          </div>
        </details>

        <details class="group rounded-2xl border border-zinc-200 bg-white overflow-hidden">
          <summary class="flex items-center justify-between px-7 py-5 cursor-pointer list-none hover:bg-[#fafafa] transition-colors">
            <span class="text-base font-semibold text-zinc-900">Program terms &amp; fine print</span>
            <svg class="w-5 h-5 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-7 pb-7 pt-1">
            <ul class="space-y-2.5">
              {finePrintItems.map((item) => (
                <li class="flex items-start gap-3 text-sm text-zinc-700">
                  <span class="mt-2 w-1 h-1 rounded-full bg-emerald-500 shrink-0" aria-hidden="true"></span>
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </details>

      </div>
    </div>
  </section>

  <!-- ───────────────────────── APPLY ───────────────────────── -->
  <section id="apply" class="border-y border-zinc-200 bg-white scroll-mt-24">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10" data-reveal>
          <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">APPLY</p>
          <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">Apply now. We respond<br />in 24 hours.</h2>
          <p class="mt-4 text-lg text-zinc-600">Every application is reviewed manually. Fit matters more than channel size.</p>
        </div>

        <form
          action={formspreeEndpoint}
          method="POST"
          class="space-y-5"
          id="partner-form"
          data-reveal
        >
          <input type="hidden" name="_subject" value="Partner Application" />

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="p-name" class="block text-sm font-medium text-zinc-700 mb-1.5">Your name</label>
              <input type="text" name="name" id="p-name" required placeholder="Full name"
                class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" />
            </div>
            <div>
              <label for="p-email" class="block text-sm font-medium text-zinc-700 mb-1.5">Email</label>
              <input type="email" name="email" id="p-email" required placeholder="you@domain.com"
                class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" />
            </div>
          </div>

          <div>
            <label for="p-channel" class="block text-sm font-medium text-zinc-700 mb-1.5">Channel name</label>
            <input type="text" name="channel_name" id="p-channel" required placeholder="e.g. NT8 Daily, Pat's Trading, etc."
              class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" />
          </div>

          <div>
            <label for="p-url" class="block text-sm font-medium text-zinc-700 mb-1.5">Channel URL</label>
            <input type="url" name="channel_url" id="p-url" required placeholder="https://youtube.com/@yourchannel"
              class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" />
            <p class="text-xs text-zinc-400 mt-1.5">YouTube, X, podcast, newsletter, Discord — your primary channel.</p>
          </div>

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="p-size" class="block text-sm font-medium text-zinc-700 mb-1.5">Audience size</label>
              <select name="audience_size" id="p-size" required
                class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent">
                <option value="" disabled selected>Select range</option>
                <option value="<1000">Under 1,000</option>
                <option value="1k-5k">1,000 – 5,000</option>
                <option value="5k-20k">5,000 – 20,000</option>
                <option value="20k-100k">20,000 – 100,000</option>
                <option value="100k+">100,000+</option>
              </select>
            </div>
            <div>
              <label for="p-platform" class="block text-sm font-medium text-zinc-700 mb-1.5">Audience trades…</label>
              <select name="audience_trades" id="p-platform" required
                class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent">
                <option value="" disabled selected>Primary focus</option>
                <option value="NT8 futures">NinjaTrader 8 futures</option>
                <option value="NT8 + prop firm">NT8 + prop firm evaluations</option>
                <option value="Mixed futures">Futures (mixed platforms)</option>
                <option value="Stocks/options">Stocks / options</option>
                <option value="Forex">Forex</option>
                <option value="Other">Other</option>
              </select>
            </div>
          </div>

          <div>
            <label for="p-fit" class="block text-sm font-medium text-zinc-700 mb-1.5">Why does Meridian fit your audience?</label>
            <textarea name="fit_reason" id="p-fit" required rows="4" placeholder="A few sentences. What problem does Meridian solve for the people who watch you?"
              class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none"></textarea>
          </div>

          <div>
            <label for="p-notes" class="block text-sm font-medium text-zinc-700 mb-1.5">
              Anything else? <span class="text-zinc-400 font-normal">(optional)</span>
            </label>
            <textarea name="notes" id="p-notes" rows="3" placeholder="Existing sponsorships, media kit link, content schedule."
              class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none"></textarea>
          </div>

          <button type="submit"
            class="w-full sm:w-auto font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm">
            Submit application
          </button>

          <p class="text-xs text-zinc-400">
            Or email us at <a href="mailto:contactmeridianpsi@gmail.com" class="underline hover:text-zinc-600">contactmeridianpsi@gmail.com</a> with the same info.
          </p>
        </form>

        <!-- Success state shown after Formspree submission -->
        <div id="partner-form-success" class="hidden text-center py-12">
          <div class="text-emerald-600 text-4xl mb-4">✓</div>
          <h3 class="text-xl font-semibold text-zinc-900 mb-2">Application received</h3>
          <p class="text-zinc-500 text-sm">We&rsquo;ll respond within 24 hours, usually faster.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── BOTTOM DISCLAIMER ───────────────────────── -->
  <section class="max-w-3xl mx-auto px-6 py-10">
    <p class="text-xs text-zinc-400 leading-relaxed text-center">
      Affiliates are responsible for ensuring promotional activity complies with FTC endorsement and financial promotion rules in their jurisdiction. Program terms subject to change with reasonable notice.
    </p>
  </section>

</Layout>

<script>
  // Async submission so we can show inline success/error without a full page reload.
  // Re-attached on every Astro client-side navigation (View Transitions).
  function initPartnerForm() {
    const form = document.getElementById('partner-form') as HTMLFormElement | null;
    const successDiv = document.getElementById('partner-form-success');
    if (!form || !successDiv) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (response.ok) {
          form.classList.add('hidden');
          successDiv.classList.remove('hidden');
        } else {
          alert('Something went wrong. Please email contactmeridianpsi@gmail.com directly with your application details.');
        }
      } catch {
        alert('Network error. Please email contactmeridianpsi@gmail.com directly with your application details.');
      }
    });
  }

  document.addEventListener('astro:page-load', initPartnerForm);
</script>
