---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Partner with Meridian — 30% Lifetime Recurring for NinjaTrader 8 Creators',
  description:
    '30% lifetime recurring commission. 10% permanent audience discount. Free Meridian Guard license. We respond to applications within 24 hours.',
  robots: { index: true, follow: true },
};

// Single canonical creator-program page. /affiliate 301-redirects here.
// Apply form posts to the same Formspree endpoint as /support — emails are
// distinguished by the hidden _subject field "Partner Application".
const formspreeEndpoint = 'https://formspree.io/f/xaqalank';

const dealCards = [
  {
    headline: '30%',
    label: 'Lifetime recurring',
    sub: 'On every payment, for as long as they stay subscribed. Paid monthly via Whop.',
  },
  {
    headline: '10%',
    label: 'Audience discount',
    sub: 'Permanent — applies to every renewal, not just first month.',
  },
  {
    headline: 'Free',
    label: 'Guard license',
    sub: 'Full Meridian Guard at no cost while the partnership is active.',
  },
];

const fitCards = [
  {
    icon: 'wallet',
    title: 'Audience already pays for NT8 software',
    body: 'Indicators, add-ons, risk tools — paid utility is the norm in this niche. No friction in audience expectation.',
  },
  {
    icon: 'shield',
    title: 'Software, not a guru',
    body: 'No course, no Discord, no founder face. Easy to recommend without picking sides in the mentor wars.',
  },
  {
    icon: 'flash',
    title: 'The trial does the convincing',
    body: 'Audience installs, sees their own behavioral signals fire on their own session, decides for themselves.',
  },
];

const kitItems = [
  'Logo pack (PNG + SVG, light & dark)',
  'Brand color palette + typography reference',
  '8 product screenshots (PSI HUD, Guard, Intel, Session Report)',
  'Embeddable demo videos (YouTube unlisted + .mp4 on request)',
  '3 video script templates: 30-sec teaser, 60-sec hook, 3-min walkthrough',
  'Talking-points doc — what to say, what to avoid, compliance language',
  'Email signature banner, X header, YouTube end-card templates',
];

const finePrintItems = [
  '7-day free trial · credit card required at checkout · auto-cancels if not converted',
  'Pricing after trial: Meridian Core $49.99/mo or $479.90/yr · Meridian Guard $69.99/mo or $671.90/yr',
  'Commission tracked and paid monthly through Whop on standard 30-day cycle',
  'Affiliates required to disclose the partnership per FTC and other applicable regulations',
  'Not all applications are accepted — fit with audience matters more than audience size',
  'Program terms subject to change with reasonable notice to active partners',
];
---

<Layout metadata={metadata}>

  <!-- ═══════════════════════════════════════════════════════
       HERO  · tight, single-screen, one clear pitch
       ═══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden border-b border-zinc-100">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
         style="background: radial-gradient(ellipse at 75% 0%, rgba(5,150,105,0.10) 0%, transparent 60%);"></div>
    <div class="relative max-w-3xl mx-auto px-6 pt-24 pb-20 md:pt-32 md:pb-24">
      <div class="inline-flex items-center gap-2.5 border px-4 py-1.5 mb-8 rounded-full"
           style="border-color:rgba(5,150,105,0.35); background:rgba(5,150,105,0.08);">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-600" aria-hidden="true"></span>
        <span class="text-[11px] font-semibold tracking-[0.15em] uppercase text-emerald-800">Partner Program · NT8 Creators</span>
      </div>

      <h1 class="text-4xl md:text-6xl font-bold tracking-tight leading-[1.05] text-zinc-900 mb-6">
        Partner with Meridian.
      </h1>

      <p class="text-lg md:text-xl text-zinc-600 leading-relaxed mb-10">
        30% lifetime recurring. 10% permanent audience discount. Free Guard license while you're a partner. We respond in 24 hours.
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <a href="#apply" class="inline-flex items-center justify-center gap-2 px-7 py-3 rounded-full bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-semibold transition-colors">
          Apply now
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#details" class="inline-flex items-center justify-center px-7 py-3 rounded-full border border-zinc-300 text-sm font-semibold text-zinc-700 hover:border-zinc-500 hover:text-zinc-900 transition-colors">
          See the details
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       THE DEAL  · 3 numbers, scannable in 5 seconds
       ═══════════════════════════════════════════════════════ -->
  <section id="details" class="py-20 md:py-24 px-6 bg-zinc-50/50 border-b border-zinc-100">
    <div class="max-w-4xl mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase mb-3 text-emerald-700">The deal</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 mb-12 max-w-2xl">
        Set up once. Earn for the lifetime of every subscriber.
      </h2>

      <div class="grid sm:grid-cols-3 gap-5">
        {dealCards.map((card) => (
          <div class="bg-white border border-zinc-200 rounded-2xl px-7 py-8">
            <p class="text-4xl font-bold text-zinc-900 mb-1.5 tracking-tight">{card.headline}</p>
            <p class="text-sm font-semibold text-emerald-700 mb-3">{card.label}</p>
            <p class="text-sm text-zinc-500 leading-relaxed">{card.sub}</p>
          </div>
        ))}
      </div>

      <!-- What you can earn — matches the page's visual system: white card,
           zinc-50 inset blocks, single emerald accent. No gradients, no black box. -->
      <div class="mt-12 rounded-2xl border border-zinc-200 bg-white px-6 py-8 md:px-10 md:py-10">
        <p class="text-[11px] font-semibold tracking-[0.2em] uppercase mb-3 text-emerald-700">What you can earn</p>
        <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 mb-3 leading-snug">
          The recurring math compounds.
        </h3>
        <p class="text-zinc-600 leading-relaxed mb-8 max-w-xl text-[15px]">
          Every active Guard subscriber pays you <span class="font-semibold text-zinc-900">$18.90/month</span> in recurring commission, for as long as they stay on the plan.
        </p>

        <!-- Tiered earnings — three equal-weight inset cards -->
        <div class="grid sm:grid-cols-3 gap-4 mb-8">
          <div class="rounded-xl border border-zinc-200 bg-zinc-50/60 px-5 py-5">
            <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">20 active subs</p>
            <p class="text-2xl font-bold text-zinc-900 tracking-tight">$4,536<span class="text-base font-normal text-zinc-500"> / yr</span></p>
            <p class="text-xs text-zinc-400 mt-1.5">Recurring</p>
          </div>
          <div class="rounded-xl border border-zinc-200 bg-zinc-50/60 px-5 py-5">
            <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">100 active subs</p>
            <p class="text-2xl font-bold text-zinc-900 tracking-tight">$22,680<span class="text-base font-normal text-zinc-500"> / yr</span></p>
            <p class="text-xs text-zinc-400 mt-1.5">Recurring</p>
          </div>
          <div class="rounded-xl border border-zinc-200 bg-zinc-50/60 px-5 py-5">
            <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1.5">200 active subs</p>
            <p class="text-2xl font-bold text-zinc-900 tracking-tight">$45,360<span class="text-base font-normal text-zinc-500"> / yr</span></p>
            <p class="text-xs text-zinc-400 mt-1.5">Recurring</p>
          </div>
        </div>

        <!-- How this scales — soft inset callout with subtle emerald accent rule -->
        <div class="rounded-xl border border-zinc-200 bg-zinc-50/60 border-l-[3px] border-l-emerald-500 px-5 py-5 md:px-6 md:py-5">
          <p class="text-[11px] font-semibold tracking-[0.18em] uppercase mb-2.5 text-emerald-700">How this scales</p>
          <p class="text-[15px] leading-relaxed text-zinc-700 mb-2">
            A single 10,000-view video at 1% conversion = <span class="font-semibold text-zinc-900">100 trial installs</span>. Industry trial-to-paid for SaaS utilities runs <span class="font-semibold text-zinc-900">30–60%</span>.
          </p>
          <p class="text-[15px] leading-relaxed text-zinc-500">
            And this is a long-term partnership — you publish multiple pieces over time. Commission stacks across content cycles, not per-video. Subscribers from a video you posted last quarter still pay you next quarter.
          </p>
        </div>

        <p class="text-xs text-zinc-400 leading-relaxed mt-6">
          Examples assume Meridian Guard monthly ($69.99) with the 10% audience discount applied. Per-subscriber commission = $69.99 × 0.90 × 0.30 = $18.90/mo. Annual plans, Core plans, and churn shift the actual numbers. Illustrative figures, not earnings guarantees.
        </p>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       WHY THIS WORKS  · 3-card icon grid, no walls of text
       ═══════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-24 px-6 bg-white border-b border-zinc-100">
    <div class="max-w-4xl mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase mb-3 text-emerald-700">Why this works</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 mb-12 max-w-2xl">
        Why Meridian converts on NT8 audiences.
      </h2>

      <div class="grid md:grid-cols-3 gap-5">
        {fitCards.map((card) => (
          <div class="rounded-2xl border border-zinc-200 px-6 py-7 hover:border-emerald-200 transition-colors">
            <div class="w-10 h-10 rounded-full bg-emerald-50 border border-emerald-200 flex items-center justify-center mb-5">
              {card.icon === 'wallet' && (
                <svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a2 2 0 00-2-2h-2a2 2 0 100 4h2a2 2 0 002-2zM3 7a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                </svg>
              )}
              {card.icon === 'shield' && (
                <svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {card.icon === 'flash' && (
                <svg class="w-5 h-5 text-emerald-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
              )}
            </div>
            <h3 class="text-base font-bold text-zinc-900 mb-2 leading-snug">{card.title}</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       DETAILS ON DEMAND  · accordion, default-collapsed
       Placed before Apply so creators see terms before applying.
       Cuts visible vertical space ~40% vs. expanded sections.
       ═══════════════════════════════════════════════════════ -->
  <section class="py-20 md:py-24 px-6 bg-zinc-50/50 border-b border-zinc-100">
    <div class="max-w-2xl mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase mb-3 text-emerald-700">Details on demand</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 mb-10">
        Everything else, only if you want it.
      </h2>

      <div class="space-y-3">

        <details class="group rounded-xl border border-zinc-200 bg-white overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none hover:bg-zinc-50/60 transition-colors">
            <span class="text-base font-semibold text-zinc-900">What's in the creator kit?</span>
            <svg class="w-5 h-5 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 pt-1">
            <p class="text-sm text-zinc-500 leading-relaxed mb-4">
              Delivered as a zip the moment your application is accepted. Custom asset requests accommodated where possible.
            </p>
            <ul class="space-y-2.5">
              {kitItems.map((item) => (
                <li class="flex items-start gap-3 text-sm text-zinc-700">
                  <svg class="w-4 h-4 mt-0.5 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </details>

        <details class="group rounded-xl border border-zinc-200 bg-white overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none hover:bg-zinc-50/60 transition-colors">
            <span class="text-base font-semibold text-zinc-900">How tracking & payouts work</span>
            <svg class="w-5 h-5 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 pt-1">
            <ul class="space-y-2.5">
              {[
                'You receive a unique affiliate link — your own Whop URL like whop.com/meridian/?a=yourname. Anyone who completes checkout through that link is automatically attributed to you.',
                'Your audience also receives a permanent 10%-off promo code in your name. Discount and attribution are two independent mechanisms, but both are managed from your Whop affiliate panel.',
                'Commission is 30% of the amount each subscriber actually pays after the discount, recurring on every billing cycle (enabled as a "Recurring payments" override on your partner account).',
                'Earnings dashboard, attribution tracking, and monthly payouts all run through your Whop affiliate panel.',
                'Standard 30-day waiting period from a referred purchase to commission release (industry-standard refund-protection window).',
              ].map((item) => (
                <li class="flex items-start gap-3 text-sm text-zinc-700">
                  <span class="mt-2 w-1 h-1 rounded-full bg-emerald-500 shrink-0" aria-hidden="true"></span>
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </details>

        <details class="group rounded-xl border border-zinc-200 bg-white overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none hover:bg-zinc-50/60 transition-colors">
            <span class="text-base font-semibold text-zinc-900">Brand-safe partnership</span>
            <svg class="w-5 h-5 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 pt-1">
            <p class="text-sm text-zinc-700 leading-relaxed mb-3">
              Your audience trusts you. We do not take that lightly.
            </p>
            <p class="text-sm text-zinc-500 leading-relaxed">
              If the response to your first piece of content is not what either of us hoped for, we close the partnership clean — assets pulled, no further obligation, no awkward follow-up. You retain any commission already earned.
            </p>
          </div>
        </details>

        <details class="group rounded-xl border border-zinc-200 bg-white overflow-hidden">
          <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none hover:bg-zinc-50/60 transition-colors">
            <span class="text-base font-semibold text-zinc-900">Program terms & fine print</span>
            <svg class="w-5 h-5 text-zinc-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 pt-1">
            <ul class="space-y-2.5">
              {finePrintItems.map((item) => (
                <li class="flex items-start gap-3 text-sm text-zinc-700">
                  <span class="mt-2 w-1 h-1 rounded-full bg-emerald-500 shrink-0" aria-hidden="true"></span>
                  <span class="leading-relaxed">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </details>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════
       APPLY  · placed after details so creators read terms first
       ═══════════════════════════════════════════════════════ -->
  <section id="apply" class="py-20 md:py-24 px-6 bg-white border-b border-zinc-100">
    <div class="max-w-2xl mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase mb-3 text-emerald-700">Apply</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 mb-3">
        Apply now. We respond in 24 hours.
      </h2>
      <p class="text-zinc-500 leading-relaxed mb-10 text-[15px]">
        Every application is reviewed manually. Fit matters more than channel size.
      </p>

      <form
        action={formspreeEndpoint}
        method="POST"
        class="space-y-5"
        id="partner-form"
      >
        <input type="hidden" name="_subject" value="Partner Application" />

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="p-name" class="block text-sm font-medium text-zinc-700 mb-1.5">Your name</label>
            <input type="text" name="name" id="p-name" required placeholder="Full name"
              class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" />
          </div>
          <div>
            <label for="p-email" class="block text-sm font-medium text-zinc-700 mb-1.5">Email</label>
            <input type="email" name="email" id="p-email" required placeholder="you@domain.com"
              class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" />
          </div>
        </div>

        <div>
          <label for="p-channel" class="block text-sm font-medium text-zinc-700 mb-1.5">Channel name</label>
          <input type="text" name="channel_name" id="p-channel" required placeholder="e.g. NT8 Daily, Pat's Trading, etc."
            class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" />
        </div>

        <div>
          <label for="p-url" class="block text-sm font-medium text-zinc-700 mb-1.5">Channel URL</label>
          <input type="url" name="channel_url" id="p-url" required placeholder="https://youtube.com/@yourchannel"
            class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent" />
          <p class="text-xs text-zinc-400 mt-1.5">YouTube, X, podcast, newsletter, Discord — your primary channel.</p>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="p-size" class="block text-sm font-medium text-zinc-700 mb-1.5">Audience size</label>
            <select name="audience_size" id="p-size" required
              class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent">
              <option value="" disabled selected>Select range</option>
              <option value="<1000">Under 1,000</option>
              <option value="1k-5k">1,000 – 5,000</option>
              <option value="5k-20k">5,000 – 20,000</option>
              <option value="20k-100k">20,000 – 100,000</option>
              <option value="100k+">100,000+</option>
            </select>
          </div>
          <div>
            <label for="p-platform" class="block text-sm font-medium text-zinc-700 mb-1.5">Audience trades…</label>
            <select name="audience_trades" id="p-platform" required
              class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent">
              <option value="" disabled selected>Primary focus</option>
              <option value="NT8 futures">NinjaTrader 8 futures</option>
              <option value="NT8 + prop firm">NT8 + prop firm evaluations</option>
              <option value="Mixed futures">Futures (mixed platforms)</option>
              <option value="Stocks/options">Stocks / options</option>
              <option value="Forex">Forex</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>

        <div>
          <label for="p-fit" class="block text-sm font-medium text-zinc-700 mb-1.5">Why does Meridian fit your audience?</label>
          <textarea name="fit_reason" id="p-fit" required rows="4" placeholder="A few sentences. What problem does Meridian solve for the people who watch you?"
            class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none"></textarea>
        </div>

        <div>
          <label for="p-notes" class="block text-sm font-medium text-zinc-700 mb-1.5">
            Anything else? <span class="text-zinc-400 font-normal">(optional)</span>
          </label>
          <textarea name="notes" id="p-notes" rows="3" placeholder="Existing sponsorships, media kit link, content schedule."
            class="w-full rounded-lg border border-zinc-300 bg-white text-zinc-900 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent resize-none"></textarea>
        </div>

        <button type="submit"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-7 py-3 rounded-full bg-zinc-900 hover:bg-zinc-700 text-white text-sm font-semibold transition-colors">
          Submit application
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>

        <p class="text-xs text-zinc-400">
          Or email us at <a href="mailto:contactmeridianpsi@gmail.com" class="underline hover:text-zinc-600">contactmeridianpsi@gmail.com</a> with the same info.
        </p>
      </form>

      <!-- Success state shown after Formspree submission -->
      <div id="partner-form-success" class="hidden text-center py-12">
        <div class="text-emerald-600 text-4xl mb-4">✓</div>
        <h3 class="text-xl font-semibold text-zinc-900 mb-2">Application received</h3>
        <p class="text-zinc-500 text-sm">We'll respond within 24 hours, usually faster.</p>
      </div>
    </div>
