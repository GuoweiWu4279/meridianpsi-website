    <div class="relative z-[1] max-w-7xl mx-auto px-6">
      <div class="pt-14 pb-12 md:pt-20 md:pb-16 lg:pt-24 lg:pb-20">
        <div class="lg:grid lg:grid-cols-[minmax(0,1fr)_minmax(0,1.12fr)] lg:gap-14 lg:items-center">
