<script>
  // ——— Scroll-triggered fade-up ———
  function initFadeUp() {
    const els = document.querySelectorAll<HTMLElement>('.fade-up');
    if (!els.length || !('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    els.forEach((el) => observer.observe(el));
  }

  // ——— Step-detail tabs ———
  function initStepTabs() {
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-step-tab]'));
    const track = document.getElementById('step-panels-track') as HTMLElement | null;
    if (!tabs.length || !track) return;
    let current = 0;

    function activate(next: number) {
      if (next === current) return;
      tabs.forEach((t, i) => {
        t.classList.toggle('is-active', i === next);
        t.setAttribute('aria-selected', i === next ? 'true' : 'false');
      });
      track!.style.transform = `translateX(-${next * 25}%)`;
      current = next;
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activate(parseInt(tab.dataset.stepTab ?? '0', 10));
      });
      tab.addEventListener('keydown', (e) => {
        const k = e.key;
        const forward = k === 'ArrowRight' || k === 'ArrowDown';
        const back = k === 'ArrowLeft' || k === 'ArrowUp';
        if (!forward && !back) return;
        e.preventDefault();
        const delta = forward ? 1 : -1;
        const next = (current + delta + tabs.length) % tabs.length;
        tabs[next].focus();
        activate(next);
      });
    });
  }

  function boot() {
    initFadeUp();
    initStepTabs();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>
