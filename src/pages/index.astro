  <!-- Design-system primitives (.win/.winsm/.halo/.tnum) now live in the global
       stylesheet (src/assets/styles/tailwind.css → @layer components). -->

  <script>
    // Homepage interactivity: lightbox (click product screens to enlarge) + Intel carousel.
    // Re-init on astro:page-load so it survives View Transitions.
    function initHome() {
      if (document.getElementById('m-lightbox')) return; // already initialised
      // Lightbox
      const lb = document.createElement('div');
      lb.id = 'm-lightbox';
      lb.style.cssText =
        'position:fixed;inset:0;z-index:100;background:rgba(8,8,10,.93);display:none;align-items:center;justify-content:center;padding:20px;cursor:zoom-out';
      const img = document.createElement('img');
      img.style.cssText = 'max-width:96vw;max-height:94vh;border-radius:10px;box-shadow:0 30px 90px rgba(0,0,0,.6)';
      lb.appendChild(img);
      document.body.appendChild(lb);
      const close = () => {
        lb.style.display = 'none';
      };
      lb.addEventListener('click', close);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
      document.querySelectorAll<HTMLImageElement>('.win img:not(.nozoom)').forEach((el) => {
        el.style.cursor = 'zoom-in';
        el.addEventListener('click', (e) => {
          e.stopPropagation();
          img.src = el.currentSrc || el.src;
          lb.style.display = 'flex';
        });
      });
      // Carousels
      document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((c) => {
        const slides = Array.from(c.querySelectorAll<HTMLElement>('[data-slide]'));
        const dots = Array.from(c.querySelectorAll<HTMLElement>('[data-dot]'));
        const cap = c.querySelector<HTMLElement>('[data-caption]');
        let i = 0;
        const show = (n: number) => {
          i = ((n % slides.length) + slides.length) % slides.length;
          slides.forEach((s, k) => {
            s.style.display = k === i ? 'block' : 'none';
          });
          dots.forEach((d, k) => {
            d.style.width = k === i ? '22px' : '8px';
            d.style.background = k === i ? '#059669' : '#d4d4d8';
          });
          if (cap) cap.textContent = slides[i].getAttribute('data-cap') || '';
        };
        const p = c.querySelector('[data-prev]');
        const nx = c.querySelector('[data-next]');
        if (p) p.addEventListener('click', () => show(i - 1));
        if (nx) nx.addEventListener('click', () => show(i + 1));
        dots.forEach((d, k) => d.addEventListener('click', () => show(k)));
        show(0);
      });
    }
    document.addEventListener('astro:page-load', initHome);
  </script>
