---
import Layout from '~/layouts/PageLayout.astro';
import pricing from '~/data/pricing.json';
import geoHooks from '~/data/geo-hooks.json';

// ─────────────────────────────────────────────────────────────────────────────
// HOMEPAGE — superset positioning ("Everything your risk tool does — and the
// part it's blind to"). Ported from the approved mockup public/p/home.html.
// Voice register: HOOK / conversion. Header, Footer, RiskBanner come from
// PageLayout. Design-system classes (.win/.halo/.eyebrow/.tnum) are scoped to
// this page for now; extract to a shared stylesheet when other pages need them.
// ─────────────────────────────────────────────────────────────────────────────

const metadata = {
  title: 'Meridian — Complete Risk Management for Serious Futures Traders',
  description:
    "Everything your risk tool does — daily loss limits, P&L and drawdown caps, loss-streak cutoffs — plus the layer none of them have: real-time behavioral detection that catches revenge trading, oversizing, and tilt before the order. Native in NinjaTrader 8; Tradovate & Ironbeam apps in early access. 14-day free trial.",
  ignoreTitleTemplate: true,
  robots: { index: true, follow: true },
};

const TRIAL = '/pricing';

function tierToSchemaOffers(tier: (typeof pricing.tiers)[number]) {
  const monthly = tier.monthlyPrice.toFixed(2);
  const annual = tier.annualPrice.toFixed(2);
  return [
    {
      '@type': 'Offer',
      name: `${tier.name} — monthly (after trial)`,
      price: monthly,
      priceCurrency: tier.currency,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: monthly,
        priceCurrency: tier.currency,
        billingDuration: 'P1M',
      },
    },
    {
      '@type': 'Offer',
      name: `${tier.name} — annual (after trial)`,
      price: annual,
      priceCurrency: tier.currency,
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: annual,
        priceCurrency: tier.currency,
        billingDuration: 'P1Y',
      },
    },
  ];
}

/** JSON-LD must be injected via set:html — inline `{JSON.stringify({...})}` breaks because Astro treats inner `}` as closing the expression. */
const homePageJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://www.meridianpsi.com/#organization',
      name: 'Meridian',
      alternateName: ['Meridian PSI', 'Meridian Guard'],
      url: 'https://www.meridianpsi.com',
      logo: 'https://www.meridianpsi.com/meridian-logo.png',
      description: geoHooks.meridianPsiCanonical,
      disambiguatingDescription:
        'Meridian (meridianpsi.com) is behavioral trading-discipline software for futures traders — a real-time psychological stability monitor and risk-enforcement add-on for NinjaTrader 8. It is not a commodity-price, energy, market-analytics, price-forecasting, or trade-signals product. "PSI" is its Psychological Stability Index, not pounds-per-square-inch or any price/strength index.',
      memberOf: {
        '@type': 'ProgramMembership',
        programName: 'NinjaTrader Ecosystem',
        hostingOrganization: {
          '@type': 'Organization',
          name: 'NinjaTrader, LLC',
          url: 'https://ninjatrader.com/',
        },
        membershipNumber: 'Official Ecosystem Vendor',
        description:
          'Meridian is an Official NinjaTrader Ecosystem Vendor — audited and approved by NinjaTrader’s Compliance, QA, and Executive teams (May 2026) — and is listed in the official NinjaTrader Ecosystem as an approved third-party add-on for NinjaTrader 8.',
      },
      knowsAbout: [
        'NinjaTrader 8',
        'Tradovate',
        'Ironbeam',
        'Behavioral risk management',
        'Psychological Stability Index',
        'Revenge trading prevention',
        'Overtrading prevention',
        'Stop-loss manipulation detection',
        'Prop firm risk control',
        'NinjaTrader broker disconnect',
        'NinjaTrader order cancellation',
      ],
      sameAs: [
        'https://x.com/Meridian_PSI',
        'https://www.youtube.com/@Meridianpsi1',
        'https://www.tiktok.com/@meridianpsi',
        'https://www.instagram.com/meridianpsi/',
        // Official vendor anchors: the live Ecosystem listing (canonical URL per
        // NT's own publish email, 2026-05-29) + the forum announcement.
        // Keep in sync with EcosystemVendorBadge.astro.
        'https://ninjatraderecosystem.com/search-results/?fwp_vendors=meridian',
        'https://discourse.ninjatrader.com/t/meridian-real-time-behavioral-risk-monitor-guard-enforcement-now-an-official-ninjatrader-ecosystem-vendor/6865',
      ],
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Meridian',
      alternateName: ['Meridian PSI', 'Meridian Guard'],
      applicationCategory: 'FinanceApplication',
      applicationSubCategory: 'TradingApplication',
      operatingSystem: 'Windows',
      softwareVersion: '1.5.0',
      softwareRequirements: 'NinjaTrader 8 (native add-on) — or a Tradovate / Ironbeam account (standalone app, early access)',
      description: geoHooks.schemaSoftwarePsi,
      keywords: geoHooks.geoSearchAssociate,
      url: 'https://www.meridianpsi.com',
      award: 'Official NinjaTrader Ecosystem Vendor (May 2026)',
      offers: pricing.tiers.flatMap(tierToSchemaOffers),
      featureList: [
        'Real-time Psychological Stability Index (PSI)',
        'Seven behavioral signal dimensions',
        'Real-time psychological stability monitor and trade lockout layer for futures traders',
        'Revenge trading lockout — rapid re-entry detection',
        'Overtrading prevention — session pace and trade frequency',
        'Trade limiter and entry blocking (Guard)',
        'Consecutive-loss countdowns and rule enforcement add-on',
        'Trading Pause — hard risk enforcement',
        'Behavioral leading indicator — fires before P&L damage compounds',
        'Revenge Entry detection',
        'Stop-Loss Manipulation detection',
        'Overtrading Pace monitoring',
        'Size Spike detection',
        'Rule Violations tracking',
        'Meridian Guard — automated behavioral enforcement',
        'Intel Layer analytics',
        'Anonymous by design — never your name, broker credentials, account numbers, or funds',
        'NinjaTrader 8 native add-on',
        'Standalone apps for Tradovate and Ironbeam accounts (early access)',
        'Prop firm compatible',
      ],
      releaseNotes: 'https://www.meridianpsi.com/download',
      downloadUrl: 'https://www.meridianpsi.com/download',
      publisher: {
        '@id': 'https://www.meridianpsi.com/#organization',
      },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://www.meridianpsi.com/#website',
      name: 'Meridian',
      url: 'https://www.meridianpsi.com',
      description:
        'Real-time psychological stability monitor for active futures traders — native in NinjaTrader 8, with Tradovate and Ironbeam apps in early access. Tracks seven behavioral patterns and computes a live PSI score, personal to your own trading baseline.',
      keywords: geoHooks.geoSearchAssociate,
      publisher: {
        '@id': 'https://www.meridianpsi.com/#organization',
      },
    },
  ],
};

const homePageJsonLdHtml = JSON.stringify(homePageJsonLd).replace(/</g, '\\u003c');
---

<Layout metadata={metadata}>
  <!-- Structured data for GEO: Organization + SoftwareApplication + WebSite -->
  <script type="application/ld+json" set:html={homePageJsonLdHtml} />

  <!-- ───────────────────────── HERO ───────────────────────── -->
  <section class="halo">
    <div data-reveal class="max-w-5xl mx-auto px-6 pt-20 md:pt-24 pb-12 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-6">RISK MANAGEMENT FOR SERIOUS FUTURES TRADERS</p>
      <h1 class="text-4xl sm:text-5xl md:text-7xl font-extrabold tracking-tight text-zinc-900 leading-[1.04]">
        Everything your risk tool does &mdash;<br />and the part it's <span class="text-emerald-600">blind to.</span>
      </h1>
      <p class="mt-7 max-w-2xl mx-auto text-lg md:text-xl text-zinc-600 leading-relaxed">
        Daily loss limits, P&amp;L caps, loss-streak cutoffs &mdash; Meridian has them all. Then it adds what no limit can: it reads the
        behavior that actually blows up accounts &mdash; revenge, oversizing, tilt &mdash; in real time, and stops you before
        the damage.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a href={TRIAL} class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3.5 rounded-xl transition shadow-sm">Start 14-day free trial</a>
        <a href="#how" class="font-semibold text-zinc-800 bg-white border border-zinc-300 hover:border-zinc-400 px-6 py-3.5 rounded-xl transition">See how it works</a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">No charge until day 14 &middot; From $49.99/mo &middot; Cancel anytime</p>
      <p class="mt-3 text-xs text-zinc-500">
        Runs in <span class="font-semibold text-zinc-700">NinjaTrader 8</span> today &middot;
        <a href="/platforms" class="font-semibold text-emerald-700 hover:underline">Tradovate &amp; Ironbeam apps in early access &rarr;</a>
      </p>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-zinc-500">
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Runs locally &mdash; your data stays on your machine
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          No P&amp;L or account numbers ever leave your PC
        </span>
        <span class="inline-flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Cancel anytime
        </span>
      </div>
    </div>
    <div data-reveal class="max-w-5xl mx-auto px-6 pb-16 md:pb-20">
      <div class="relative">
        <div class="win"><img src="/m/overview.png" alt="Meridian Overview dashboard" class="nozoom" /></div>
        <div
          class="absolute -bottom-7 right-3 w-32 md:w-44 hidden sm:block rounded-2xl overflow-hidden"
          style="box-shadow:0 30px 70px -20px rgba(0,0,0,.5);border:1px solid rgba(0,0,0,.06)"
        >
          <img src="/m/ring.png" alt="Meridian live PSI gauge — catching a warning behavioral state" class="block w-full" />
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── ENDORSEMENT (Official NT Vendor + partners) ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div data-reveal class="max-w-4xl mx-auto px-6 py-10 text-center">
      <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full mb-4" style="border:1px solid rgba(242,101,34,0.25); background:rgba(242,101,34,0.05);">
        <svg class="w-3.5 h-3.5" fill="none" stroke="#F26522" stroke-width="2.8" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
        <span class="text-[11px] font-semibold tracking-[0.12em] uppercase" style="color:#F26522;">Official NinjaTrader Vendor</span>
      </div>
      <p class="text-sm text-zinc-500 mb-8 max-w-xl mx-auto">Audited and approved by NinjaTrader&rsquo;s Compliance, QA &amp; Executive teams.</p>
      <div class="flex items-center justify-center gap-10 md:gap-16">
        <a href="https://ninjatraderus.pxf.io/jROzm0" target="_blank" rel="noopener noreferrer" aria-label="NinjaTrader — official trading platform partner" class="flex flex-col items-center gap-2 group">
          <img src="/logos/ninjatrader-wordmark.png" alt="NinjaTrader" style="height:30px; width:auto; object-fit:contain; opacity:0.85; transition:opacity 0.2s;" class="group-hover:opacity-100" />
          <span class="text-[10px] tracking-[0.08em] uppercase text-zinc-400">Ecosystem Vendor</span>
        </a>
        <div class="w-px h-8 self-center bg-zinc-200" aria-hidden="true"></div>
        <a href="https://kinetick.com/NinjaTrader" target="_blank" rel="noopener noreferrer" aria-label="Kinetick — official market data partner" class="flex flex-col items-center gap-2 group">
          <img src="/logos/kinetick-logo.png" alt="Kinetick" style="height:28px; width:auto; object-fit:contain; opacity:0.85; transition:opacity 0.2s;" class="group-hover:opacity-100" />
          <span class="text-[10px] tracking-[0.08em] uppercase text-zinc-400">Market Data Partner</span>
        </a>
      </div>
      <!-- C14v2: platform coverage cards — answers "can I even use this?" AND
           "is my broker / funded account covered?". Tradovate & Ironbeam are
           infrastructure brands most funded traders don't recognize by name,
           so each card says WHO it covers, and the line below teaches the
           credentials test. Wordmark-style text for Tradovate/Ironbeam until
           we have official logo files — do not hand-redraw third-party marks. -->
      <div class="mt-9 pt-7 border-t border-zinc-100">
        <p class="text-[10px] tracking-[0.14em] uppercase text-zinc-400 mb-4">Works with</p>
        <div class="grid sm:grid-cols-3 gap-3 max-w-3xl mx-auto text-left">
          <a href="/platforms" class="rounded-2xl border border-zinc-200 bg-white p-4 hover:border-emerald-300 transition group">
            <div class="flex items-center justify-between gap-2 mb-2 min-h-[26px]">
              <img src="/logos/ninjatrader-wordmark.png" alt="NinjaTrader 8" style="height:15px; width:auto; object-fit:contain; opacity:0.85;" class="group-hover:opacity-100 transition" />
              <span class="shrink-0 px-1.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wide bg-emerald-100 text-emerald-800">Available now</span>
            </div>
            <p class="text-[11.5px] leading-snug text-zinc-500">Native add-on &mdash; works with any broker or funded account you trade through NinjaTrader&nbsp;8.</p>
          </a>
          <a href="/platforms" class="rounded-2xl border border-zinc-200 bg-white p-4 hover:border-emerald-300 transition group">
            <div class="flex items-center justify-between gap-2 mb-2 min-h-[26px]">
              <span class="flex items-center gap-1.5">
                <img src="/logos/tradovate-mark.png" alt="" aria-hidden="true" style="height:18px; width:auto; object-fit:contain; opacity:0.9;" class="group-hover:opacity-100 transition" />
                <span class="text-[16px] font-bold tracking-tight text-zinc-800" style="line-height:1;">Tradovate</span>
              </span>
              <span class="shrink-0 px-1.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wide bg-amber-100 text-amber-800">Early access</span>
            </div>
            <p class="text-[11.5px] leading-snug text-zinc-500">Standalone app &mdash; the brokerage infrastructure behind many funded-trader programs.</p>
          </a>
          <a href="/platforms" class="rounded-2xl border border-zinc-200 bg-white p-4 hover:border-emerald-300 transition group">
            <div class="flex items-center justify-between gap-2 mb-2 min-h-[26px]">
              <img src="/logos/ironbeam-wordmark.png" alt="Ironbeam" style="height:15px; width:auto; object-fit:contain; opacity:0.9;" class="group-hover:opacity-100 transition" />
              <span class="shrink-0 px-1.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wide bg-amber-100 text-amber-800">Early access</span>
            </div>
            <p class="text-[11.5px] leading-snug text-zinc-500">Standalone app &mdash; connects to any account cleared through Ironbeam.</p>
          </a>
        </div>
        <p class="mt-4 text-[13px] text-zinc-500 max-w-2xl mx-auto">
          Not sure what your funded account runs on? Check the credentials you sign in with &mdash; a NinjaTrader, Tradovate, or
          Ironbeam login means Meridian covers it.
          <a href="/platforms#prop-firms" class="text-emerald-700 hover:underline font-semibold whitespace-nowrap">Funded-account guide &rarr;</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── SUPERSET ───────────────────────── -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div data-reveal class="text-center mb-12">
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">NOT A DIFFERENT TOOL. A STRONGER ONE.</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">
        Every other tool does one piece.<br />Meridian does all of it.
      </h2>
      <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">Keep the safety net you already trust. Gain the layer none of them have.</p>
    </div>
    <div data-reveal class="grid md:grid-cols-2 gap-5 max-w-4xl mx-auto">
      <div class="rounded-2xl border border-zinc-200 bg-white p-7">
        <div class="text-sm font-semibold text-zinc-500 mb-4">What every risk tool does</div>
        <ul class="space-y-3 text-zinc-700">
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>Daily loss limit</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>Single-trade loss cap</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>P&amp;L / drawdown caps</span></li>
          <li class="flex gap-3"><span class="text-zinc-400">&check;</span><span>Loss-streak cutoff</span></li>
        </ul>
        <p class="mt-5 text-sm text-zinc-500">Meridian does all of this too.</p>
      </div>
      <div class="rounded-2xl border-2 border-emerald-500 bg-emerald-50/40 p-7">
        <div class="text-sm font-semibold text-emerald-700 mb-4">What only Meridian adds</div>
        <ul class="space-y-3 text-zinc-800">
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Real-time <strong>behavior</strong> detection &mdash; 7 signals (revenge, oversizing, tilt&hellip;)</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>A baseline that learns how <em>you</em> trade &mdash; not a generic average</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>It steps in <em>before</em> the order, not after the loss</span></li>
          <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>The whole loop: monitor &middot; guard &middot; journal &middot; review</span></li>
        </ul>
        <p class="mt-5 text-sm text-emerald-700 font-medium">No limit-based tool can do this.</p>
      </div>
    </div>
    <div data-reveal class="max-w-3xl mx-auto mt-10 rounded-2xl calloutd px-8 py-9 text-center">
      <p class="eyebrow text-[11px] font-bold text-emerald-400 mb-3">A LIMIT REACTS. MERIDIAN PREVENTS.</p>
      <p class="text-lg md:text-xl leading-relaxed text-zinc-200">
        A $500 daily loss limit can't stop you until you're already down <span class="text-rose-400 font-semibold tnum">&minus;$500</span> &mdash; four revenge trades too late.<br class="hidden md:block" />
        Meridian catches the revenge trading at <span class="text-emerald-400 font-semibold">trade two</span>, before the damage is done.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── WHY IT MATTERS ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-5xl mx-auto px-6 py-24">
      <div data-reveal class="text-center mb-12">
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">WHY IT MATTERS</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">
          Most blown accounts aren't<br />bad strategy. They're one bad session.
        </h2>
        <p class="mt-5 text-lg text-zinc-600 max-w-2xl mx-auto">
          The strategy you spent months on rarely fails you. One session does &mdash; the entries you'd have rejected
          yesterday, the size you'd ruled out, the stop you moved twice. A daily loss limit catches that at the end.
          Meridian catches the behavior that's causing it.
        </p>
      </div>
      <div data-reveal class="grid sm:grid-cols-3 gap-4 max-w-3xl mx-auto text-center">
        <div class="rounded-2xl border border-zinc-200 p-6"><div class="text-3xl font-extrabold text-zinc-900 tnum">$89&ndash;540</div><div class="mt-2 text-sm text-zinc-600">A prop-firm evaluation. Lost if you fail it.</div></div>
        <div class="rounded-2xl border border-zinc-200 p-6"><div class="text-3xl font-extrabold text-zinc-900 tnum">$300&ndash;800</div><div class="mt-2 text-sm text-zinc-600">One revenge session &mdash; and the funded account it can blow.</div></div>
        <div class="rounded-2xl border-2 border-emerald-500 p-6"><div class="text-3xl font-extrabold text-emerald-700 tnum">$49.99</div><div class="mt-2 text-sm text-zinc-600">Meridian. One month.</div></div>
      </div>
      <p class="text-center mt-5 text-xs text-zinc-400 max-w-2xl mx-auto">
        Illustrative &mdash; prop-firm fees are publicly listed; session-loss ranges are self-reported by users. Meridian does not guarantee trading results.
      </p>
    </div>
  </section>

  <!-- ───────────────────────── LIVE MONITOR ───────────────────────── -->
  <section id="how" class="max-w-6xl mx-auto px-6 py-24 grid lg:grid-cols-2 gap-14 items-center scroll-mt-24">
    <div data-reveal>
      <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">LIVE MONITOR</p>
      {/* The "watches how you trade" line lives on /psi-monitor (its thesis) —
          home teases the same idea with its own words so a visitor never reads
          the identical headline twice. */}
      <h2 class="text-3xl md:text-[2.7rem] font-bold tracking-tight text-zinc-900 leading-[1.1]">
        Your discipline, as one<br />live number: 0&ndash;100.
      </h2>
      <p class="mt-5 text-lg text-zinc-600 leading-relaxed">
        Meridian turns your order flow into one live score from 0&ndash;100, updated in real time after every fill. When tilt
        creeps in, you watch the number fall &mdash; before your P&amp;L does.
      </p>
      <ul class="mt-6 space-y-3 text-zinc-700">
        <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Seven behavioral signals in one number &mdash; so you can see your discipline in real time</span></li>
        <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>Measured against <em>your</em> baseline, not a generic average</span></li>
        <li class="flex gap-3"><span class="text-emerald-600 font-bold">&check;</span><span>An always-on HUD that sits over your chart</span></li>
      </ul>
    </div>
    <div data-reveal class="win"><img src="/m/monitor.png" alt="Meridian live PSI Monitor — radial gauge, PSI timeline, and behavioral signal bars" /></div>
  </section>

  <!-- ───────────────────────── 7 SIGNALS ───────────────────────── -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div data-reveal class="text-center mb-12">
        <p class="eyebrow text-[11px] font-bold text-emerald-700 mb-3">WHAT IT CATCHES</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">The 7 behaviors that quietly kill accounts.</h2>
        <p class="mt-4 text-lg text-zinc-600 max-w-2xl mx-auto">Every one is scored in real time, against your own history.</p>
      </div>
