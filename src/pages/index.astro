<script>
  // ——— Scroll-triggered fade-up ———
  function initFadeUp() {
    const els = document.querySelectorAll<HTMLElement>('.fade-up');
    if (!els.length || !('IntersectionObserver' in window)) {
      els.forEach((el) => el.classList.add('is-visible'));
      return;
    }
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.01, rootMargin: '0px' }
    );
    els.forEach((el) => observer.observe(el));
    requestAnimationFrame(() => {
      els.forEach((el) => {
        if (el.classList.contains('is-visible')) return;
        const r = el.getBoundingClientRect();
        const h = window.innerHeight || 0;
        if (r.top < h + 1 && r.bottom > -1) el.classList.add('is-visible');
      });
    });
  }

  // ——— Word-blur animation ———
  // Uses TreeWalker to wrap only text nodes, preserving all HTML tags intact
  function initWordBlur() {
    const targets = document.querySelectorAll<HTMLElement>('.word-blur-target');
    if (!('IntersectionObserver' in window)) {
      targets.forEach((el) => el.classList.add('word-blur-done'));
      return;
    }
    targets.forEach((el) => {
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
      const textNodes: Text[] = [];
      let node: Text | null;
      while ((node = walker.nextNode() as Text | null)) {
        if (node.nodeValue && node.nodeValue.trim()) textNodes.push(node);
      }
      let wordIdx = 0;
      textNodes.forEach((textNode) => {
        const text = textNode.nodeValue || '';
        const parts = text.split(/(\s+)/);
        const frag = document.createDocumentFragment();
        parts.forEach((part) => {
          if (/^\s+$/.test(part) || part === '') {
            frag.appendChild(document.createTextNode(part));
          } else {
            const span = document.createElement('span');
            span.className = 'word-blur-word';
            span.style.animationDelay = `${wordIdx++ * 45}ms`;
            span.textContent = part;
            frag.appendChild(span);
          }
        });
        textNode.parentNode?.replaceChild(frag, textNode);
      });
    });
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('word-blur-done');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    targets.forEach((el) => observer.observe(el));
    // Hero heading is already visible — trigger immediately
    const hero = document.querySelector('.word-blur-target') as HTMLElement | null;
    if (hero) hero.classList.add('word-blur-done');
  }

  // ——— Accordion (step-detail) ———
  function initAccordion() {
    const items  = Array.from(document.querySelectorAll<HTMLElement>('[data-acc-item]'));
    const images = Array.from(document.querySelectorAll<HTMLElement>('[data-step-img]'));
    const panel  = document.getElementById('step-img-panel');
    if (!items.length) return;
    let current = 0;

    const prevBtn = panel?.querySelector<HTMLButtonElement>('[data-step-carousel-prev]');
    const nextBtn = panel?.querySelector<HTMLButtonElement>('[data-step-carousel-next]');
    const liveRoot = panel?.querySelector<HTMLElement>('[data-step-live-carousel]');
    const liveCarouselStep = liveRoot?.dataset.stepImg != null ? Number(liveRoot.dataset.stepImg) : -1;
    let liveIdx = 0;

    function liveSlides() {
      return Array.from(liveRoot?.querySelectorAll<HTMLElement>('[data-step-carousel-slide]') ?? []);
    }

    function setLiveNav(on: boolean) {
      [prevBtn, nextBtn].forEach((btn) => {
        if (!btn) return;
        btn.style.visibility = on ? 'visible' : 'hidden';
        btn.style.pointerEvents = on ? 'auto' : 'none';
        btn.setAttribute('aria-hidden', on ? 'false' : 'true');
        btn.tabIndex = on ? 0 : -1;
      });
    }

    function showLiveCarousel(delta: number) {
      const slides = liveSlides();
      if (slides.length <= 1) return;
      liveIdx = (liveIdx + delta + slides.length) % slides.length;
      slides.forEach((el, si) => el.classList.toggle('is-active', si === liveIdx));
    }

    function syncLiveCarouselNav() {
      const on = liveCarouselStep >= 0 && current === liveCarouselStep && liveSlides().length > 1;
      setLiveNav(on);
    }

    function setPanelBg(idx: number) {
      if (!panel) return;
      const bg = images[idx]?.dataset.stepBg ?? '#f4f4f5';
      panel.style.background = bg;
    }

    function activate(next: number) {
      if (next === current) return;

      if (liveCarouselStep >= 0 && current === liveCarouselStep && next !== liveCarouselStep) {
        liveIdx = 0;
        liveSlides().forEach((el, si) => el.classList.toggle('is-active', si === 0));
      }

      images.forEach((img, i) => {
        img.classList.toggle('acc-img-visible', i === next);
        img.style.opacity = i === next ? '1' : '0';
      });

      items.forEach((item, i) => {
        const isActive = i === next;
        item.classList.toggle('acc-item-active', isActive);
        item.setAttribute('tabindex', isActive ? '0' : '-1');
        const body = item.querySelector<HTMLElement>('.acc-item-body');
        if (body) body.style.maxHeight = isActive ? body.scrollHeight + 'px' : '0';
      });

      setPanelBg(next);
      current = next;
      syncLiveCarouselNav();
    }

    prevBtn?.addEventListener('click', () => showLiveCarousel(-1));
    nextBtn?.addEventListener('click', () => showLiveCarousel(1));

    // Click & keyboard
    items.forEach((item, i) => {
      item.addEventListener('click', () => activate(i));
      item.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(i); }
        else if (e.key === 'ArrowDown') { e.preventDefault(); activate((i + 1) % items.length); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); activate((i - 1 + items.length) % items.length); }
      });
    });

    // Init
    images.forEach((img, i) => {
      img.classList.toggle('acc-img-visible', i === 0);
      img.style.opacity = i === 0 ? '1' : '0';
    });
    setPanelBg(0);
    syncLiveCarouselNav();
    const firstBody = items[0]?.querySelector<HTMLElement>('.acc-item-body');
    if (firstBody) firstBody.style.maxHeight = firstBody.scrollHeight + 'px';
  }

  // ——— Intel showcase tabs (left labels, per-tab image carousel) ———
  function initIntelTabs() {
    const root = document.querySelector<HTMLElement>('[data-intel-showcase]');
    if (!root) return;
    const tabs    = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-intel-tab]'));
    const views   = Array.from(root.querySelectorAll<HTMLElement>('[data-intel-view]'));
    const panel   = root.querySelector<HTMLElement>('#intel-showcase-panel');
    const prevBtn = root.querySelector<HTMLButtonElement>('[data-intel-carousel-prev]');
    const nextBtn = root.querySelector<HTMLButtonElement>('[data-intel-carousel-next]');
    if (!tabs.length || !views.length) return;

    // slideIndex[tabIdx] tracks which slide is active within that tab
    const slideIndex = views.map(() => 0);
    let currentTab = 0;

    function slideCount(tabIdx: number) {
      return views[tabIdx]?.querySelectorAll<HTMLElement>('[data-intel-slide]').length ?? 0;
    }

    function showSlide(tabIdx: number) {
      const view = views[tabIdx];
      if (!view) return;
      const imgs = Array.from(view.querySelectorAll<HTMLElement>('[data-intel-slide]'));
      const n = imgs.length;
      if (!n) return;
      let idx = ((slideIndex[tabIdx] % n) + n) % n;
      slideIndex[tabIdx] = idx;
      imgs.forEach((img, si) => img.classList.toggle('is-active', si === idx));
    }

    function setCarouselBtn(btn: HTMLButtonElement | null | undefined, on: boolean) {
      if (!btn) return;
      btn.style.visibility = on ? 'visible' : 'hidden';
      btn.style.pointerEvents = on ? 'auto' : 'none';
      btn.setAttribute('aria-hidden', on ? 'false' : 'true');
      btn.tabIndex = on ? 0 : -1;
    }

    function updateNav() {
      const show = slideCount(currentTab) > 1;
      setCarouselBtn(prevBtn, show);
      setCarouselBtn(nextBtn, show);
    }

    function activateTab(next: number) {
      if (next < 0 || next >= tabs.length) return;
      currentTab = next;
      tabs.forEach((tab, i) => {
        const on = i === currentTab;
        tab.setAttribute('aria-selected', on ? 'true' : 'false');
        tab.tabIndex = on ? 0 : -1;
        tab.classList.toggle('acc-item-active', on);
      });
      views.forEach((v, i) => {
        const on = i === currentTab;
        v.classList.toggle('is-active', on);
        v.setAttribute('aria-hidden', on ? 'false' : 'true');
      });
      showSlide(currentTab);
      updateNav();
      if (panel && tabs[currentTab]) panel.setAttribute('aria-labelledby', tabs[currentTab].id);
    }

    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => { activateTab(i); tab.focus(); });
      tab.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
          e.preventDefault(); const n = (i + 1) % tabs.length; activateTab(n); tabs[n]?.focus();
        } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
          e.preventDefault(); const n = (i - 1 + tabs.length) % tabs.length; activateTab(n); tabs[n]?.focus();
        } else if (e.key === 'Home') { e.preventDefault(); activateTab(0); tabs[0]?.focus(); }
          else if (e.key === 'End')  { e.preventDefault(); const l = tabs.length - 1; activateTab(l); tabs[l]?.focus(); }
      });
    });

    prevBtn?.addEventListener('click', () => { slideIndex[currentTab]--; showSlide(currentTab); });
    nextBtn?.addEventListener('click', () => { slideIndex[currentTab]++; showSlide(currentTab); });

    // Init
    activateTab(0);
  }

  function boot() {
    initFadeUp();
    initWordBlur();
    initAccordion();
    initIntelTabs();
  }

  // View Transitions (ClientRouter): soft navigations do not fire DOMContentLoaded again.
  // astro:page-load runs after the initial full load and after each client-side navigation.
  document.addEventListener('astro:page-load', boot);
</script>

<script>
  // ─── Section A: scroll-triggered sequential timeline reveal ───
  // Story order: Post-session → After damage → At limit → [pause] → Before the order (Meridian)
  (function () {
    var block = document.querySelector('.timeline-block');
    if (!block) return;

    var axisLine  = block.querySelector('.timeline-axis-line');
    var dot1 = block.querySelector('.timeline-dot-1');
    var dot2 = block.querySelector('.timeline-dot-2');
    var dot3 = block.querySelector('.timeline-dot-3');
    var dot4 = block.querySelector('.timeline-dot-4');
    var card1 = block.querySelector('.timeline-card-1');
    var card2 = block.querySelector('.timeline-card-2');
    var card3 = block.querySelector('.timeline-card-3');
    var card4 = block.querySelector('.timeline-card-4');
    var punchline = document.getElementById('timeline-punchline');

    // Respect prefers-reduced-motion — reveal instantly
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    function show(el, transition, transform) {
      if (!el) return;
      el.style.transition = transition;
      el.style.opacity = '1';
      if (transform !== undefined) el.style.transform = transform;
    }

    function runSequence() {
      // 0 ms — axis draws left → right (1.2 s)
      setTimeout(function () {
        show(axisLine, 'transform 1200ms ease-out', 'scaleX(1)');
      }, 0);

      // 600 ms — Post-session label + dot (rightmost: column 4)
      setTimeout(function () { show(dot4, 'opacity 500ms ease-out, transform 500ms ease-out', 'translateY(0)'); }, 600);
      // 780 ms — Post-session card rises
      setTimeout(function () { show(card4, 'opacity 650ms ease-out, transform 650ms ease-out', 'translateY(0)'); }, 780);

      // 1150 ms — After damage label + dot (column 3)
      setTimeout(function () { show(dot3, 'opacity 500ms ease-out, transform 500ms ease-out', 'translateY(0)'); }, 1150);
      // 1330 ms — After damage card rises
      setTimeout(function () { show(card3, 'opacity 650ms ease-out, transform 650ms ease-out', 'translateY(0)'); }, 1330);

      // 1700 ms — At limit label + dot (column 2)
      setTimeout(function () { show(dot2, 'opacity 500ms ease-out, transform 500ms ease-out', 'translateY(0)'); }, 1700);
      // 1880 ms — At limit card rises
      setTimeout(function () { show(card2, 'opacity 650ms ease-out, transform 650ms ease-out', 'translateY(0)'); }, 1880);

      // ── 900 ms dramatic pause — audience sits with "so what came before all this?" ──

      // 2780 ms — Before the order dot pulses in (column 1)
      setTimeout(function () { show(dot1, 'opacity 700ms ease-out, transform 700ms ease-out', 'translateY(0)'); }, 2780);

      // 3000 ms — Meridian card springs in with bounce settle
      setTimeout(function () {
        if (!card1) return;
        card1.style.transition = 'opacity 700ms ease-out, transform 1000ms cubic-bezier(0.34,1.56,0.64,1), box-shadow 700ms ease-out';
        card1.style.opacity = '1';
        card1.style.transform = 'translateY(-5px) scale(1)';
      }, 3000);

      // 4300 ms — Punchline fades up (audience has absorbed all 4 stages)
      setTimeout(function () {
        show(punchline, 'opacity 900ms ease-out, transform 900ms ease-out', 'translateY(0)');
      }, 4300);
    }

    var observer = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting) {
        runSequence();
        observer.disconnect();
      }
    }, { threshold: 0.12 });
    observer.observe(block);
  })();
</script>
