---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Meridian — The First Real-Time Psychological Stability Index for Active Traders',
  ignoreTitleTemplate: true,
};

const marqueeRow1 = [
  {
    quote: "Three months in. I thought I had clean execution — the overtrading metric disagreed from day one.",
    name: 'Jason K.',
    role: 'Futures day trader',
  },
  {
    quote: "Passed my third Apex evaluation. The first two I blew up on days where, in hindsight, I should have just closed the platform.",
    name: 'Mike R.',
    role: 'Prop firm trader',
  },
  {
    quote: "Turned out I wasn't losing because of my entries. I was adding to losing positions and ignoring my own rules.",
    name: 'Anonymous',
    role: '',
  },
  {
    quote: "Didn't want another subscription. Tried the trial anyway. Kept it — the overlay is actually readable mid-session without being in the way.",
    name: 'Rina M.',
    role: 'Day trader',
  },
];

const marqueeRow2 = [
  {
    quote: "The caution signal fired and I decided I could manage through it. Twenty minutes later I had hit my daily limit. I can't blame the tool — I ignored it.",
    name: 'Sara',
    role: 'ES trader',
  },
  {
    quote: "If someone had told me a revenge-entry detector would matter more than another indicator, I wouldn't have believed them.",
    name: 'Alex Nowak',
    role: 'Prop trader',
  },
  {
    quote: "Four years trading NQ. Thought I had a solid read on my own behavior. First week of data showed me several habits I wasn't aware of.",
    name: 'James O.',
    role: 'Day trader',
  },
  {
    quote: "Took a few sessions to calibrate. Once it did, the alerts started making sense — I could trace each one back to a specific pattern.",
    name: 'Priya S.',
    role: 'Futures trader',
  },
];

const steps = [
  {
    label: 'Configure',
    desc: 'Set your rules once',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    label: 'Live Monitor',
    desc: 'PSI updates in <100ms',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>',
  },
  {
    label: 'Guard',
    desc: 'Automated enforcement',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>',
  },
  {
    label: 'Review & Intel',
    desc: 'Patterns across sessions',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>',
  },
];

const signals = [
  { name: 'Revenge Entry',     desc: 'Re-entry after loss with elevated size' },
  { name: 'Stop Manipulation', desc: 'Widening stops in the adverse direction' },
  { name: 'Size Spike',        desc: 'Position exceeds your declared rule' },
  { name: 'Hold Bias',         desc: 'Abnormal hold duration vs your baseline' },
  { name: 'Position Overstay', desc: 'Holding a loser past your 90th-percentile time' },
  { name: 'Rule Violations',   desc: 'Trading outside your declared session rules' },
  { name: 'Overtrading Pace',  desc: 'Entry frequency accelerating vs history' },
];
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Start free trial',
        href: '/pricing',
      },
      { text: 'How it works', href: '#how-it-works' },
    ]}
  >
    <Fragment slot="title">
      Every trader has a plan.
      <br />
      <span class="text-emerald-700 dark:text-emerald-500">The market's job is to make you forget it.</span>
    </Fragment>

    <Fragment slot="subtitle">
      <strong class="text-zinc-900 dark:text-zinc-100 font-semibold">Meridian</strong> is the first real-time behavioral and psychological stability monitor for active traders. Seven behavioral patterns, grounded in cognitive science. PSI updates in under 100ms.
    </Fragment>
  </Hero>

  <!-- Stats bar -->
  <section class="px-6 -mt-8 md:-mt-12 fade-up">
    <div class="max-w-6xl mx-auto">
      <Stats
        stats={[
          { title: 'Live behavioral signals', amount: '7' },
          { title: 'Update latency', amount: '<100ms' },
          { title: 'Session history', amount: '5 yr' },
          { title: 'Free trial', amount: '7 day' },
        ]}
      />
    </div>
  </section>

  <!-- ——— PROBLEM ——— -->
  <section class="section">
    <div class="container-narrow text-center">
      <p class="eyebrow mb-5 fade-up">The gap</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-6 fade-up">
        Institutional traders have risk managers.<br />You have yourself.
      </h2>
      <p class="lead mb-14 fade-up">
        They have compliance officers, position limits, and systems that enforce rules outside their control.
        Retail traders have experience and hard-won rules — and nothing to stop them from breaking those rules
        the moment it matters most.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-2xl mx-auto text-left fade-up">
        {[
          'Added size right after a loss',
          'Moved the stop to "give it a little more room"',
          'Took the next trade too fast — still feeling the last one',
          'Held a loser longer than your plan ever allowed',
          'Broke your session rule — just this once',
          'Hit your daily limit and took one more anyway',
        ].map((item) => (
          <div class="flex items-center gap-3 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl px-4 py-3.5">
            <svg class="w-4 h-4 text-red-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <span class="text-sm text-zinc-700 dark:text-zinc-300">{item}</span>
          </div>
        ))}
      </div>

      <p class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 max-w-xl mx-auto mt-16 fade-up">
        Meridian doesn't tell you what to trade.<br />
        It tells you <em class="text-emerald-700 dark:text-emerald-500 not-italic">where you are</em> — so you can decide whether to continue.
      </p>
    </div>
  </section>

  <!-- ——— ROADMAP / HOW IT WORKS ——— -->
  <section id="how-it-works" class="section bg-zinc-50 dark:bg-zinc-900/40 border-y border-zinc-100 dark:border-zinc-800">
    <div class="container-wide">
      <div class="text-center mb-20 max-w-2xl mx-auto">
        <p class="eyebrow mb-4 fade-up">How it works</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5 fade-up">
          Before. During. After. Every session.
        </h2>
        <p class="lead fade-up">
          Meridian fits into every stage of how you trade — from setup, to real-time monitoring and
          automatic guardrails, to post-session review.
        </p>
      </div>

      <!-- 4-step roadmap -->
      <div class="relative">
        <!-- dotted connector line (desktop) -->
        <div
          class="hidden md:block absolute top-6 left-[12.5%] right-[12.5%] border-t border-dashed border-zinc-300 dark:border-zinc-700"
          aria-hidden="true"
        ></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
          {[
            { num: '01', title: 'Configure',     sub: 'Any strategy. Any style.',      bullets: ['Session rules & time windows', 'Size limits and stop conventions', 'Profile settings per account'] },
            { num: '02', title: 'Live Monitor',  sub: '7 signals. <100ms updates.',    bullets: ['PSI score updates in real time', 'Seven behavioral signal bars', 'Floating HUD overlay'] },
            { num: '03', title: 'Guard',         sub: 'Rules that enforce themselves.', bullets: ['6 trigger conditions', '5 response levels', 'Toast to broker disconnect'] },
            { num: '04', title: 'Review & Intel', sub: 'Every session. Every pattern.', bullets: ['PSI, Composure, and trade stats', 'Monthly digest & P&L correlation', "Today's Risk Brief"] },
          ].map((step, i) => (
            <div class="fade-up" style={`transition-delay:${i * 80}ms`}>
              <!-- Number disc -->
              <div class="relative z-10 mx-auto w-12 h-12 rounded-full bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 flex items-center justify-center mb-5 text-sm font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
                {step.num}
              </div>
              <div class="text-center mb-5">
                <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100 mb-1">{step.title}</h3>
                <p class="text-sm text-zinc-500 dark:text-zinc-400">{step.sub}</p>
              </div>
              <ul class="card card-hover p-5 space-y-2.5">
                {step.bullets.map((b) => (
                  <li class="flex items-start gap-2.5 text-sm text-zinc-600 dark:text-zinc-300">
                    <svg class="mt-0.5 w-4 h-4 text-emerald-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ——— STEP DETAIL — tabbed slider ——— -->
  <section id="step-detail" class="section overflow-x-hidden bg-zinc-50/60 dark:bg-zinc-900/20 border-y border-zinc-100 dark:border-zinc-800/60">
    <div class="container-wide">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <p class="eyebrow mb-4 fade-up">See it in action</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 fade-up">
          Pick a stage. See what you'd get.
        </h2>
      </div>

      <!-- Split layout: vertical tab rail on desktop, horizontal sticky tabs on mobile -->
      <div class="md:grid md:grid-cols-[220px_1fr] lg:grid-cols-[240px_1fr] md:gap-12 lg:gap-16">

        <!-- Tab rail — sticky on both breakpoints -->
        <div
          role="tablist"
          aria-label="Product stages"
          class="step-tab-rail sticky z-20 top-0 md:top-24 -mx-6 md:mx-0 px-6 md:px-0 mb-6 md:mb-0 bg-white/90 dark:bg-zinc-950/90 backdrop-blur-md md:bg-transparent md:dark:bg-transparent md:backdrop-blur-0 border-b md:border-b-0 border-zinc-100 dark:border-zinc-800 flex md:flex-col gap-0 md:gap-1 overflow-x-auto md:overflow-visible md:self-start"
        >
          {steps.map((step, i) => (
            <button
              type="button"
              role="tab"
              data-step-tab={i}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`step-panel-${i}`}
              id={`step-tab-${i}`}
              class:list={['step-tab-btn', { 'is-active': i === 0 }]}
            >
              <span class="step-tab-icon" aria-hidden="true" set:html={step.icon} />
              <span class="step-tab-body">
                <span class="step-tab-num">0{i + 1}</span>
                <span class="step-tab-label">{step.label}</span>
                <span class="step-tab-desc">{step.desc}</span>
              </span>
            </button>
          ))}
        </div>

        <!-- Sliding panels -->
        <div class="overflow-hidden min-w-0">
          <div id="step-panels-track" class="flex" style="width:400%;">
          <!-- Panel 0: Configure -->
          <div class="w-1/4" role="tabpanel" id="step-panel-0" aria-labelledby="step-tab-0">
            <div class="grid lg:grid-cols-[3fr_2fr] gap-8 lg:gap-16 items-center">
              <div class="rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800 shadow-lg shadow-zinc-200/60 dark:shadow-black/30">
                <img src="/screenshots/baseline-learning.png" alt="Meridian personal baseline configuration panel" class="w-full h-auto block" loading="lazy" />
              </div>
              <div>
                <p class="eyebrow mb-3">Configure</p>
                <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5">Set your rules once. Meridian applies them every session.</h3>
                <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-6">
                  Your profile defines how Meridian reads your behavior — position limits, session
                  windows, stop conventions. Every alert is personalized to your declared rules, not a
                  generic threshold.
                </p>
                <ul class="space-y-2.5 text-sm text-zinc-700 dark:text-zinc-300">
                  {['Session rules & time windows', 'Position size limits and stop conventions', 'Profile settings per account', 'Personal baseline adapts with each session'].map((item) => (
                    <li class="flex items-start gap-2.5"><span class="mt-1.5 h-1 w-1 rounded-full bg-emerald-600 shrink-0"></span>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <!-- Panel 1: Live Monitor -->
          <div class="w-1/4" role="tabpanel" id="step-panel-1" aria-labelledby="step-tab-1">
            <div class="grid lg:grid-cols-[3fr_2fr] gap-8 lg:gap-16 items-center">
              <div class="rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800 shadow-lg shadow-zinc-200/60 dark:shadow-black/30">
                <img src="/screenshots/psi-critical.png" alt="Meridian PSI Monitor showing a Critical score with seven behavioral signal bars" class="w-full h-auto block" loading="lazy" />
              </div>
              <div>
                <p class="eyebrow mb-3">Live Monitor</p>
                <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5">Your stability score, updating in real time.</h3>
                <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-6">
                  PSI updates within 100ms of every fill, every stop move, every size decision. Seven
                  behavioral signal bars show exactly what is affecting the score right now.
                </p>
                <ul class="space-y-2.5 text-sm text-zinc-700 dark:text-zinc-300">
                  {['PSI score updates after every action in <100ms', 'Seven behavioral signal bars visible while trading', 'Floating HUD overlay — stays readable mid-session', 'Session stats: trades, win rate, alerts, duration'].map((item) => (
                    <li class="flex items-start gap-2.5"><span class="mt-1.5 h-1 w-1 rounded-full bg-emerald-600 shrink-0"></span><span set:html={item} /></li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <!-- Panel 2: Guard -->
          <div class="w-1/4" role="tabpanel" id="step-panel-2" aria-labelledby="step-tab-2">
            <div class="grid lg:grid-cols-[3fr_2fr] gap-8 lg:gap-16 items-center">
              <div class="rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800 shadow-lg shadow-zinc-200/60 dark:shadow-black/30">
                <img src="/screenshots/psi-performance.png" alt="Meridian PSI vs P&amp;L correlation chart" class="w-full h-auto block" loading="lazy" />
              </div>
              <div>
                <p class="eyebrow mb-3">Guard</p>
                <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5">Rules that enforce themselves — even when you won't.</h3>
                <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-6">
                  Guard is a commitment device. When you are calm, you write the rules. When the moment
                  comes, Guard enforces them automatically — no decision required from you.
                </p>
                <ul class="space-y-2.5 text-sm text-zinc-700 dark:text-zinc-300">
                  {['6 configurable trigger conditions', '5 response levels — quiet toast to full broker disconnect', 'Set once, active every session automatically', 'No manual override required in the heat of the moment'].map((item) => (
                    <li class="flex items-start gap-2.5"><span class="mt-1.5 h-1 w-1 rounded-full bg-emerald-600 shrink-0"></span>{item}</li>
                  ))}
                </ul>
                <a href="/guard" class="btn-tertiary mt-6">
                  Explore Meridian Guard
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Panel 3: Review & Intel -->
          <div class="w-1/4" role="tabpanel" id="step-panel-3" aria-labelledby="step-tab-3">
            <div class="grid lg:grid-cols-[3fr_2fr] gap-8 lg:gap-16 items-center">
              <div class="rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800 shadow-lg shadow-zinc-200/60 dark:shadow-black/30">
                <img src="/screenshots/intel-session-calendar.png" alt="Meridian session calendar showing PSI, Composure and P&amp;L per session" class="w-full h-auto block" loading="lazy" />
              </div>
              <div>
                <p class="eyebrow mb-3">Review & Intel</p>
                <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5">Not just P&amp;L. Whether you traded right.</h3>
                <p class="text-zinc-500 dark:text-zinc-400 leading-relaxed mb-6">
                  Every session is saved with PSI score, Composure, and trade stats. Over months,
                  behavioral patterns become visible — and so does the improvement.
                </p>
                <ul class="space-y-2.5 text-sm text-zinc-700 dark:text-zinc-300">
                  {['Session log: PSI, Composure, and trade stats', 'Monthly behavioral grade and P&L correlation', "Today's Risk Brief — built from your own history", '5 years of session history stored locally'].map((item) => (
                    <li class="flex items-start gap-2.5"><span class="mt-1.5 h-1 w-1 rounded-full bg-emerald-600 shrink-0"></span>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          </div> <!-- /step-panels-track -->
        </div> <!-- /overflow-hidden -->
      </div> <!-- /md:grid -->
    </div> <!-- /container-wide -->
  </section>

  <!-- ——— SEVEN DIMENSIONS ——— -->
  <section class="section bg-zinc-50 dark:bg-zinc-900/40 border-y border-zinc-100 dark:border-zinc-800">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="eyebrow mb-4 fade-up">Behavioral signals</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5 fade-up">
          Seven patterns. Each tied to a known failure mode.
        </h2>
        <p class="lead fade-up">
          Every signal tracks a behavioral pattern from behavioral-finance research. They run
          independently and combine into a single PSI score.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 fade-up">
        {signals.map((s, i) => (
          <div class="card card-hover p-5 flex items-start gap-4">
            <span class="shrink-0 mt-0.5 w-7 h-7 rounded-lg bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400 text-xs font-semibold flex items-center justify-center">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div>
              <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 mb-1">{s.name}</h3>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/features#seven-dimensions" class="btn-tertiary">
          Read the technical detail
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ——— SESSION HISTORY — before / after comparison ——— -->
  <section class="section">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <p class="eyebrow mb-4 fade-up">Session review and history</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-5 fade-up">
          Not just P&amp;L. Whether you traded right.
        </h2>
        <p class="lead fade-up">
          Meridian tracks discipline session by session. Over time, the pattern becomes visible — and
          so does the improvement.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 fade-up">
        <!-- Before -->
        <div>
          <div class="rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-800">
            <img src="/screenshots/session-log-december.png" alt="Session log December 2025 — Composure 49%, average P&amp;L -$629" class="w-full h-auto block" loading="lazy" />
          </div>
          <div class="mt-4 flex items-center flex-wrap gap-2">
            <span class="text-xs font-semibold px-2.5 py-1 rounded-md bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300">Month 1 — Dec 2025</span>
            <span class="text-sm text-zinc-500 dark:text-zinc-400">Composure <span class="text-zinc-900 dark:text-zinc-100 font-semibold">49%</span></span>
            <span class="text-zinc-300 dark:text-zinc-600">·</span>
            <span class="text-sm text-zinc-500 dark:text-zinc-400">Avg P&amp;L <span class="text-zinc-900 dark:text-zinc-100 font-semibold">&minus;$629</span></span>
          </div>
        </div>

        <!-- After -->
        <div>
