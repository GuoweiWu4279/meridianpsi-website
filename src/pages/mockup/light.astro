---
// MOCKUP B — premium-light shell + dark product windows. Self-contained, noindex.
const I = {
  overview: '/m/overview.png', intel: '/m/intel.png', guard: '/m/guard.png',
  debrief: '/m/debrief.png', patterns: '/m/patterns.png', hud: '/m/hud.png',
};
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="robots" content="noindex" />
<title>Meridian — direction B (light)</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
<style>
  body{font-family:Inter,system-ui,sans-serif;-webkit-font-smoothing:antialiased}
  /* dark "product window" that floats on the light page */
  .win{background:#0b0b0d;border-radius:16px;padding:10px;box-shadow:0 40px 90px -30px rgba(4,40,28,.35),0 12px 30px -12px rgba(0,0,0,.18);border:1px solid rgba(0,0,0,.06)}
  .win img{border-radius:9px;display:block;width:100%}
  .halo{background:radial-gradient(60% 55% at 50% 0%, rgba(5,150,105,.10), transparent 70%)}
  .eyebrow{letter-spacing:.18em}
</style>
</head>
<body class="bg-[#fafafa] text-zinc-600 antialiased selection:bg-emerald-200">

  <!-- nav -->
  <header class="sticky top-0 z-40 backdrop-blur bg-[#fafafa]/80 border-b border-zinc-200/70">
    <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
      <div class="flex items-center gap-2.5">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h4l2 6 4-16 2 10 2-2h4"/></svg>
        <span class="text-zinc-900 font-bold tracking-tight">MERIDIAN</span>
      </div>
      <nav class="hidden md:flex items-center gap-8 text-sm text-zinc-600">
        <a class="hover:text-zinc-900" href="#">Guard</a><a class="hover:text-zinc-900" href="#">Intel</a><a class="hover:text-zinc-900" href="#">Pricing</a>
      </nav>
      <a href="#" class="text-sm font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-4 py-2 rounded-lg transition">Start free trial</a>
    </div>
  </header>

  <!-- hero -->
  <section class="halo relative">
    <div class="max-w-6xl mx-auto px-6 pt-20 pb-10 text-center">
      <p class="eyebrow text-[11px] font-semibold text-emerald-700 mb-5">REAL-TIME BEHAVIORAL RISK · NINJATRADER 8</p>
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-zinc-900 leading-[1.04]">Your edge isn't a<br/>better setup. It's a<br/><span class="text-emerald-600">steadier you.</span></h1>
      <p class="mt-7 max-w-2xl mx-auto text-lg text-zinc-600 leading-relaxed">Meridian reads your discipline in real time, stops the order before you tilt, and shows you exactly what staying composed is worth — to the dollar.</p>
      <div class="mt-9 flex items-center justify-center gap-3">
        <a href="#" class="font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-6 py-3 rounded-xl transition">Start 7-day free trial</a>
        <a href="#" class="font-semibold text-zinc-800 border border-zinc-300 hover:border-zinc-400 px-6 py-3 rounded-xl transition">Watch how it works</a>
      </div>
      <p class="mt-4 text-xs text-zinc-500">No charge until day 7 · From $49.99/mo · Cancel anytime</p>
    </div>
    <div class="max-w-5xl mx-auto px-6 pb-20"><div class="win"><img src={I.overview} alt="Meridian Overview" /></div></div>
  </section>

  <!-- trust strip -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-5 flex flex-wrap items-center justify-center gap-x-10 gap-y-2 text-sm text-zinc-500">
      <span class="text-emerald-700 font-semibold">Official NinjaTrader Ecosystem Vendor</span>
      <span>·</span><span>Local-first, anonymized telemetry</span>
      <span>·</span><span>Runs natively inside NinjaTrader 8</span>
    </div>
  </section>

  <!-- the loop -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="text-center mb-14">
      <p class="eyebrow text-[11px] font-semibold text-emerald-700 mb-3">HOW IT WORKS</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900">One calm loop. Every session.</h2>
      <p class="mt-4 text-zinc-600 max-w-2xl mx-auto">Prime before the open, get caught before the order, learn after the close — and your edge compounds.</p>
    </div>
    <div class="grid md:grid-cols-4 gap-4">
      {[
        ['01','Prime','A 30-second read before you click Start: today’s one risk, yesterday’s lesson, the limits you’re armed with.'],
        ['02','Monitor','A live discipline score built from your order flow. Tilt shows up here before it shows up in your P&L.'],
        ['03','Guard','Cross your own line and Meridian acts — a nudge, a typed acknowledgment, a pause, or a broker cut.'],
        ['04','Review','After the close: what was edge, what was luck, and the one habit costing you the most money.'],
      ].map(([n,t,d]) => (
        <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
          <div class="text-emerald-600 text-xs font-bold mb-3">{n}</div>
          <div class="text-zinc-900 font-semibold text-lg mb-2">{t}</div>
          <p class="text-sm text-zinc-600 leading-relaxed">{d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- killer stat -->
  <section class="border-y border-zinc-200 bg-white">
    <div class="max-w-6xl mx-auto px-6 py-24 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="eyebrow text-[11px] font-semibold text-emerald-700 mb-3">PUT A NUMBER ON IT</p>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 leading-tight">Discipline stops being a feeling.</h2>
        <p class="mt-5 text-zinc-600 leading-relaxed text-lg">Most tools show you P&amp;L. Meridian shows you that your <span class="text-emerald-700 font-semibold">composed</span> sessions earn and your <span class="text-rose-600 font-semibold">tilted</span> ones bleed — so you can finally trade on it.</p>
        <div class="mt-8 grid grid-cols-2 gap-4 max-w-md">
          <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-5"><div class="text-xs text-zinc-500 mb-1">Composed</div><div class="text-3xl font-bold text-emerald-700">+$120<span class="text-base text-zinc-400">/session</span></div></div>
          <div class="rounded-xl border border-rose-200 bg-rose-50 p-5"><div class="text-xs text-zinc-500 mb-1">Tilted</div><div class="text-3xl font-bold text-rose-600">−$59<span class="text-base text-zinc-400">/session</span></div></div>
        </div>
      </div>
      <div class="win"><img src={I.intel} alt="Meridian Intel & Stats" /></div>
    </div>
  </section>

  <!-- guard -->
  <section class="max-w-6xl mx-auto px-6 py-24 grid lg:grid-cols-2 gap-12 items-center">
    <div class="win order-2 lg:order-1"><img src={I.guard} alt="Meridian Guard" /></div>
    <div class="order-1 lg:order-2">
      <p class="eyebrow text-[11px] font-semibold text-emerald-700 mb-3">MERIDIAN GUARD</p>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-zinc-900 leading-tight">Rules you set when calm.<br/>Enforced when you're not.</h2>
      <p class="mt-5 text-zinc-600 leading-relaxed text-lg">Daily loss limit, loss-streak pause, max size, session window — Guard turns your own rules into automatic enforcement, escalating from a quiet nudge to a full broker disconnect.</p>
      <p class="mt-4 text-zinc-800"><span class="text-emerald-700 font-semibold">Strict Lock</span> makes it un-bypassable for a window you choose — for when the tilted version of you wants to turn it off.</p>
    </div>
  </section>

  <!-- final cta -->
  <section class="halo border-t border-zinc-200">
    <div class="max-w-3xl mx-auto px-6 py-28 text-center">
      <h2 class="text-4xl md:text-6xl font-extrabold tracking-tight text-zinc-900 leading-tight">Trade the version of you<br/>that you respect.</h2>
      <div class="mt-9"><a href="#" class="inline-block font-semibold text-white bg-emerald-600 hover:bg-emerald-700 px-8 py-4 rounded-xl text-lg transition">Start your 7-day free trial</a></div>
      <p class="mt-4 text-xs text-zinc-500">No charge until day 7 · Cancel anytime · NinjaTrader 8 required</p>
    </div>
  </section>

  <footer class="border-t border-zinc-200 bg-white"><div class="max-w-6xl mx-auto px-6 py-8 text-xs text-zinc-400 text-center">Mockup B · premium-light + dark product windows · not the live site</div></footer>
</body>
</html>
